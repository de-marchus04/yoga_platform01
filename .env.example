# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=YogaLifeEnterpriseDb

# Public origin for API CORS in production
APP_ORIGIN=https://example.com
APP_ORIGIN_WWW=https://www.example.com

# Public absolute API origin used by the externally hosted Blazor frontend
# Configure this as a GitHub Actions repository variable named FRONTEND_PUBLIC_API_BASE_URL
# Example: https://api.example.com

# Telegram Notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional admin bootstrap controls
AdminPortal__EnableSeedAdminEndpoint=false
AdminPortal__SeedAdminBootstrapToken=
AdminCms__EnableSampleContentBootstrap=false
