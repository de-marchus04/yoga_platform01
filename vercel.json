{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "github": {
    "enabled": false
  },
  "framework": null,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://api.medisha.space/api/$1"
    },
    {
      "source": "/uploads/(.*)",
      "destination": "https://api.medisha.space/uploads/$1"
    },
    {
      "source": "/blogHub/(.*)",
      "destination": "https://api.medisha.space/blogHub/$1"
    },
    {
      "source": "/blogHub",
      "destination": "https://api.medisha.space/blogHub"
    },
    {
      "source": "/health/(.*)",
      "destination": "https://api.medisha.space/health/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/_framework/blazor.boot.json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache"
        }
      ]
    },
    {
      "source": "/Yoga.Client.styles.css(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/app.css(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/css/(.*).css(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/_framework/(.*).wasm",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/wasm"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=604800, immutable"
        }
      ]
    },
    {
      "source": "/retreats/me01",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex"
        }
      ]
    },
    {
      "source": "/retreats/11111111-1111-1111-1111-111111111111",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex"
        }
      ]
    }
  ]
}
