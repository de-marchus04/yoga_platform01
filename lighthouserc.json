{
  "ci": {
    "collect": {
      "numberOfRuns": 2,
      "settings": {
        "preset": "desktop",
        "onlyCategories": ["performance", "accessibility", "best-practices", "seo"],
        "skipAudits": ["is-on-https"]
      },
      "startServerCommand": "npx --yes serve@14 publish/wwwroot -l 5234 -s",
      "startServerReadyPattern": "Accepting connections",
      "startServerReadyTimeout": 120000,
      "url": [
        "http://127.0.0.1:5234/",
        "http://127.0.0.1:5234/retreats",
        "http://127.0.0.1:5234/retreats/actual",
        "http://127.0.0.1:5234/contacts"
      ]
    },
    "assert": {
      "assertions": {
        "cumulative-layout-shift": [
          "warn",
          { "maxNumericValue": 0.1 }
        ],
        "categories:performance": [
          "warn",
          { "minScore": 0.5 }
        ]
      }
    }
  }
}
