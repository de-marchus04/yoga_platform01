{
  "ci": {
    "collect": {
      "numberOfRuns": 2,
      "settings": {
        "preset": "desktop",
        "onlyCategories": ["performance", "accessibility", "best-practices", "seo"],
        "skipAudits": ["is-on-https"],
        "chromeFlags": "--no-sandbox --disable-setuid-sandbox --disable-dev-shm-usage"
      },
      "staticDistDir": "./publish/wwwroot",
      "isSinglePageApplication": true,
      "url": []
    },
    "assert": {
      "assertions": {
        "cumulative-layout-shift": [
          "warn",
          { "maxNumericValue": 0.1 }
        ],
        "categories:performance": [
          "warn",
          { "minScore": 0.5 }
        ],
        "categories:accessibility": [
          "warn",
          { "minScore": 0.85 }
        ]
      }
    },
    "upload": {
      "target": "filesystem",
      "outputDir": "./lighthouse-ci-reports"
    }
  }
}
