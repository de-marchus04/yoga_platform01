@inherits LayoutComponentBase
@inject UserAuthService Auth
@inject UserApiService Api
@inject NavigationManager Nav
@implements IDisposable

<div class="cab-shell @(navOpen ? "nav-open" : "")">

    <!-- Sidebar -->
    <aside class="cab-sidebar">
        <div class="cab-sidebar-inner">

            <!-- Brand -->
            <a href="/" class="cab-brand">
                <span class="cab-brand-logo">Y·L</span>
                <span class="cab-brand-label">Yoga Life</span>
            </a>

            <!-- User card -->
            <div class="cab-user-card">
                <div class="cab-avatar">@Initials</div>
                <div class="cab-user-info">
                    <span class="cab-user-name">@(fullName ?? "—")</span>
                    @if (!string.IsNullOrEmpty(subscriptionTier))
                    {
                        <span class="cab-tier-badge @subscriptionTier.ToLower()">@subscriptionTier</span>
                    }
                    else
                    {
                        <span class="cab-tier-badge none">Базовый</span>
                    }
                </div>
            </div>

            <!-- Navigation -->
            <nav class="cab-nav">
                <a href="/account" class="cab-nav-item @IsActive("/account", exact: true)" @onclick="CloseNav">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
                    <span>Обзор</span>
                </a>
                <a href="/account/products" class="cab-nav-item @IsActive("/account/products")" @onclick="CloseNav">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    <span>Мои продукты</span>
                </a>
                <a href="/account/library" class="cab-nav-item @IsActive("/account/library")" @onclick="CloseNav">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 19.5A2.5 2.5 0 016.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z"/></svg>
                    <span>Библиотека</span>
                </a>
                <a href="/account/streams" class="cab-nav-item @IsActive("/account/streams")" @onclick="CloseNav">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8"/></svg>
                    <span>Трансляции</span>
                </a>
                <a href="/account/profile" class="cab-nav-item @IsActive("/account/profile")" @onclick="CloseNav">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                    <span>Профиль</span>
                </a>
                <a href="/account/leads" class="cab-nav-item @IsActive("/account/leads")" @onclick="CloseNav">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
                    <span>История заявок</span>
                </a>
            </nav>

            <div class="cab-sidebar-footer">
                <a href="/" class="cab-back-link">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="15 18 9 12 15 6"/></svg>
                    На сайт
                </a>
                <button class="cab-logout-btn" @onclick="Logout">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                    Выйти
                </button>
            </div>
        </div>
    </aside>

    <!-- Mobile overlay -->
    @if (navOpen)
    {
        <div class="cab-overlay" @onclick="CloseNav"></div>
    }

    <!-- Main content -->
    <div class="cab-content">
        <!-- Mobile header -->
        <header class="cab-mobile-header">
            <button class="cab-hamburger" @onclick="ToggleNav" aria-label="Меню">
                <span></span><span></span><span></span>
            </button>
            <span class="cab-mobile-title">Личный кабинет</span>
            <div class="cab-mobile-avatar">@Initials</div>
        </header>

        <main class="cab-main">
            @Body
        </main>
    </div>

</div>

@code {
    private string? fullName;
    private string? subscriptionTier;
    private bool navOpen = false;

    protected override async Task OnInitializedAsync()
    {
        var token = await Auth.GetTokenAsync();
        if (string.IsNullOrEmpty(token))
        {
            Nav.NavigateTo("/account/login", forceLoad: false);
            return;
        }
        try
        {
            var me = await Api.GetMeAsync();
            fullName = me?.FullName;
            subscriptionTier = me?.Subscription?.IsActive == true ? me.Subscription.Tier : null;
        }
        catch { }
    }

    private string Initials => string.IsNullOrEmpty(fullName) ? "?" :
        string.Concat(fullName.Split(' ', StringSplitOptions.RemoveEmptyEntries)
            .Take(2).Select(w => char.ToUpper(w[0])));

    private string IsActive(string href, bool exact = false)
    {
        var current = Nav.Uri.Replace(Nav.BaseUri.TrimEnd('/'), "").ToLower();
        var h = href.ToLower();
        return exact ? (current == h || current == h + "/" ? "active" : "") :
               (current == h || current.StartsWith(h + "/") ? "active" : "");
    }

    private void ToggleNav() => navOpen = !navOpen;
    private void CloseNav() => navOpen = false;

    private async Task Logout()
    {
        await Auth.LogoutAsync();
        Nav.NavigateTo("/account/login");
    }

    public void Dispose() { }
}
