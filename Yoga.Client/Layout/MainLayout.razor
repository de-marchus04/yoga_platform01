@inherits LayoutComponentBase
@inject LocalizationService Loc
@inject ThemeService Theme
@inject IJSRuntime JS
@implements IDisposable

<div class="page">
    <header class="app-header">
        <div class="container d-flex align-items-center justify-content-between">
            <div class="logo">
                <a href="/">Yoga.Life</a>
            </div>
            <nav class="main-nav">
                <ul class="nav-menu">
                    <li><a href="/">@Loc["nav.home"]</a></li>
                    
                    <li class="dropdown @(openDropdown == "courses" ? "open" : "")" @onmouseenter='() => OpenDropdown("courses")' @onmouseleave="CloseDropdown">
                        <a href="/courses">@Loc["nav.courses"] ▾</a>
                        <ul class="dropdown-menu">
                            <li><a href="/courses/pranayama">@Loc["nav.courses.pranayama"]</a></li>
                            <li><a href="/courses/meditation">@Loc["nav.courses.meditation"]</a></li>
                            <li><a href="/courses/yoga">@Loc["nav.courses.yoga"]</a></li>
                        </ul>
                    </li>

                    <li class="dropdown @(openDropdown == "consultations" ? "open" : "")" @onmouseenter='() => OpenDropdown("consultations")' @onmouseleave="CloseDropdown">
                        <a href="/consultations">@Loc["nav.consultations"] ▾</a>
                        <ul class="dropdown-menu">
                            <li><a href="/consultations/energy">@Loc["nav.consultations.energy"]</a></li>
                            <li><a href="/consultations/ayurveda">@Loc["nav.consultations.ayurveda"]</a></li>
                            <li><a href="/consultations/spirituality">@Loc["nav.consultations.spirituality"]</a></li>
                        </ul>
                    </li>

                    <li class="dropdown @(openDropdown == "retreats" ? "open" : "")" @onmouseenter='() => OpenDropdown("retreats")' @onmouseleave="CloseDropdown">
                        <a href="/retreats">@Loc["nav.retreats"] ▾</a>
                        <ul class="dropdown-menu">
                            <li><a href="/retreats/actual">@Loc["nav.retreats.actual"]</a></li>
                            <li><a href="/retreats/upcoming">@Loc["nav.retreats.upcoming"]</a></li>
                            <li><a href="/retreats/past">@Loc["nav.retreats.past"]</a></li>
                        </ul>
                    </li>

                    <li class="dropdown @(openDropdown == "blog" ? "open" : "")" @onmouseenter='() => OpenDropdown("blog")' @onmouseleave="CloseDropdown">
                        <a href="/blog">@Loc["nav.blog"] ▾</a>
                        <ul class="dropdown-menu">
                            <li><a href="/blog/articles">@Loc["nav.blog.articles"]</a></li>
                            <li><a href="/blog/videos">@Loc["nav.blog.videos"]</a></li>
                            <li><a href="/blog/photos">@Loc["nav.blog.photos"]</a></li>
                        </ul>
                    </li>

                    <li><a href="/about">@Loc["nav.about"]</a></li>
                    <li><a href="/contacts">@Loc["nav.contacts"]</a></li>
                </ul>
            </nav>
            <div class="header-controls">
                <a href="/account" class="cabinet-icon-link header-account" title="Личный кабинет">
                    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <circle cx="12" cy="7" r="4"/>
                        <path d="M4 21c0-4 3.582-7 8-7s8 3 8 7"/>
                    </svg>
                </a>
                <div class="lang-switcher header-languages">
                    <button class="lang-btn @(Loc.CurrentLang == "ru" ? "active" : "")" @onclick='() => SetLang("ru")'>RU</button>
                    <span class="lang-sep">·</span>
                    <button class="lang-btn @(Loc.CurrentLang == "uk" ? "active" : "")" @onclick='() => SetLang("uk")'>UK</button>
                    <span class="lang-sep">·</span>
                    <button class="lang-btn @(Loc.CurrentLang == "en" ? "active" : "")" @onclick='() => SetLang("en")'>EN</button>
                </div>
                <button class="theme-toggle header-theme" @onclick="ToggleTheme">@(Theme.IsDark ? "☀" : "☾")</button>
                <button class="menu-toggle" @onclick="ToggleMenu" aria-label="Menu" aria-expanded="@menuOpen" aria-controls="mobile-menu">
                    @(menuOpen ? "✕" : "☰")
                </button>
            </div>
        </div>
    </header>

    @if (menuOpen)
    {
        <div class="mobile-backdrop" @onclick="CloseMenu"></div>
    }
    <nav id="mobile-menu" class="mobile-nav @(menuOpen ? "open" : "")" aria-hidden="@(!menuOpen)">
        <div class="mobile-nav-header">
            <span class="mobile-nav-title">Yoga.Life</span>
            <button class="mobile-nav-close" @onclick="CloseMenu" aria-label="Close menu">✕</button>
        </div>
        <ul class="mobile-nav-menu">
            <li><a href="/" @onclick="CloseMenu">@Loc["nav.home"]</a></li>
            <li class="mobile-section-label">@Loc["nav.courses"]</li>
            <li><a href="/courses/pranayama" @onclick="CloseMenu">@Loc["nav.courses.pranayama"]</a></li>
            <li><a href="/courses/meditation" @onclick="CloseMenu">@Loc["nav.courses.meditation"]</a></li>
            <li><a href="/courses/yoga" @onclick="CloseMenu">@Loc["nav.courses.yoga"]</a></li>
            <li class="mobile-section-label">@Loc["nav.consultations"]</li>
            <li><a href="/consultations/energy" @onclick="CloseMenu">@Loc["nav.consultations.energy"]</a></li>
            <li><a href="/consultations/ayurveda" @onclick="CloseMenu">@Loc["nav.consultations.ayurveda"]</a></li>
            <li><a href="/consultations/spirituality" @onclick="CloseMenu">@Loc["nav.consultations.spirituality"]</a></li>
            <li class="mobile-section-label">@Loc["nav.retreats"]</li>
            <li><a href="/retreats/actual" @onclick="CloseMenu">@Loc["nav.retreats.actual"]</a></li>
            <li><a href="/retreats/upcoming" @onclick="CloseMenu">@Loc["nav.retreats.upcoming"]</a></li>
            <li><a href="/retreats/past" @onclick="CloseMenu">@Loc["nav.retreats.past"]</a></li>
            <li class="mobile-section-label">@Loc["nav.blog"]</li>
            <li><a href="/blog/articles" @onclick="CloseMenu">@Loc["nav.blog.articles"]</a></li>
            <li><a href="/blog/videos" @onclick="CloseMenu">@Loc["nav.blog.videos"]</a></li>
            <li><a href="/blog/photos" @onclick="CloseMenu">@Loc["nav.blog.photos"]</a></li>
            <li class="mobile-divider"></li>
            <li><a href="/about" @onclick="CloseMenu">@Loc["nav.about"]</a></li>
            <li><a href="/contacts" @onclick="CloseMenu">@Loc["nav.contacts"]</a></li>
            <li class="mobile-divider"></li>
            <li><a href="/account" @onclick="CloseMenu">👤 Личный кабинет</a></li>
        </ul>
        <div class="mobile-nav-footer">
            <div class="lang-switcher">
                <button class="lang-btn @(Loc.CurrentLang == "ru" ? "active" : "")" @onclick='() => SetLang("ru")'>RU</button>
                <span class="lang-sep">·</span>
                <button class="lang-btn @(Loc.CurrentLang == "uk" ? "active" : "")" @onclick='() => SetLang("uk")'>UK</button>
                <span class="lang-sep">·</span>
                <button class="lang-btn @(Loc.CurrentLang == "en" ? "active" : "")" @onclick='() => SetLang("en")'>EN</button>
            </div>
            <button class="mobile-theme-toggle" @onclick="ToggleTheme" aria-label="Toggle theme">@(Theme.IsDark ? "☀ Светлая тема" : "☾ Тёмная тема")</button>
        </div>
    </nav>

    <main>
        @Body
    </main>

    <footer class="app-footer">
        <div class="container">
            <p>@Loc["footer.copy"]</p>
        </div>
    </footer>
</div>

@code {
    private bool menuOpen = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Theme.InitAsync(JS);
            // Loc.InitAsync already called in Program.cs before RunAsync — translations pre-loaded
            Theme.OnThemeChanged += Refresh;
            Loc.OnLanguageChanged += Refresh;
            StateHasChanged();
        }
    }

    private void Refresh() => InvokeAsync(StateHasChanged);
    private async Task SetLang(string lang) => await Loc.SetLanguageAsync(lang, JS);
    private async Task ToggleTheme() => await Theme.ToggleAsync(JS);
    private string openDropdown = "";
    private void OpenDropdown(string name) => openDropdown = name;
    private void CloseDropdown() => openDropdown = "";

    private async Task ToggleMenu()
    {
        menuOpen = !menuOpen;
        await SetBodyScrollLockAsync(menuOpen);
    }

    private async Task CloseMenu()
    {
        if (!menuOpen)
        {
            return;
        }

        menuOpen = false;
        await SetBodyScrollLockAsync(false);
    }

    private Task SetBodyScrollLockAsync(bool locked) => JS.InvokeVoidAsync("ylToggleBodyScroll", locked).AsTask();

    public void Dispose()
    {
        Theme.OnThemeChanged -= Refresh;
        Loc.OnLanguageChanged -= Refresh;
    }
}
