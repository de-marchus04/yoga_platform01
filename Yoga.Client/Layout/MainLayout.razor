@inherits LayoutComponentBase
@inject LocalizationService Loc
@inject ThemeService Theme
@inject IJSRuntime JS
@implements IDisposable

<div class="page">
    <header class="app-header">
        <div class="container align-items-center">
            <div class="logo">
                <a href="/" aria-label="shakti.ashram">
                    <span class="brand-lockup">
                        <span class="brand-mark" aria-hidden="true">
                            <svg viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg" focusable="false">
                                <circle cx="32" cy="32" r="28.5" />
                                <path d="M32 13.5c4.9 6.2 7.4 11.9 7.4 17.1 0 6.1-2.5 11.1-7.4 15.2-4.9-4.1-7.4-9.1-7.4-15.2 0-5.2 2.5-10.9 7.4-17.1Z" />
                                <path d="M24.2 24.1c-6 1.2-10.1 4.7-12.5 10.5 6.8.3 12.2 2.8 16.3 7.6" />
                                <path d="M39.8 24.1c6 1.2 10.1 4.7 12.5 10.5-6.8.3-12.2 2.8-16.3 7.6" />
                                <path d="M20.2 33.2c-4.6 1.1-7.9 4-9.8 8.6 5.4.1 9.8 1.9 13.1 5.3" />
                                <path d="M43.8 33.2c4.6 1.1 7.9 4 9.8 8.6-5.4.1-9.8 1.9-13.1 5.3" />
                                <path d="M21.4 49.6c3.3-2.9 6.9-4.3 10.6-4.3 3.8 0 7.3 1.4 10.6 4.3" />
                                <path d="M28.8 54.2c.9-2.3 2-3.9 3.2-4.8 1.2.9 2.3 2.5 3.2 4.8" />
                                <path d="M32 22.1c1.7 1.4 2.5 3.2 2.5 5.3S33.7 31.3 32 32.7c-1.7-1.4-2.5-3.2-2.5-5.3s.8-3.9 2.5-5.3Z" />
                            </svg>
                        </span>
                        <span class="brand-wordmark brand-wordmark-header">
                            <span class="brand-prefix">sha</span><span class="brand-rest">kti.ashram</span>
                        </span>
                    </span>
                </a>
            </div>
            <nav class="main-nav">
                <ul class="nav-menu">
                    <li><a href="/">@Loc["nav.home"]</a></li>
                    
                    <li class="dropdown @(openDropdown == "courses" ? "open" : "")" @onmouseenter='() => OpenDropdown("courses")' @onmouseleave="CloseDropdown">
                        <div class="dropdown-trigger">
                            <a href="/courses" class="dropdown-link">@Loc["nav.courses"]</a>
                            <button type="button"
                                    class="dropdown-toggle"
                                    aria-label="Подменю курсов"
                                    aria-expanded="@(openDropdown == "courses")"
                                    aria-controls="desktop-submenu-courses"
                                    @onclick='() => ToggleDropdown("courses")'>
                                <span aria-hidden="true">▾</span>
                            </button>
                        </div>
                        <ul id="desktop-submenu-courses" class="dropdown-menu">
                            <li><a href="/courses/pranavidya">@Loc["nav.courses.pranayama"]</a></li>
                            <li><a href="/courses/meditation">@Loc["nav.courses.meditation"]</a></li>
                            <li><a href="/courses/yoga">@Loc["nav.courses.yoga"]</a></li>
                        </ul>
                    </li>

                    <li class="dropdown @(openDropdown == "consultations" ? "open" : "")" @onmouseenter='() => OpenDropdown("consultations")' @onmouseleave="CloseDropdown">
                        <div class="dropdown-trigger">
                            <a href="/consultations" class="dropdown-link">@Loc["nav.consultations"]</a>
                            <button type="button"
                                    class="dropdown-toggle"
                                    aria-label="Подменю консультаций"
                                    aria-expanded="@(openDropdown == "consultations")"
                                    aria-controls="desktop-submenu-consultations"
                                    @onclick='() => ToggleDropdown("consultations")'>
                                <span aria-hidden="true">▾</span>
                            </button>
                        </div>
                        <ul id="desktop-submenu-consultations" class="dropdown-menu">
                            <li><a href="/consultations/energy">@Loc["nav.consultations.energy"]</a></li>
                            <li><a href="/consultations/for-teenagers">@Loc["nav.consultations.ayurveda"]</a></li>
                            <li><a href="/consultations/spirituality">@Loc["nav.consultations.spirituality"]</a></li>
                        </ul>
                    </li>

                    <li class="dropdown @(openDropdown == "retreats" ? "open" : "")" @onmouseenter='() => OpenDropdown("retreats")' @onmouseleave="CloseDropdown">
                        <div class="dropdown-trigger">
                            <a href="/retreats" class="dropdown-link">@Loc["nav.retreats"]</a>
                            <button type="button"
                                    class="dropdown-toggle"
                                    aria-label="Подменю ретритов"
                                    aria-expanded="@(openDropdown == "retreats")"
                                    aria-controls="desktop-submenu-retreats"
                                    @onclick='() => ToggleDropdown("retreats")'>
                                <span aria-hidden="true">▾</span>
                            </button>
                        </div>
                        <ul id="desktop-submenu-retreats" class="dropdown-menu">
                            <li><a href="/retreats/actual">@Loc["nav.retreats.actual"]</a></li>
                        </ul>
                    </li>

                    <li class="dropdown @(openDropdown == "yagyas" ? "open" : "")" @onmouseenter='() => OpenDropdown("yagyas")' @onmouseleave="CloseDropdown">
                        <div class="dropdown-trigger">
                            <a href="/yagyas" class="dropdown-link">@Loc["nav.yagyas"]</a>
                            <button type="button"
                                    class="dropdown-toggle"
                                    aria-label="Подменю ягий"
                                    aria-expanded="@(openDropdown == "yagyas")"
                                    aria-controls="desktop-submenu-yagyas"
                                    @onclick='() => ToggleDropdown("yagyas")'>
                                <span aria-hidden="true">▾</span>
                            </button>
                        </div>
                        <ul id="desktop-submenu-yagyas" class="dropdown-menu">
                            <li><a href="/yagyas/upcoming">@Loc["nav.yagyas.upcoming"]</a></li>
                            <li><a href="/yagyas/past">@Loc["nav.yagyas.past"]</a></li>
                        </ul>
                    </li>

                    <li class="dropdown @(openDropdown == "blog" ? "open" : "")" @onmouseenter='() => OpenDropdown("blog")' @onmouseleave="CloseDropdown">
                        <div class="dropdown-trigger">
                            <a href="/blog" class="dropdown-link">@Loc["nav.blog"]</a>
                            <button type="button"
                                    class="dropdown-toggle"
                                    aria-label="Подменю блога"
                                    aria-expanded="@(openDropdown == "blog")"
                                    aria-controls="desktop-submenu-blog"
                                    @onclick='() => ToggleDropdown("blog")'>
                                <span aria-hidden="true">▾</span>
                            </button>
                        </div>
                        <ul id="desktop-submenu-blog" class="dropdown-menu">
                            <li><a href="/blog/articles">@Loc["nav.blog.articles"]</a></li>
                            <li><a href="/blog/videos">@Loc["nav.blog.videos"]</a></li>
                            <li><a href="/blog/photos">@Loc["nav.blog.photos"]</a></li>
                        </ul>
                    </li>

                    <li><a href="/about">@Loc["nav.about"]</a></li>
                    <li><a href="/contacts">@Loc["nav.contacts"]</a></li>
                </ul>
            </nav>
            <div class="header-controls">
                <a href="/account" class="cabinet-icon-link header-account" title='@Loc["footer.account"]'>
                    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <circle cx="12" cy="7" r="4"/>
                        <path d="M4 21c0-4 3.582-7 8-7s8 3 8 7"/>
                    </svg>
                </a>
                <div class="lang-switcher header-languages">
                    <button class="lang-btn @(Loc.CurrentLang == "ru" ? "active" : "")" @onclick='() => SetLang("ru")'>RU</button>
                    <span class="lang-sep">·</span>
                    <button class="lang-btn @(Loc.CurrentLang == "uk" ? "active" : "")" @onclick='() => SetLang("uk")'>UK</button>
                    <span class="lang-sep">·</span>
                    <button class="lang-btn @(Loc.CurrentLang == "en" ? "active" : "")" @onclick='() => SetLang("en")'>EN</button>
                </div>
                <button class="theme-toggle header-theme" @onclick="ToggleTheme">@(Theme.IsDark ? "☀" : "☾")</button>
                <button class="menu-toggle" @onclick="ToggleMenu" aria-label="Menu" aria-expanded="@menuOpen" aria-controls="mobile-menu">
                    @(menuOpen ? "✕" : "☰")
                </button>
            </div>
        </div>
    </header>

    @if (menuOpen)
    {
        <div class="mobile-backdrop" @onclick="CloseMenu"></div>
    }
    <nav id="mobile-menu" class="mobile-nav @(menuOpen ? "open" : "")" aria-hidden="@(!menuOpen)" aria-label="Mobile menu">
        <ul class="mobile-nav-menu">
            <li><a href="/" @onclick="CloseMenu">@Loc["nav.home"]</a></li>
            <li class="mobile-section-label">@Loc["nav.courses"]</li>
            <li><a href="/courses/pranavidya" @onclick="CloseMenu">@Loc["nav.courses.pranayama"]</a></li>
            <li><a href="/courses/meditation" @onclick="CloseMenu">@Loc["nav.courses.meditation"]</a></li>
            <li><a href="/courses/yoga" @onclick="CloseMenu">@Loc["nav.courses.yoga"]</a></li>
            <li class="mobile-section-label">@Loc["nav.consultations"]</li>
            <li><a href="/consultations/energy" @onclick="CloseMenu">@Loc["nav.consultations.energy"]</a></li>
            <li><a href="/consultations/for-teenagers" @onclick="CloseMenu">@Loc["nav.consultations.ayurveda"]</a></li>
            <li><a href="/consultations/spirituality" @onclick="CloseMenu">@Loc["nav.consultations.spirituality"]</a></li>
            <li class="mobile-section-label">@Loc["nav.retreats"]</li>
            <li><a href="/retreats/actual" @onclick="CloseMenu">@Loc["nav.retreats.actual"]</a></li>
            <li class="mobile-section-label">@Loc["nav.yagyas"]</li>
            <li><a href="/yagyas/upcoming" @onclick="CloseMenu">@Loc["nav.yagyas.upcoming"]</a></li>
            <li><a href="/yagyas/past" @onclick="CloseMenu">@Loc["nav.yagyas.past"]</a></li>
            <li class="mobile-section-label">@Loc["nav.blog"]</li>
            <li><a href="/blog/articles" @onclick="CloseMenu">@Loc["nav.blog.articles"]</a></li>
            <li><a href="/blog/videos" @onclick="CloseMenu">@Loc["nav.blog.videos"]</a></li>
            <li><a href="/blog/photos" @onclick="CloseMenu">@Loc["nav.blog.photos"]</a></li>
            <li class="mobile-divider"></li>
            <li><a href="/about" @onclick="CloseMenu">@Loc["nav.about"]</a></li>
            <li><a href="/contacts" @onclick="CloseMenu">@Loc["nav.contacts"]</a></li>
            <li class="mobile-divider"></li>
            <li><a href="/privacy" @onclick="CloseMenu">@Loc["footer.privacy"]</a></li>
            <li><a href="/terms" @onclick="CloseMenu">@Loc["footer.terms"]</a></li>
            <li class="mobile-divider"></li>
            <li><a href="/account" @onclick="CloseMenu">👤 @Loc["footer.account"]</a></li>
        </ul>
        <div class="mobile-nav-footer">
            <div class="lang-switcher">
                <button class="lang-btn @(Loc.CurrentLang == "ru" ? "active" : "")" @onclick='() => SetLang("ru")'>RU</button>
                <span class="lang-sep">·</span>
                <button class="lang-btn @(Loc.CurrentLang == "uk" ? "active" : "")" @onclick='() => SetLang("uk")'>UK</button>
                <span class="lang-sep">·</span>
                <button class="lang-btn @(Loc.CurrentLang == "en" ? "active" : "")" @onclick='() => SetLang("en")'>EN</button>
            </div>
            <button class="mobile-theme-toggle" @onclick="ToggleTheme" aria-label="Toggle theme">@(Theme.IsDark ? $"☀ {Loc["footer.light_theme"]}" : $"☾ {Loc["footer.dark_theme"]}")</button>
        </div>
    </nav>

    <main>
        @Body
    </main>

    <footer class="app-footer">
        <div class="container">
            <p class="footer-copy">
                <span>© 2026 </span>
                <span class="brand-wordmark footer-brand" aria-label="shakti.ashram">
                    <span class="brand-prefix">sha</span><span class="brand-rest">kti.ashram</span>
                </span>
                <span>. @Loc["footer.tagline"]</span>
            </p>
            <div class="footer-legal-links">
                <a href="/privacy">@Loc["footer.privacy"]</a>
                <a href="/terms">@Loc["footer.terms"]</a>
            </div>
        </div>
    </footer>

    <CookieConsent />
</div>

@code {
    private bool menuOpen = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Theme.InitAsync(JS);
            // Loc.InitAsync already called in Program.cs before RunAsync — translations pre-loaded
            Theme.OnThemeChanged += Refresh;
            Loc.OnLanguageChanged += Refresh;
            StateHasChanged();
        }
    }

    private void Refresh() => InvokeAsync(StateHasChanged);
    private async Task SetLang(string lang) => await Loc.SetLanguageAsync(lang, JS);
    private async Task ToggleTheme() => await Theme.ToggleAsync(JS);
    private string openDropdown = "";
    private void OpenDropdown(string name) => openDropdown = name;
    private void CloseDropdown() => openDropdown = "";
    private void ToggleDropdown(string name) => openDropdown = openDropdown == name ? "" : name;

    private async Task ToggleMenu()
    {
        menuOpen = !menuOpen;
        await SetBodyScrollLockAsync(menuOpen);
    }

    private async Task CloseMenu()
    {
        if (!menuOpen)
        {
            return;
        }

        menuOpen = false;
        await SetBodyScrollLockAsync(false);
    }

    private Task SetBodyScrollLockAsync(bool locked) => JS.InvokeVoidAsync("ylToggleBodyScroll", "menu", locked).AsTask();

    public void Dispose()
    {
        Theme.OnThemeChanged -= Refresh;
        Loc.OnLanguageChanged -= Refresh;
    }
}
