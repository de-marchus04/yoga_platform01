@inherits LayoutComponentBase
@inject ApiService Api
@inject IJSRuntime JS
@inject NavigationManager Nav

@if (showLoginModal)
{
    <AdminLoginModal OnClose="@OnLoginSuccess" />
}
else if (isAuthenticated)
{
<div class="admin-shell @(sidebarCollapsed ? "sidebar-collapsed" : "")">
    <aside class="admin-sidebar">
        <div class="sidebar-header">
            @if (!sidebarCollapsed)
            {
                <span class="sidebar-brand">shakti.ashram</span>
            }
            else
            {
                <span class="sidebar-brand-icon">S</span>
            }
            <button class="collapse-btn" @onclick="ToggleSidebar">
                @if (sidebarCollapsed)
                {
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
                }
                else
                {
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"/></svg>
                }
            </button>
        </div>
        <nav class="sidebar-nav">
            <NavLink href="/admin" class="nav-item" Match="NavLinkMatch.All">
                <span class="nav-icon">⊞</span><span class="nav-label">Dashboard</span>
            </NavLink>
            <NavLink href="/admin/courses" class="nav-item">
                <span class="nav-icon">◎</span><span class="nav-label">Courses</span>
            </NavLink>
            <NavLink href="/admin/consultations" class="nav-item">
                <span class="nav-icon">◈</span><span class="nav-label">Consultations</span>
            </NavLink>
            <NavLink href="/admin/retreats" class="nav-item">
                <span class="nav-icon">◇</span><span class="nav-label">Retreats</span>
            </NavLink>
            <NavLink href="/admin/yagyas" class="nav-item">
                <span class="nav-icon">✦</span><span class="nav-label">Yagyas</span>
            </NavLink>
            <NavLink href="/admin/pages" class="nav-item">
                <span class="nav-icon">☰</span><span class="nav-label">Site Pages</span>
            </NavLink>
            <NavLink href="/admin/media" class="nav-item">
                <span class="nav-icon">▣</span><span class="nav-label">Media</span>
            </NavLink>
            <NavLink href="/admin/leads" class="nav-item">
                <span class="nav-icon">◐</span><span class="nav-label">Leads</span>
            </NavLink>
            <NavLink href="/admin/translations" class="nav-item">
                <span class="nav-icon">❖</span><span class="nav-label">Translations</span>
            </NavLink>
        </nav>
    </aside>
    <div class="admin-main">
        <header class="admin-topbar">
            <span class="topbar-spacer"></span>
            <div class="topbar-right">
                @if (!string.IsNullOrWhiteSpace(adminLogin))
                {
                    <span class="admin-username">@adminLogin</span>
                }
                <button class="btn-logout" @onclick="Logout">Logout</button>
                <a href="/" class="btn-logout" style="text-decoration:none">← Site</a>
            </div>
        </header>
        <div class="admin-content">
            @Body
        </div>
    </div>
</div>
}

@code {
    private string? adminLogin;
    private bool showLoginModal;
    private bool isAuthenticated;
    private bool sidebarCollapsed;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var token = await JS.InvokeAsync<string?>("localStorage.getItem", "yl-admin-token");
            if (string.IsNullOrWhiteSpace(token))
            {
                showLoginModal = true;
                StateHasChanged();
                return;
            }

            var user = await Api.AdminGetCurrentUserAsync();
            if (user is null)
            {
                await JS.InvokeVoidAsync("localStorage.removeItem", "yl-admin-token");
                showLoginModal = true;
                StateHasChanged();
                return;
            }

            adminLogin = user.Login;
            isAuthenticated = true;
            StateHasChanged();
        }
    }

    private async Task OnLoginSuccess()
    {
        showLoginModal = false;
        var user = await Api.AdminGetCurrentUserAsync();
        if (user is not null)
        {
            adminLogin = user.Login;
            isAuthenticated = true;
        }
        StateHasChanged();
    }

    private async Task Logout()
    {
        await JS.InvokeVoidAsync("localStorage.removeItem", "yl-admin-token");
        isAuthenticated = false;
        adminLogin = null;
        showLoginModal = true;
        StateHasChanged();
    }

    private void ToggleSidebar() => sidebarCollapsed = !sidebarCollapsed;
}
