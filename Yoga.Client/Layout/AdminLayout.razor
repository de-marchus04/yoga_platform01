@inherits LayoutComponentBase
@inject NavigationManager Nav
@inject AdminAuthService Auth
@inject AuthenticationStateProvider AuthState
@implements IDisposable

<AuthorizeView>
    <Authorized>
        <div class="admin-shell @(sidebarCollapsed ? "sidebar-collapsed" : "")">
            <!-- Sidebar -->
            <aside class="admin-sidebar @(mobileOpen ? "mobile-open" : "")">
                <div class="sidebar-header">
                    @if (!sidebarCollapsed)
                    {
                        <span class="sidebar-brand">YOGA · LIFE</span>
                    }
                    else
                    {
                        <span class="sidebar-brand-icon">Y</span>
                    }
                    <button class="collapse-btn" @onclick="ToggleSidebar" title="@(sidebarCollapsed ? "Развернуть" : "Свернуть")">
                        @if (sidebarCollapsed)
                        {
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
                        }
                        else
                        {
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
                        }
                    </button>
                </div>

                <nav class="sidebar-nav">
                    <a href="/admin" class="nav-item @IsActive("/admin")" @onclick="CloseMobile">
                        <span class="nav-icon">▦</span>
                        @if (!sidebarCollapsed) { <span class="nav-label">Dashboard</span> }
                    </a>
                    <a href="/admin/pages/home/edit" class="nav-item @IsActive("/admin/pages/home/edit")" @onclick="CloseMobile">
                        <span class="nav-icon">⌂</span>
                        @if (!sidebarCollapsed) { <span class="nav-label">Главная страница</span> }
                    </a>
                    <a href="/admin/pages/about/edit" class="nav-item @IsActive("/admin/pages/about/edit")" @onclick="CloseMobile">
                        <span class="nav-icon">ℹ</span>
                        @if (!sidebarCollapsed) { <span class="nav-label">О нас</span> }
                    </a>
                    <a href="/admin/pages/contacts/edit" class="nav-item @IsActive("/admin/pages/contacts/edit")" @onclick="CloseMobile">
                        <span class="nav-icon">☎</span>
                        @if (!sidebarCollapsed) { <span class="nav-label">Контакты</span> }
                    </a>
                    <a href="/admin/leads" class="nav-item @IsActive("/admin/leads")" @onclick="CloseMobile">
                        <span class="nav-icon">✉</span>
                        @if (!sidebarCollapsed) { <span class="nav-label">Заявки (CRM)</span> }
                    </a>
                    <a href="/admin/retreats" class="nav-item @IsActive("/admin/retreats")" @onclick="CloseMobile">
                        <span class="nav-icon">⛰</span>
                        @if (!sidebarCollapsed) { <span class="nav-label">Ретриты</span> }
                    </a>
                    <a href="/admin/courses" class="nav-item @IsActive("/admin/courses")" @onclick="CloseMobile">
                        <span class="nav-icon">📖</span>
                        @if (!sidebarCollapsed) { <span class="nav-label">Курсы</span> }
                    </a>
                    <a href="/admin/consultations" class="nav-item @IsActive("/admin/consultations")" @onclick="CloseMobile">
                        <span class="nav-icon">💬</span>
                        @if (!sidebarCollapsed) { <span class="nav-label">Консультации</span> }
                    </a>
                    <a href="/admin/blog" class="nav-item @IsActive("/admin/blog")" @onclick="CloseMobile">
                        <span class="nav-icon">✎</span>
                        @if (!sidebarCollapsed) { <span class="nav-label">Блог</span> }
                    </a>
                    <!-- Убрали дублирующееся меню 'Страницы', 'Переводы' и 'Медиа' -->
                    <a href="/admin/clients" class="nav-item @IsActive("/admin/clients")" @onclick="CloseMobile">
                        <span class="nav-icon">👤</span>
                        @if (!sidebarCollapsed) { <span class="nav-label">Клиенты</span> }
                    </a>
                    <a href="/admin/access" class="nav-item @IsActive("/admin/access")" @onclick="CloseMobile">
                        <span class="nav-icon">🔑</span>
                        @if (!sidebarCollapsed) { <span class="nav-label">Доступы</span> }
                    </a>
                    <a href="/admin/premium-library" class="nav-item @IsActive("/admin/premium-library")" @onclick="CloseMobile">
                        <span class="nav-icon">📚</span>
                        @if (!sidebarCollapsed) { <span class="nav-label">Premium-библиотека</span> }
                    </a>
                    <a href="/admin/live-events" class="nav-item @IsActive("/admin/live-events")" @onclick="CloseMobile">
                        <span class="nav-icon">🎬</span>
                        @if (!sidebarCollapsed) { <span class="nav-label">Эфиры</span> }
                    </a>
                    <a href="/admin/audit" class="nav-item @IsActive("/admin/audit")" @onclick="CloseMobile">
                        <span class="nav-icon">📋</span>
                        @if (!sidebarCollapsed) { <span class="nav-label">Аудит</span> }
                    </a>
                    <a href="/admin/settings" class="nav-item @IsActive("/admin/settings")" @onclick="CloseMobile">
                        <span class="nav-icon">⚙</span>
                        @if (!sidebarCollapsed) { <span class="nav-label">Настройки (СИСТЕМНЫЕ)</span> }
                    </a>
                </nav>

            </aside>

            @if (mobileOpen)
            {
                <div class="sidebar-overlay" @onclick="CloseMobile"></div>
            }

            <!-- Main content -->
            <div class="admin-main">
                <header class="admin-topbar">
                    <button class="mobile-menu-btn" @onclick="ToggleMobile">☰</button>
                    <div class="topbar-spacer"></div>
                    <div class="topbar-right">
                        <span class="admin-username">@context.User.FindFirst("display_name")?.Value</span>
                        <button class="btn-logout" @onclick="HandleLogout">Выход</button>
                    </div>
                </header>

                <main class="admin-content">
                    @Body
                </main>
            </div>
        </div>
    </Authorized>
    <NotAuthorized>
        @{
            RedirectToLogin();
        }
    </NotAuthorized>
</AuthorizeView>

@code {
    private bool sidebarCollapsed;
    private bool mobileOpen;

    protected override void OnInitialized()
    {
        Nav.LocationChanged += OnLocationChanged;
    }

    private string IsActive(string href)
    {
        var uri = Nav.ToAbsoluteUri(Nav.Uri).AbsolutePath;
        if (href == "/admin")
            return uri == "/admin" || uri == "/admin/" ? "active" : "";
        return uri.StartsWith(href, StringComparison.OrdinalIgnoreCase) ? "active" : "";
    }

    private void ToggleSidebar() => sidebarCollapsed = !sidebarCollapsed;
    private void ToggleMobile() => mobileOpen = !mobileOpen;
    private void CloseMobile() => mobileOpen = false;

    private async Task HandleLogout()
    {
        await Auth.LogoutAsync();
        Nav.NavigateTo("/admin/login");
    }

    private void RedirectToLogin()
    {
        Nav.NavigateTo("/admin/login");
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        mobileOpen = false;
        StateHasChanged();
    }

    public void Dispose()
    {
        Nav.LocationChanged -= OnLocationChanged;
    }
}
