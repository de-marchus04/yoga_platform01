@inherits LayoutComponentBase
@inject ApiService Api
@inject IJSRuntime JS
@inject NavigationManager Nav

@if (showLoginModal)
{
    <AdminLoginModal OnClose="@OnLoginSuccess" />
}
else if (isAuthenticated)
{
<div class="admin-shell">
    <aside class="admin-sidebar">
        <div class="admin-sidebar-header">
            <span class="admin-logo">shakti.ashram</span>
            <span class="admin-badge">Admin</span>
        </div>
        <nav class="admin-nav">
            <NavLink href="/admin" class="admin-nav-link" Match="NavLinkMatch.All">Dashboard</NavLink>
            <NavLink href="/admin/courses" class="admin-nav-link">Courses</NavLink>
            <NavLink href="/admin/consultations" class="admin-nav-link">Consultations</NavLink>
            <NavLink href="/admin/retreats" class="admin-nav-link">Retreats</NavLink>
            <NavLink href="/admin/yagyas" class="admin-nav-link">Yagyas</NavLink>
            <NavLink href="/admin/pages" class="admin-nav-link">Site Pages</NavLink>
            <NavLink href="/admin/media" class="admin-nav-link">Media</NavLink>
            <NavLink href="/admin/leads" class="admin-nav-link">Leads</NavLink>
            <NavLink href="/admin/translations" class="admin-nav-link">Translations</NavLink>
        </nav>
        <div class="admin-sidebar-footer">
            @if (!string.IsNullOrWhiteSpace(adminLogin))
            {
                <div class="admin-nav-link admin-back-link">@adminLogin</div>
            }
            <button class="admin-logout-btn" @onclick="Logout">Logout</button>
            <a href="/" class="admin-nav-link admin-back-link">← Back to site</a>
        </div>
    </aside>
    <main class="admin-main">
        @Body
    </main>
</div>
}

@code {
    private string? adminLogin;
    private bool showLoginModal;
    private bool isAuthenticated;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var token = await JS.InvokeAsync<string?>("localStorage.getItem", "yl-admin-token");
            if (string.IsNullOrWhiteSpace(token))
            {
                showLoginModal = true;
                StateHasChanged();
                return;
            }

            var user = await Api.AdminGetCurrentUserAsync();
            if (user is null)
            {
                await JS.InvokeVoidAsync("localStorage.removeItem", "yl-admin-token");
                showLoginModal = true;
                StateHasChanged();
                return;
            }

            adminLogin = user.Login;
            isAuthenticated = true;
            StateHasChanged();
        }
    }

    private async Task OnLoginSuccess()
    {
        showLoginModal = false;
        var user = await Api.AdminGetCurrentUserAsync();
        if (user is not null)
        {
            adminLogin = user.Login;
            isAuthenticated = true;
        }
        StateHasChanged();
    }

    private async Task Logout()
    {
        await JS.InvokeVoidAsync("localStorage.removeItem", "yl-admin-token");
        isAuthenticated = false;
        adminLogin = null;
        showLoginModal = true;
        StateHasChanged();
    }
}
