@inject LocalizationService Loc

<div class="lead-modal-backdrop" @onclick="Close">
    <div class="lead-modal-content" @onclick:stopPropagation>
        <svg class="modal-mountain-decor" viewBox="0 0 480 80" preserveAspectRatio="none" aria-hidden="true">
            <path d="M0,80 L60,35 L110,55 L180,15 L240,45 L300,10 L360,40 L420,20 L480,50 L480,80Z" fill="rgba(140,107,58,0.04)"/>
            <path d="M0,80 L80,50 L150,30 L220,55 L290,25 L360,50 L440,35 L480,55 L480,80Z" fill="rgba(140,107,58,0.03)"/>
        </svg>
        <button class="close-btn" @onclick="Close" @onclick:stopPropagation aria-label="Close">&times;</button>
        @if (!string.IsNullOrWhiteSpace(ContextTitle))
        {
            <p class="modal-context-label">@Loc["form.context_prefix"]: <strong>@ContextTitle</strong> @(string.IsNullOrEmpty(TargetFormat) ? "" : $"({TargetFormat})")</p>
        }
        <h2>@Loc["form.heading"]</h2>
        <p>@Loc["form.subtext"]</p>

        @if (isSubmitted)
        {
            <div class="success-message">
                @Loc["form.success"]
            </div>
        }
        else
        {
            <EditForm Model="@leadModel" OnValidSubmit="HandleSubmit">
                <DataAnnotationsValidator />

                <div class="form-group">
                    <label for="lead-name">@Loc["form.name"]</label>
                    <InputText id="lead-name" @bind-Value="leadModel.Name" class="@NameFieldClass" @oninput="OnNameInput" />
                    @if (_nameTouched && !_nameIsValid)
                    {
                        <div class="field-validation-hint error">@_nameError</div>
                    }
                    else if (_nameTouched && _nameIsValid)
                    {
                        <div class="field-validation-hint ok">@Loc["validation.name_ok"]</div>
                    }
                </div>

                <div class="form-group">
                    <label for="lead-messenger">@Loc["form.messenger"]</label>
                    <InputSelect id="lead-messenger" @bind-Value="leadModel.Messager" @bind-Value:after="OnMessengerChanged" class="form-control">
                        <option value="Telegram">Telegram</option>
                        <option value="WhatsApp">WhatsApp</option>
                        <option value="Viber">Viber</option>
                        <option value="Phone">@Loc["form.phone_call"]</option>
                        <option value="Email">Email</option>
                    </InputSelect>
                    <ValidationMessage For="@(() => leadModel.Messager)" />
                </div>

                <div class="form-group">
                    <label for="lead-contact">@Loc["form.contact"]</label>
                    @if (leadModel.Messager == "Email")
                    {
                        <EmailInput Value="@leadModel.ContactDetails"
                                    ValueChanged="v => leadModel.ContactDetails = v"
                                    IsValidChanged="v => contactIsValid = v" />
                    }
                    else if (leadModel.Messager == "Phone" || leadModel.Messager == "WhatsApp")
                    {
                        @* Phone/WhatsApp — always a phone number, strict validation *@
                        <PhoneInput Value="@leadModel.ContactDetails"
                                    ValueChanged="v => leadModel.ContactDetails = v"
                                    IsValidChanged="v => contactIsValid = v" />
                    }
                    else
                    {
                        @* Telegram / Viber — phone number OR @username, show phone picker but allow username fallback *@
                        <div class="contact-mode-toggle">
                            <button type="button" class="contact-mode-btn @(usernameMode ? "" : "active")" @onclick="() => SetContactMode(false)">@Loc["validation.phone_toggle"]</button>
                            <button type="button" class="contact-mode-btn @(usernameMode ? "active" : "")" @onclick="() => SetContactMode(true)">@@ Username</button>
                        </div>
                        @if (usernameMode)
                        {
                            <InputText id="lead-contact" @bind-Value="leadModel.ContactDetails" class="form-control" placeholder="@("@example_bot")" />
                            <ValidationMessage For="@(() => leadModel.ContactDetails)" />
                        }
                        else
                        {
                            <PhoneInput Value="@leadModel.ContactDetails"
                                        ValueChanged="v => leadModel.ContactDetails = v"
                                        IsValidChanged="v => contactIsValid = v" />
                        }
                    }
                </div>

                <div class="form-group">
                    <label for="lead-comment">@Loc["form.comment"]</label>
                    <InputTextArea id="lead-comment" @bind-Value="leadModel.Comment" class="form-control" />
                    <ValidationMessage For="@(() => leadModel.Comment)" />
                </div>

                <button type="submit" class="btn btn-primary w-100" disabled="@IsSubmitDisabled">
                    @(isSubmitting ? Loc["form.submitting"] : Loc["form.submit"])
                </button>
            </EditForm>
        }
    </div>
</div>

@code {
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public string? ContextTitle { get; set; }
    
    // Structured backend targeting
    [Parameter] public Guid? TargetCourseId { get; set; }
    [Parameter] public Guid? TargetConsultationId { get; set; }
    [Parameter] public string TargetFormat { get; set; } = string.Empty; // "Online" or "Offline"

    [Inject] private Yoga.Client.Services.ApiService ApiService { get; set; } = default!;

    private Yoga.Shared.Models.Lead leadModel = new() { Messager = "Telegram" };
    private bool isSubmitting = false;
    private bool isSubmitted = false;
    private bool contactIsValid = true;
    private bool usernameMode = false; // Telegram/Viber: phone vs @username
    private bool _nameTouched = false;
    private bool _nameIsValid = false;
    private string _nameError = "";

    private string NameFieldClass => _nameTouched && !_nameIsValid
        ? "form-control input-error"
        : "form-control";

    private bool IsSubmitDisabled =>
        isSubmitting ||
        (_nameTouched && !_nameIsValid) ||
        (!_nameTouched && string.IsNullOrWhiteSpace(leadModel.Name)) ||
        (leadModel.Messager is "Phone" or "WhatsApp" or "Email" && !contactIsValid) ||
        (leadModel.Messager is "Telegram" or "Viber" && !usernameMode && !contactIsValid);

    private void OnNameInput(ChangeEventArgs e)
    {
        _nameTouched = true;
        var val = e.Value?.ToString() ?? "";
        var (valid, msg) = ValidateName(val);
        _nameIsValid = valid;
        _nameError = msg;
    }

    private (bool valid, string message) ValidateName(string name)
    {
        if (string.IsNullOrWhiteSpace(name))
            return (false, Loc["validation.name_required"]);
        var trimmed = name.Trim();
        if (trimmed.Length < 2)
            return (false, Loc["validation.name_short"]);
        if (!System.Text.RegularExpressions.Regex.IsMatch(trimmed, @"^[\p{L}\s\-']+$"))
            return (false, Loc["validation.name_invalid"]);
        // at least one vowel
        const string vowels = "аеёиоуыьъэюяйАЕЁИОУЫЬЪЭЮЯЙaeiouyAEIOUY";
        if (!trimmed.Any(c => vowels.Contains(c)))
            return (false, Loc["validation.name_fake"]);
        // no consonant cluster longer than 3
        var vowelSet = new HashSet<char>(vowels);
        int run = 0, maxRun = 0;
        foreach (var ch in trimmed.ToLower().Where(char.IsLetter))
        {
            if (vowelSet.Contains(ch)) run = 0;
            else { run++; if (run > maxRun) maxRun = run; }
        }
        if (maxRun > 3)
            return (false, Loc["validation.name_fake"]);
        return (true, "");
    }

    private void OnMessengerChanged()
    {
        leadModel.ContactDetails = "";
        usernameMode = false;
        contactIsValid = leadModel.Messager is not ("Phone" or "WhatsApp" or "Email");
    }

    private void SetContactMode(bool username)
    {
        usernameMode = username;
        leadModel.ContactDetails = "";
        contactIsValid = username; // username mode = always valid (plain text); phone mode = requires validation
    }

    private async Task HandleSubmit()
    {
        isSubmitting = true;
        if (!string.IsNullOrWhiteSpace(ContextTitle))
        {
            var formatSuffix = string.IsNullOrEmpty(TargetFormat) ? "" : $" ({TargetFormat})";
            leadModel.Comment = string.IsNullOrWhiteSpace(leadModel.Comment)
                ? $"{Loc["form.signup_prefix"]}: {ContextTitle}{formatSuffix}"
                : $"{Loc["form.signup_prefix"]}: {ContextTitle}{formatSuffix}. {leadModel.Comment}";
        }

        // Apply robust references
        leadModel.CourseId = TargetCourseId;
        leadModel.ConsultationId = TargetConsultationId;
        leadModel.TargetFormat = TargetFormat;

        var success = await ApiService.SubmitLeadAsync(leadModel);
        if (success)
            isSubmitted = true;

        isSubmitting = false;
    }

    private async Task Close()
    {
        await OnClose.InvokeAsync();
    }
}
