@inject Yoga.Client.Services.AdminApiService Api
@inject NavigationManager Nav
@inject IJSRuntime JS

<div class="media-picker-overlay" @onclick="Close">
    <div class="media-picker-modal" @onclick:stopPropagation="true">
        <div class="media-picker-header">
            <div>
                <h3>@PickerTitle</h3>
                <div class="admin-text-muted media-picker-subtitle">Загружайте файлы с компьютера, выбирайте из библиотеки или вставляйте прямую ссылку.</div>
            </div>
            <button type="button" class="btn-admin btn-admin-outline" @onclick="Close">✕</button>
        </div>
        <div class="media-picker-toolbar">
            <input class="admin-input media-picker-search" type="text" placeholder="Поиск по имени, alt или типу..." @bind="searchTerm" />
            <button type="button" class="btn-admin btn-admin-outline" @onclick="ReloadAsync" disabled="@(loading || uploading || deleting)">Обновить</button>
        </div>
        <div class="media-picker-body">
            @if (loading)
            {
                <div class="admin-loading">Загрузка...</div>
            }
            else if (!string.IsNullOrWhiteSpace(loadError))
            {
                <div class="form-error">@loadError</div>
            }
            else if (VisibleFiles.Count == 0)
            {
                <div class="admin-empty">@EmptyStateText</div>
            }
            else
            {
                <div class="media-picker-grid">
                    @foreach (var f in VisibleFiles)
                    {
                        <article class="media-picker-card">
                            <button type="button" class="media-picker-preview" @onclick="() => Select(f)" title="Выбрать файл">
                                @if (IsImage(f.Url))
                                {
                                    <img src="@GetFullUrl(f.Url)" alt="@f.Alt" loading="lazy" />
                                }
                                else if (IsVideo(f.Url))
                                {
                                    <video src="@GetFullUrl(f.Url)" muted preload="metadata"></video>
                                    <span class="media-picker-kind-badge">Видео</span>
                                }
                                else
                                {
                                    <div class="media-picker-file-icon">@FileIcon(f.Url)</div>
                                    <span class="media-picker-kind-badge">@GetKindLabel(f.Url)</span>
                                }
                            </button>

                            <div class="media-picker-card-body">
                                <div class="media-picker-card-title" title="@DisplayName(f)">@DisplayName(f)</div>
                                <div class="media-picker-card-meta">Тип: @GetKindLabel(f.Url)</div>
                                <div class="media-picker-card-meta">Раздел: @GetEntityLabel(f)</div>
                                <div class="media-picker-card-meta">Загружено: @GetUploadedAtLabel(f)</div>
                            </div>

                            <div class="media-picker-card-actions">
                                <button type="button" class="btn-admin btn-admin-primary btn-admin-sm" @onclick="() => Select(f)">Выбрать</button>
                                <button type="button" class="btn-admin btn-admin-danger btn-admin-sm" @onclick="() => DeleteAsync(f)" disabled="@deleting">Удалить</button>
                            </div>
                        </article>
                    }
                </div>
            }
        </div>
        <div class="media-picker-footer">
            <div class="media-picker-upload">
                <label class="btn-admin btn-admin-primary upload-btn" style="margin:0; font-size:0.85rem;">
                    @(uploading ? "Загрузка..." : "+ Загрузить")
                    <InputFile OnChange="HandleUpload" accept="@AcceptValue" style="display:none" />
                </label>
                <a class="btn-admin btn-admin-outline" href="/admin/media">Открыть медиатеку</a>
            </div>
            <div class="media-picker-url">
                <input type="text" placeholder="Или вставьте URL..." @bind="manualUrl" />
                <button type="button" class="btn-admin btn-admin-outline" @onclick="UseManualUrl" disabled="@string.IsNullOrWhiteSpace(manualUrl)">OK</button>
            </div>
        </div>
        @if (!string.IsNullOrWhiteSpace(statusMessage))
        {
            <div class="form-error media-picker-message">@statusMessage</div>
        }
    </div>
</div>

@code {
    [Parameter] public string EntityType { get; set; } = "General";
    [Parameter] public string MediaKind { get; set; } = "image";
    [Parameter] public long MaxFileSizeBytes { get; set; } = 256L * 1024 * 1024;
    [Parameter] public EventCallback<string> OnSelected { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    private List<Yoga.Shared.Models.MediaFile> files = new();
    private Dictionary<Guid, DateTime> uploadedAtByMediaId = new();
    private bool loading = true;
    private bool uploading;
    private bool deleting;
    private string manualUrl = "";
    private string searchTerm = "";
    private string? loadError;
    private string? statusMessage;

    private IReadOnlyList<Yoga.Shared.Models.MediaFile> VisibleFiles => files
        .Where(f => MatchesMediaKind(f.Url))
        .Where(SearchMatches)
        .OrderByDescending(GetUploadedAt)
        .ThenBy(f => DisplayName(f), StringComparer.OrdinalIgnoreCase)
        .ToList();
    private string PickerTitle => MediaKind switch
    {
        "video" => "Выбрать видео",
        "audio" => "Выбрать аудио",
        "document" => "Выбрать документ",
        "mixed" => "Выбрать медиа",
        _ => "Выбрать изображение"
    };
    private string EmptyStateText => MediaKind switch
    {
        "video" => "Нет загруженных видео",
        "audio" => "Нет загруженного аудио",
        "document" => "Нет загруженных документов",
        "mixed" => "Нет подходящих файлов",
        _ => "Нет загруженных изображений"
    };
    private string AcceptValue => MediaKind switch
    {
        "video" => "video/*",
        "audio" => "audio/*",
        "document" => ".pdf",
        "mixed" => "image/*,video/*,audio/*,.pdf",
        _ => "image/*"
    };

    protected override async Task OnInitializedAsync()
    {
        await ReloadAsync();
    }

    private async Task Select(Yoga.Shared.Models.MediaFile f)
    {
        await OnSelected.InvokeAsync(GetFullUrl(f.Url));
    }

    private async Task UseManualUrl()
    {
        if (!string.IsNullOrWhiteSpace(manualUrl))
            await OnSelected.InvokeAsync(manualUrl.Trim());
    }

    private async Task ReloadAsync()
    {
        loading = true;
        loadError = null;
        statusMessage = null;

        try
        {
            files = await Api.GetAllMediaAsync();
            var auditLogs = await Api.GetAuditLogsAsync(page: 1, pageSize: 500, action: "media-uploaded", entityType: nameof(Yoga.Shared.Models.MediaFile));
            uploadedAtByMediaId = auditLogs?.Items
                .Where(item => item.EntityId.HasValue)
                .GroupBy(item => item.EntityId!.Value)
                .ToDictionary(group => group.Key, group => group.Max(item => item.CreatedAt))
                ?? new Dictionary<Guid, DateTime>();
        }
        catch (Exception ex)
        {
            loadError = ex.Message;
            files = new();
            uploadedAtByMediaId = new();
        }
        finally
        {
            loading = false;
        }
    }

    private async Task HandleUpload(InputFileChangeEventArgs e)
    {
        statusMessage = null;
        var file = e.File;
        if (file.Size > MaxFileSizeBytes)
        {
            statusMessage = $"Файл слишком большой. Максимум {MaxFileSizeBytes / (1024 * 1024)} MB.";
            return;
        }

        if (!MatchesMediaKind(file.Name))
        {
            statusMessage = "Тип файла не подходит для этого поля.";
            return;
        }

        uploading = true;
        var content = new MultipartFormDataContent();
        await using var stream = file.OpenReadStream(MaxFileSizeBytes);
        content.Add(new StreamContent(stream), "file", file.Name);
        content.Add(new StringContent(EntityType), "entityType");

        var (result, error) = await Api.UploadMediaAsync(content);
        if (result != null)
        {
            files.Insert(0, result);
            uploadedAtByMediaId[result.Id] = DateTime.UtcNow;
            await OnSelected.InvokeAsync(GetFullUrl(result.Url));
        }
        else
        {
            statusMessage = string.IsNullOrWhiteSpace(error) ? "Не удалось загрузить файл." : error;
        }

        uploading = false;
    }

    private async Task DeleteAsync(Yoga.Shared.Models.MediaFile file)
    {
        if (deleting)
            return;

        var confirmed = await JS.InvokeAsync<bool>("confirm", $"Удалить файл '{DisplayName(file)}'?");
        if (!confirmed)
            return;

        deleting = true;
        statusMessage = null;

        var (success, error) = await Api.DeleteMediaAsync(file.Id);
        if (success)
        {
            files.RemoveAll(item => item.Id == file.Id);
            uploadedAtByMediaId.Remove(file.Id);
        }
        else
        {
            statusMessage = string.IsNullOrWhiteSpace(error) ? "Не удалось удалить файл." : error;
        }

        deleting = false;
    }

    private async Task Close() => await OnClose.InvokeAsync();

    private string GetFullUrl(string url)
    {
        if (url.StartsWith("http")) return url;
        var baseUri = Nav.BaseUri.TrimEnd('/').Replace(":5190", ":5293");
        return baseUri + url;
    }

    private bool IsImage(string url) =>
        url.EndsWith(".jpg", StringComparison.OrdinalIgnoreCase) ||
        url.EndsWith(".jpeg", StringComparison.OrdinalIgnoreCase) ||
        url.EndsWith(".png", StringComparison.OrdinalIgnoreCase) ||
        url.EndsWith(".gif", StringComparison.OrdinalIgnoreCase) ||
        url.EndsWith(".webp", StringComparison.OrdinalIgnoreCase) ||
        url.EndsWith(".svg", StringComparison.OrdinalIgnoreCase);

    private bool IsVideo(string url) =>
        url.EndsWith(".mp4", StringComparison.OrdinalIgnoreCase) ||
        url.EndsWith(".webm", StringComparison.OrdinalIgnoreCase) ||
        url.EndsWith(".mov", StringComparison.OrdinalIgnoreCase);

    private bool IsAudio(string url) =>
        url.EndsWith(".mp3", StringComparison.OrdinalIgnoreCase) ||
        url.EndsWith(".wav", StringComparison.OrdinalIgnoreCase) ||
        url.EndsWith(".m4a", StringComparison.OrdinalIgnoreCase) ||
        url.EndsWith(".aac", StringComparison.OrdinalIgnoreCase) ||
        url.EndsWith(".ogg", StringComparison.OrdinalIgnoreCase);

    private bool IsDocument(string url) =>
        url.EndsWith(".pdf", StringComparison.OrdinalIgnoreCase);

    private bool MatchesMediaKind(string url) => MediaKind switch
    {
        "video" => IsVideo(url),
        "audio" => IsAudio(url),
        "document" => IsDocument(url),
        "mixed" => IsImage(url) || IsVideo(url) || IsAudio(url) || IsDocument(url),
        _ => IsImage(url)
    };

    private string FileIcon(string url) => MediaKind switch
    {
        "audio" => "🎧",
        "document" => "📄",
        _ when IsAudio(url) => "🎧",
        _ when IsDocument(url) => "📄",
        _ => "📦"
    };

    private bool SearchMatches(Yoga.Shared.Models.MediaFile file)
    {
        if (string.IsNullOrWhiteSpace(searchTerm))
            return true;

        var needle = searchTerm.Trim();
        return DisplayName(file).Contains(needle, StringComparison.OrdinalIgnoreCase)
            || file.EntityType.Contains(needle, StringComparison.OrdinalIgnoreCase)
            || file.Url.Contains(needle, StringComparison.OrdinalIgnoreCase)
            || (file.Alt?.Contains(needle, StringComparison.OrdinalIgnoreCase) ?? false);
    }

    private DateTime GetUploadedAt(Yoga.Shared.Models.MediaFile file) =>
        uploadedAtByMediaId.TryGetValue(file.Id, out var uploadedAt) ? uploadedAt : DateTime.MinValue;

    private string GetUploadedAtLabel(Yoga.Shared.Models.MediaFile file) =>
        uploadedAtByMediaId.TryGetValue(file.Id, out var uploadedAt)
            ? uploadedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
            : "нет данных";

    private static string GetEntityLabel(Yoga.Shared.Models.MediaFile file) =>
        string.IsNullOrWhiteSpace(file.EntityType) ? "Общее" : file.EntityType;

    private string GetKindLabel(string url) => MediaKind switch
    {
        "video" => "Видео",
        "audio" => "Аудио",
        "document" => "Документ",
        _ when IsImage(url) => "Изображение",
        _ when IsVideo(url) => "Видео",
        _ when IsAudio(url) => "Аудио",
        _ when IsDocument(url) => "Документ",
        _ => "Файл"
    };

    private static string DisplayName(Yoga.Shared.Models.MediaFile file) =>
        !string.IsNullOrWhiteSpace(file.Alt) ? file.Alt : Path.GetFileName(file.Url);
}
