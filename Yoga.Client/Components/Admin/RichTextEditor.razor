@inject IJSRuntime JSRuntime
@implements IAsyncDisposable

<div @ref="editorElement"></div>

@code {
    [Parameter] public string? Value { get; set; }
    [Parameter] public EventCallback<string?> ValueChanged { get; set; }

    private ElementReference editorElement;
    private string? editorId;
    private DotNetObjectReference<RichTextEditor>? dotNetRef;
    private bool isInitialized = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            dotNetRef = DotNetObjectReference.Create(this);
            editorId = await JSRuntime.InvokeAsync<string>(
                "quillInterop.init",
                editorElement,
                dotNetRef,
                Value
            );
            isInitialized = true;
        }
    }

    protected override void OnParametersSet()
    {
        if (isInitialized && !string.IsNullOrEmpty(editorId))
        {
            // Note: In a real app we need to be careful with infinite loops if typing
            // But since this is a simple CMS, we can just optionally update when Value changes
            // JSRuntime.InvokeVoidAsync("quillInterop.setContent", editorId, Value);
        }
    }

    [JSInvokable]
    public async Task UpdateContent(string content)
    {
        if (Value != content)
        {
            Value = content;
            await ValueChanged.InvokeAsync(content);
        }
    }

    public async ValueTask DisposeAsync()
    {
        dotNetRef?.Dispose();
        if (isInitialized && !string.IsNullOrEmpty(editorId))
        {
            try
            {
                await JSRuntime.InvokeVoidAsync("quillInterop.destroy", editorId);
            }
            catch
            {
                // Ignore JS disconnected errors
            }
        }
    }
}