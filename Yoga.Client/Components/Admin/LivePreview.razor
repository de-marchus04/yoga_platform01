@inject NavigationManager Nav
@inject IJSRuntime JS

<div class="live-preview">
    <div class="lp-toolbar">
        <span class="lp-title">Превью</span>
        <div class="lp-viewport-btns">
            <button class="lp-vp-btn @(viewport == "desktop" ? "active" : "")" @onclick='() => SetViewport("desktop")' title="Desktop">🖥</button>
            <button class="lp-vp-btn @(viewport == "tablet" ? "active" : "")" @onclick='() => SetViewport("tablet")' title="Tablet">📱</button>
            <button class="lp-vp-btn @(viewport == "mobile" ? "active" : "")" @onclick='() => SetViewport("mobile")' title="Mobile">📲</button>
        </div>
        <button class="btn-admin btn-admin-outline btn-admin-sm" @onclick="Refresh">↻ Обновить</button>
    </div>
    <div class="lp-frame-wrap lp-@viewport">
        <iframe @ref="iframeRef" src="@FullUrl" class="lp-iframe" sandbox="allow-same-origin allow-scripts"></iframe>
    </div>
</div>

@code {
    [Parameter] public string PreviewPath { get; set; } = "/";
    [Parameter] public string Language { get; set; } = "ru";

    private ElementReference iframeRef;
    private string viewport = "desktop";
    private int refreshKey;

    private string FullUrl
    {
        get
        {
            var baseUri = Nav.BaseUri.TrimEnd('/');
            var separator = PreviewPath.Contains('?') ? "&" : "?";
            return $"{baseUri}{PreviewPath}{separator}lang={Language}&_r={refreshKey}";
        }
    }

    private void SetViewport(string vp) => viewport = vp;

    private void Refresh()
    {
        refreshKey++;
        StateHasChanged();
    }

    public async Task SendUpdate(Dictionary<string, string> values)
    {
        try
        {
            await JS.InvokeVoidAsync("eval", $"document.querySelector('.lp-iframe')?.contentWindow?.postMessage({{type:'preview-update',data:{System.Text.Json.JsonSerializer.Serialize(values)}}},'*')");
        }
        catch { /* iframe may not be ready */ }
    }
}
