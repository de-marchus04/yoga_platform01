@inject IJSRuntime JS
@inject Yoga.Client.Services.LocalizationService Loc

@if (showBanner)
{
    <div class="cookie-consent">
        <div class="cookie-consent-inner">
            <p class="cookie-consent-text">
                @Loc["cookie.text"]
                <a href="/privacy">@Loc["cookie.link"]</a>.
            </p>
            <div class="cookie-consent-actions">
                <button class="cookie-btn cookie-btn-accept" @onclick="Accept">@Loc["cookie.accept"]</button>
                <button class="cookie-btn cookie-btn-decline" @onclick="Decline">@Loc["cookie.decline"]</button>
            </div>
        </div>
    </div>
}

@code {
    private const string ConsentKey = "cookie-consent-v2";
    private bool showBanner;
    private bool _checked;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_checked)
        {
            _checked = true;
            var consent = await JS.InvokeAsync<string?>("localStorage.getItem", ConsentKey);
            if (string.IsNullOrEmpty(consent))
            {
                showBanner = true;
                StateHasChanged();
            }
        }
    }

    private async Task Accept()
    {
        await JS.InvokeVoidAsync("localStorage.setItem", ConsentKey, "all");
        showBanner = false;
    }

    private async Task Decline()
    {
        await JS.InvokeVoidAsync("localStorage.setItem", ConsentKey, "essential");
        showBanner = false;
    }
}
