@inject Yoga.Client.Services.ToastService ToastService
@implements IDisposable

<div class="toast-container" role="status" aria-live="polite" aria-atomic="true">
    @foreach (var toast in ToastService.Toasts)
    {
        <div class="toast-item toast-@toast.Level.ToString().ToLower() show" @key="toast.Id">
            <div class="toast-icon">
                @switch (toast.Level)
                {
                    case Yoga.Client.Services.ToastLevel.Info:
                        <span>ℹ️</span>
                        break;
                    case Yoga.Client.Services.ToastLevel.Success:
                        <span>✅</span>
                        break;
                    case Yoga.Client.Services.ToastLevel.Warning:
                        <span>⚠️</span>
                        break;
                    case Yoga.Client.Services.ToastLevel.Error:
                        <span>❌</span>
                        break;
                }
            </div>
            <div class="toast-content">
                @if (!string.IsNullOrEmpty(toast.Title))
                {
                    <h4 class="toast-title">@toast.Title</h4>
                }
                <p class="toast-message">@toast.Message</p>
            </div>
            <button class="toast-close" @onclick="() => ToastService.RemoveToast(toast)">×</button>
        </div>
    }
</div>

@code {
    protected override void OnInitialized()
    {
        ToastService.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        ToastService.OnChange -= StateHasChanged;
    }
}