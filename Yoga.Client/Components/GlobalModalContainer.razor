@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Web
@using Yoga.Client.Services
@inject ModalService ModalService
@inject IJSRuntime JS
@implements IDisposable

@if (ModalService.IsVisible && ModalService.CurrentComponentType != null)
{
    var parameters = new Dictionary<string, object>();
    if (ModalService.CurrentParameters != null)
    {
        foreach (var kvp in ModalService.CurrentParameters)
        {
            parameters[kvp.Key] = kvp.Value;
        }
    }
    
    // Inject close callback if the modal expects it
    if (!parameters.ContainsKey("OnClose"))
    {
        parameters["OnClose"] = EventCallback.Factory.Create(this, CloseModal);
    }

    <DynamicComponent Type="ModalService.CurrentComponentType" Parameters="parameters" />
}

@code {
    private bool _isBodyScrollLocked;
    private Action? _onShow;
    private Action? _onClose;

    protected override void OnInitialized()
    {
        _onShow  = () => InvokeAsync(StateHasChanged);
        _onClose = () => InvokeAsync(StateHasChanged);
        ModalService.OnShow  += _onShow;
        ModalService.OnClose += _onClose;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (ModalService.IsVisible == _isBodyScrollLocked)
        {
            return;
        }

        _isBodyScrollLocked = ModalService.IsVisible;
        await JS.InvokeVoidAsync("ylToggleBodyScroll", "modal", _isBodyScrollLocked);
    }

    public void Dispose()
    {
        ModalService.OnShow  -= _onShow;
        ModalService.OnClose -= _onClose;
    }

    private void CloseModal()
    {
        ModalService.Close();
    }
}
