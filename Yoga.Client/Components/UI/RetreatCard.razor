@namespace Yoga.Client.Components.UI
@using Yoga.Shared.DTOs
@inject Yoga.Client.Services.ApiService Api

<div class="retreat-card @(Featured ? "retreat-card--featured " : "")reveal">
    <div class="card-img-wrapper">
        <img src="@ImgSrc" alt="@Retreat.Title" class="card-img" loading="lazy" decoding="async" />
    </div>
    <div class="card-content" style="@(IsPast ? "opacity:0.8;" : "")">
        <h3>@Retreat.Title</h3>
        <p class="location card-meta-line">
            <span class="card-meta-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 21s-7-4.35-7-10a7 7 0 1 1 14 0c0 5.65-7 10-7 10Z"/>
                    <circle cx="12" cy="11" r="2.5"/>
                </svg>
            </span>
            @Retreat.Location
        </p>
        <p class="dates card-meta-line">
            <span class="card-meta-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="4" width="18" height="18" rx="2"/>
                    <path d="M3 10h18M8 2v4M16 2v4"/>
                </svg>
            </span>
            @Retreat.StartDate.ToString("dd MMM yyyy") — @Retreat.EndDate.ToString("dd MMM yyyy")
        </p>
        <p class="description">@Retreat.Description</p>

        @if (IsPast)
        {
            <a href="/retreats/@Retreat.Id" class="btn btn-outline" style="width:100%; text-align:center;">@DetailText</a>
        }
        else
        {
            <div class="retreat-card-actions">
                <a href="/retreats/@Retreat.Id" class="btn btn-outline" style="width:100%; text-align:center;">@DetailText</a>
                @if (HasCta)
                {
                    <button type="button" class="btn btn-outline btn-sm" style="width:100%;" @onclick="() => OnCtaClick.InvokeAsync(Retreat.Title)">@CtaText</button>
                }
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public RetreatDto Retreat { get; set; } = default!;
    [Parameter] public bool IsPast { get; set; }
    [Parameter] public bool Featured { get; set; }
    [Parameter] public string DetailText { get; set; } = "Детали";
    [Parameter] public string CtaText { get; set; } = "Записаться";
    [Parameter] public bool HasCta { get; set; } = true;
    [Parameter] public EventCallback<string> OnCtaClick { get; set; }

    private string ImgSrc => !string.IsNullOrEmpty(Retreat.ImageUrl)
        ? Api.ResolveMediaUrl(Retreat.ImageUrl)
        : "https://images.unsplash.com/photo-1545205597-3d9d02c29597?auto=format&fit=crop&w=600&q=80";
}
