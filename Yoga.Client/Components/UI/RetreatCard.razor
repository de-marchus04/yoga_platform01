@namespace Yoga.Client.Components.UI
@using Yoga.Shared.DTOs
@inject Yoga.Client.Services.ApiService Api

<div class="retreat-card reveal">
    <div class="card-img-wrapper">
        <img src="@(!string.IsNullOrEmpty(Retreat.ImageUrl) ? Api.ResolveMediaUrl(Retreat.ImageUrl) : "https://images.unsplash.com/photo-1545205597-3d9d02c29597?auto=format&fit=crop&w=600&q=80")" alt="@Retreat.Title" class="card-img" loading="lazy" decoding="async" />
    </div>
    <div class="card-content" style="@(IsPast ? "opacity:0.8;" : "")">
        <h3>@Retreat.Title</h3>
        <p class="location">📍 @Retreat.Location</p>
        <p class="dates">🗓 @Retreat.StartDate.ToString("dd MMM yyyy") — @Retreat.EndDate.ToString("dd MMM yyyy")</p>
        <p class="description">@Retreat.Description</p>
        
        @if (IsPast)
        {
            <a href="/retreats/@Retreat.Id" class="btn btn-outline" style="width:100%; text-align:center;">@DetailText</a>
        }
        else
        {
            <div class="retreat-card-actions">
                <a href="/retreats/@Retreat.Id" class="btn btn-outline" style="width:100%; text-align:center;">@DetailText</a>
                @if (HasCta)
                {
                    <button class="btn btn-outline btn-sm" style="width:100%;" @onclick="() => OnCtaClick.InvokeAsync(Retreat.Title)">@CtaText</button>
                }
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public RetreatDto Retreat { get; set; } = default!;
    [Parameter] public bool IsPast { get; set; }
    [Parameter] public string DetailText { get; set; } = "Детали";
    [Parameter] public string CtaText { get; set; } = "Записаться";
    [Parameter] public bool HasCta { get; set; } = true;
    [Parameter] public EventCallback<string> OnCtaClick { get; set; }
}