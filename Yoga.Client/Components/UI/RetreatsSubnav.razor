@namespace Yoga.Client.Components.UI
@inject LocalizationService Loc

<nav class="retreats-subnav" aria-label="@Loc["page.retreats.subnav.aria"]">
    <div class="container retreats-subnav-inner">
        <a href="/retreats/actual"
           class="retreats-subnav-link @(Active == "actual" ? "active" : null)">@Loc["page.retreats.tab.actual"]</a>
        <a href="/retreats/upcoming"
           class="retreats-subnav-link @(Active == "upcoming" ? "active" : null)">@Loc["page.retreats.tab.upcoming"]</a>
        <a href="/retreats/past"
           class="retreats-subnav-link @(Active == "past" ? "active" : null)">@Loc["page.retreats.tab.past"]</a>
    </div>
</nav>

@code {
    /// <summary>One of: actual, upcoming, past</summary>
    [Parameter] public string Active { get; set; } = "actual";
}
