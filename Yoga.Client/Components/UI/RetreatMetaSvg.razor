@namespace Yoga.Client.Components.UI

@if (Kind == "calendar")
{
    <svg class="@Class" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="3" y="4" width="18" height="18" rx="2" />
        <path d="M3 10h18M8 2v4M16 2v4" />
    </svg>
}
else
{
    <svg class="@Class" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M12 21s-7-4.35-7-10a7 7 0 1 1 14 0c0 5.65-7 10-7 10Z" />
        <circle cx="12" cy="11" r="2.5" />
    </svg>
}

@code {
    /// <summary>pin or calendar</summary>
    [Parameter] public string Kind { get; set; } = "pin";
    [Parameter] public string? Class { get; set; }
}
