<CascadingAuthenticationState>
<ErrorBoundary>
    <ChildContent>
        <Router AppAssembly="@typeof(App).Assembly">
            <Found Context="routeData">
                <RouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)" />
                <FocusOnNavigate RouteData="@routeData" Selector="h1" />
            </Found>
            <NotFound>
                <PageTitle>404 — Страница не найдена</PageTitle>
                <LayoutView Layout="@typeof(MainLayout)">
                    <section style="padding:10rem 0 6rem;text-align:center;">
                        <div class="container" style="max-width:620px;">
                            <p class="section-eyebrow">404</p>
                            <h1 style="font-size:2.5rem;margin-bottom:1rem;">Страница не найдена</h1>
                            <div class="section-divider" style="margin:1.5rem auto;"></div>
                            <p style="color:var(--text-muted);margin-bottom:2rem;">
                                Возможно, страница была удалена или адрес указан неверно.
                            </p>
                            <a class="btn btn-outline" href="/" style="display:inline-flex;">← На главную</a>
                        </div>
                    </section>
                </LayoutView>
            </NotFound>
        </Router>
    </ChildContent>
    <ErrorContent>
        <LayoutView Layout="@typeof(MainLayout)">
            <section style="padding:8rem 0;">
                <div class="container" style="text-align:center; max-width: 780px;">
                    <p class="section-eyebrow">Application Error</p>
                    <h1>Страница временно недоступна</h1>
                    <div class="section-divider" style="margin:2rem auto;"></div>
                    <p style="color:var(--text-muted);">Интерфейс столкнулся с необработанной ошибкой. Обновите страницу. Если проблема повторяется, проверьте подключение публичного сайта к API и настройки production CORS.</p>
                    <a class="btn btn-outline" href="/" style="margin-top:1.5rem; display:inline-flex;">Вернуться на главную</a>
                </div>
            </section>
        </LayoutView>
    </ErrorContent>
</ErrorBoundary>
<div role="region" aria-label="Notifications and dialogs" class="yl-a11y-overlays">
    <Yoga.Client.Components.GlobalModalContainer />
    <Yoga.Client.Components.ToastContainer />
</div>
</CascadingAuthenticationState>
