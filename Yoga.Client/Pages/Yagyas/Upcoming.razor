@page "/yagyas/upcoming"
@inject LocalizationService Loc
@inject ApiService ApiService
@implements IDisposable

<PageTitle>@Loc["page.yagyas.upcoming.title"]</PageTitle>

<section class="page-hero">
    <div class="page-hero-bg" style="background-image: url('@F("UpcomingImageUrl", F("HeroImageUrl", "https://images.unsplash.com/photo-1506126613408-eca07ce68773?auto=format&fit=crop&w=1600&q=80"))');"></div>
    <div class="page-hero-overlay"></div>
    <div class="container page-hero-content">
        <p class="section-eyebrow" style="color:var(--accent);">@F("Eyebrow", Loc["page.yagyas.eyebrow"])</p>
        <h1>@F("UpcomingH1", Loc["page.yagyas.upcoming.h1"])</h1>
        <div class="section-divider" style="margin:2rem 0;"></div>
        <p>@F("UpcomingIntro", Loc["page.yagyas.upcoming.intro"])</p>
    </div>
</section>

<section class="retreats-section @(items == null || !items.Any() ? "retreats-section--center-body" : "")">
    <div class="container">
        @if (items == null)
        {
            <p style="text-align:center; padding:4rem 0; color:var(--text-muted); letter-spacing:2px; font-size:0.8rem; text-transform:uppercase;"><em>@Loc["page.yagyas.loading"]</em></p>
        }
        else if (!items.Any())
        {
            <div class="empty-state">
                <p>@Loc["page.yagyas.upcoming.empty"]</p>
            </div>
        }
        else
        {
            <div class="retreats-grid">
                @foreach (var item in items)
                {
                    <div class="retreat-card reveal">
                        <div class="card-img-wrapper">
                            <img src="@(string.IsNullOrWhiteSpace(item.ImageUrl) ? "https://images.unsplash.com/photo-1511275539165-cc46b1ee89bf?auto=format&fit=crop&w=600&q=80" : ApiService.ResolveMediaUrl(item.ImageUrl))" alt="@item.Title" class="card-img" loading="lazy" decoding="async" />
                        </div>
                        <div class="card-content">
                            <h3>@item.Title</h3>
                            <p class="location">📍 @item.Location</p>
                            <p class="dates">🗓 @item.StartDate.ToString("dd MMM yyyy") — @item.EndDate.ToString("dd MMM yyyy")</p>
                            @if (!string.IsNullOrWhiteSpace(item.PriceLabel))
                            {
                                <p class="dates">@item.PriceLabel</p>
                            }
                            <p class="description">@item.Description</p>
                            <div class="retreat-card-actions">
                                <a href="/yagyas/@item.Id" class="btn btn-outline" style="width:100%; text-align:center;">@Loc["page.yagya.card.detail"]</a>
                                <button class="btn btn-outline btn-sm" style="width:100%;" @onclick="() => OpenModal(item.Title)">@Loc["page.yagyas.card.cta"]</button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</section>

@code {
    private List<YagyaDto>? items;
    private SitePageDto? pageData;

    protected override async Task OnInitializedAsync()
    {
        Loc.OnLanguageChanged += Refresh;
        await Task.WhenAll(LoadData(), LoadPage());
    }

    private async Task LoadData()
    {
        try { items = await CatalogState.GetUpcomingYagyasAsync(Loc.CurrentLang); }
        catch { items = new(); }
    }

    private async Task LoadPage()
    {
        try { pageData = await ApiService.GetSitePageAsync("yagyas", Loc.CurrentLang); }
        catch { pageData = null; }
    }

    private string F(string field, string fallback = "")
    {
        var val = pageData?.Fields != null && pageData.Fields.TryGetValue(field, out var v) && !string.IsNullOrEmpty(v) ? v : fallback;
        return field.Contains("Image", StringComparison.OrdinalIgnoreCase) ? ApiService.ResolveMediaUrl(val) : val;
    }

    private async void Refresh()
    {
        await Task.WhenAll(LoadData(), LoadPage());
        await InvokeAsync(StateHasChanged);
    }

    private void OpenModal(string title)
    {
        ModalService.Show<LeadModal>(new Dictionary<string, object>
        {
            { "ContextTitle", title }
        });
    }

    public void Dispose() => Loc.OnLanguageChanged -= Refresh;
}