@page "/yagyas/{Slug}"
@inject LocalizationService Loc
@inject ApiService Api
@implements IDisposable

@if (item is null)
{
    <PageTitle>@Loc["page.yagyas.title"]</PageTitle>
    <section class="hero-section"><div class="container"><div class="skeleton-block"></div></div></section>
}
else
{
    <PageTitle>@item.Title | shakti.ashram</PageTitle>

    <section class="hero-section">
        <div class="container">
            <span class="eyebrow">@item.Eyebrow</span>
            <h1>@item.Title</h1>
            <p class="hero-subtitle">@item.Subtitle</p>
        </div>
    </section>

    <section class="detail-section">
        <div class="container">
            @if (!string.IsNullOrEmpty(item.ImageUrl))
            {
                <div class="detail-hero-image">
                    <img src="@Api.ResolveMediaUrl(item.ImageUrl)" alt="@item.Title" loading="lazy" />
                </div>
            }

            <div class="detail-overview">
                <span class="eyebrow">@Loc["section.overview.eyebrow"]</span>
                <h2>@Loc["section.overview.h2"]</h2>
                <p>@item.Description</p>

                <div class="detail-meta">
                    @if (!string.IsNullOrEmpty(item.Duration)) { <div class="meta-item"><strong>Duration:</strong> @item.Duration</div> }
                    @if (!string.IsNullOrEmpty(item.Format)) { <div class="meta-item"><strong>Format:</strong> @item.Format</div> }
                    @if (!string.IsNullOrEmpty(item.PriceLabel)) { <div class="meta-item"><strong>Price:</strong> @item.PriceLabel</div> }
                </div>
            </div>

            @if (item.Benefits.Length > 0)
            {
                <div class="detail-benefits">
                    <h4>@Loc["section.benefits.h4"]</h4>
                    <ul>
                        @foreach (var b in item.Benefits)
                        {
                            <li>@b</li>
                        }
                    </ul>
                </div>
            }
        </div>
    </section>
}

@code {
    [Parameter] public string Slug { get; set; } = "";
    private Yoga.Shared.DTOs.YagyaDto? item;

    protected override async Task OnInitializedAsync()
    {
        Loc.OnLanguageChanged += Reload;
        await LoadAsync();
    }

    private async void Reload()
    {
        await LoadAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadAsync()
    {
        item = await Api.GetYagyaAsync(Slug, Loc.CurrentLang);
    }

    public void Dispose() => Loc.OnLanguageChanged -= Reload;
}
