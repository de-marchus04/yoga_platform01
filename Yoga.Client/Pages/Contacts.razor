@page "/contacts"
@inject LocalizationService Loc
@inject ApiService Api
@implements IDisposable

<PageTitle>@(F("MetaTitle", Loc["page.contacts.title"]))</PageTitle>

<section class="page-hero">
    <div class="page-hero-bg" style="background-image: url('@F("HeroImageUrl", "https://images.unsplash.com/photo-1544367567-0f2fcb009e0b?auto=format&fit=crop&w=1600&q=80")');"></div>
    <div class="page-hero-overlay"></div>
    <div class="container page-hero-content">
        <p class="section-eyebrow" style="color:var(--accent);">@Loc["page.contacts.eyebrow"]</p>
        <h1>@F("HeroTitle", Loc["page.contacts.h1"])</h1>
        <div class="section-divider" style="margin:2rem 0;"></div>
        <p>@F("HeroSubtitle", P("Сюда нужно добавить короткое пояснение: по каким вопросам к вам обращаются, как быстро вы отвечаете и какой канал связи предпочтителен.", "Сюди потрібно додати коротке пояснення: з якими питаннями до вас звертаються, як швидко ви відповідаєте і який канал зв'язку бажаний.", "Add a short explanation here: what people can contact you about, how quickly you respond, and which communication channel is preferred."))</p>
    </div>
</section>

@if (!string.IsNullOrEmpty(F("Content")))
{
    <section class="info-cards-section">
        <div class="container">
            @((MarkupString)F("Content"))
        </div>
    </section>
}
else
{
    <section class="info-cards-section">
        <div class="container">
            <div class="section-header reveal">
                <p class="section-eyebrow">@Loc["page.contacts.eyebrow"]</p>
                <h2>@Loc["page.contacts.info.h2"]</h2>
                <div class="section-divider"></div>
            </div>
            <div class="info-cards-grid">
                <div class="info-card reveal">
                    <span class="info-card-icon">✈</span>
                    <span class="info-card-label">Telegram</span>
                    <h3>Telegram</h3>
                    <p>@F("TelegramDesc", P("Добавьте сюда Telegram как основной канал для быстрых вопросов, первичного контакта и отправки коротких уточнений.", "Додайте сюди Telegram як основний канал для швидких питань, первинного контакту та коротких уточнень.", "Use this block for Telegram if it is your primary channel for quick questions, first contact, and short clarifications."))</p>
                    <a href="@F("TelegramUrl", "#")" target="_blank" rel="noopener">@F("TelegramHandle", P("Укажите @username или t.me ссылку", "Вкажіть @username або t.me посилання", "Add the @username or t.me link"))</a>
                </div>
                <div class="info-card reveal reveal-d1">
                    <span class="info-card-icon">💬</span>
                    <span class="info-card-label">WhatsApp</span>
                    <h3>WhatsApp</h3>
                    <p>@F("WhatsAppDesc", P("Добавьте сюда WhatsApp, если нужен удобный канал для голосовых сообщений, договорённостей и длинных вопросов клиента.", "Додайте сюди WhatsApp, якщо потрібен зручний канал для голосових повідомлень, домовленостей і довгих запитань клієнта.", "Use this block for WhatsApp if you want a convenient channel for voice notes, scheduling, and longer client questions."))</p>
                    <a href="@F("WhatsAppUrl", "#")" target="_blank" rel="noopener">@F("WhatsAppPhone", P("Укажите номер в международном формате", "Вкажіть номер у міжнародному форматі", "Add the phone number in international format"))</a>
                </div>
                <div class="info-card reveal reveal-d2">
                    <span class="info-card-icon">📸</span>
                    <span class="info-card-label">Instagram</span>
                    <h3>Instagram</h3>
                    <p>@F("InstagramDesc", P("Добавьте сюда Instagram, если эта площадка нужна как витрина бренда, доверительный визуальный архив и канал прогрева аудитории.", "Додайте сюди Instagram, якщо цей майданчик потрібен як вітрина бренду, візуальний архів довіри та канал прогріву аудиторії.", "Use this block for Instagram if it serves as your brand showcase, visual trust archive, and audience nurturing channel."))</p>
                    <a href="@F("InstagramUrl", "#")" target="_blank" rel="noopener">@F("InstagramHandle", P("Укажите @username или ссылку на профиль", "Вкажіть @username або посилання на профіль", "Add the @username or profile link"))</a>
                </div>
            </div>
        </div>
    </section>

    <section class="social-section">
        <div class="container">
            <div class="section-header reveal">
                <p class="section-eyebrow">@Loc["page.contacts.social.eyebrow"]</p>
                <h2>@Loc["page.contacts.social.h2"]</h2>
                <div class="section-divider"></div>
            </div>
            <div class="social-links">
                <a href="@F("TelegramUrl", "https://t.me/yogalife_enterprise")" class="social-link reveal" target="_blank" rel="noopener">
                    <span>✈</span> Telegram
                </a>
                <a href="@F("WhatsAppUrl", "#")" class="social-link reveal reveal-d1" target="_blank" rel="noopener">
                    <span>💬</span> WhatsApp
                </a>
                <a href="@F("InstagramUrl", "#")" class="social-link reveal reveal-d2" target="_blank" rel="noopener">
                    <span>📸</span> Instagram
                </a>
                <a href="@F("YouTubeUrl", "#")" class="social-link reveal reveal-d3" target="_blank" rel="noopener">
                    <span>▶</span> YouTube
                </a>
            </div>
        </div>
    </section>
}

@code {
    private SitePageDto? pageData;

    protected override async Task OnInitializedAsync()
    {
        Loc.OnLanguageChanged += Refresh;
        await LoadPage();
    }

    private async Task LoadPage()
    {
        try { pageData = await Api.GetSitePageAsync("contacts", Loc.CurrentLang); }
        catch { pageData = null; }
    }

    private string F(string field, string fallback = "")
    {
        if (pageData?.Fields != null && pageData.Fields.TryGetValue(field, out var val) && !string.IsNullOrEmpty(val))
            return val;
        return fallback;
    }

    private string P(string ru, string uk, string en) => Loc.CurrentLang switch
    {
        "uk" => uk,
        "en" => en,
        _ => ru
    };

    private async void Refresh()
    {
        await LoadPage();
        await InvokeAsync(StateHasChanged);
    }
    public void Dispose() => Loc.OnLanguageChanged -= Refresh;
}
