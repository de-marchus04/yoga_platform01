@page "/admin/blog"
@layout Yoga.Client.Layout.AdminLayout
@inject Yoga.Client.Services.AdminApiService Api
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>Блог — Админ</PageTitle>

<div class="blog-page">
    <div class="page-header">
        <h1>Блог</h1>
        <button class="btn-admin btn-admin-primary" @onclick="CreateNew">+ Добавить запись</button>
    </div>

    @if (catalogPage != null)
    {
        <details class="catalog-settings-accordion">
            <summary class="ce-section-header" style="list-style:none; cursor:pointer;">
                <span class="ce-section-title">⚙ Настройки страницы каталога</span>
            </summary>
            <div style="padding:0.75rem 0;">
                <Yoga.Client.Components.Admin.ContentEditor
                    EntityType="SitePage"
                    EntityId="catalogPage.Id"
                    Fields="catalogFields" />
            </div>
        </details>
    }

    <div class="admin-filters">
        <button class="filter-btn @FilterClass(null)" @onclick="() => SetCategory(null)">Все</button>
        <button class="filter-btn @FilterClass("articles")" @onclick='() => SetCategory("articles")'>Статьи</button>
        <button class="filter-btn @FilterClass("videos")" @onclick='() => SetCategory("videos")'>Видео</button>
        <button class="filter-btn @FilterClass("photos")" @onclick='() => SetCategory("photos")'>Фото</button>
    </div>

    @if (loading)
    {
        <div class="admin-loading">Загрузка...</div>
    }
    else if (filtered.Count == 0)
    {
        <div class="admin-empty">Записи не найдены</div>
    }
    else
    {
        <div class="admin-table-wrap">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Slug</th>
                        <th>Категория</th>
                        <th>Секции</th>
                        <th>Дата</th>
                        <th>Статус</th>
                        <th>Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in filtered)
                    {
                        <tr>
                            <td>@p.Slug</td>
                            <td>@CategoryLabel(p.Category)</td>
                            <td>@(p.Sections.Length > 0 ? string.Join(", ", p.Sections) : "—")</td>
                            <td class="nowrap">@p.PublishedAt.ToString("dd.MM.yyyy")</td>
                            <td>
                                @if (p.IsActive)
                                {
                                    <span class="badge badge-success">Активна</span>
                                }
                                else
                                {
                                    <span class="badge badge-muted">Скрыта</span>
                                }
                            </td>
                            <td class="actions-cell">
                                <button class="btn-admin btn-admin-sm btn-admin-outline" @onclick="() => Edit(p.Id)">✎</button>
                                <button class="btn-admin btn-admin-sm btn-admin-danger" @onclick="() => ConfirmDelete(p)">✕</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    @if (deleteTarget != null)
    {
        <div class="modal-backdrop" @onclick="CancelDelete">
            <div class="modal-card" @onclick:stopPropagation="true">
                <h3>Удалить запись?</h3>
                <p>Запись «@deleteTarget.Slug» будет удалена вместе со всеми переводами.</p>
                <div class="modal-actions">
                    <button class="btn-admin btn-admin-outline" @onclick="CancelDelete">Отмена</button>
                    <button class="btn-admin btn-admin-danger" @onclick="ExecuteDelete">Удалить</button>
                </div>
            </div>
        </div>
    }

    @if (!string.IsNullOrEmpty(toast))
    {
        <div class="admin-toast @toastType">@toast</div>
    }
</div>

@code {
    private List<BlogPost> posts = new();
    private List<BlogPost> filtered = new();
    private SitePage? catalogPage;
    private bool loading = true;
    private string? category;
    private BlogPost? deleteTarget;
    private string? toast;
    private string toastType = "";
    private System.Threading.Timer? toastTimer;

    private static readonly ContentField[] catalogFields = new ContentField[]
    {
        new("HeroImageUrl", "Фото каталога", ContentFieldType.Image, "Каталог"),
        new("Eyebrow", "Надзаголовок", ContentFieldType.Text, "Каталог"),
        new("H1", "Заголовок", ContentFieldType.Text, "Каталог"),
        new("Intro", "Вводный текст", ContentFieldType.TextArea, "Каталог"),
        new("H2", "Подзаголовок", ContentFieldType.Text, "Каталог"),
        new("ArticlesImageUrl", "Фото секции Статьи", ContentFieldType.Image, "Секции"),
        new("VideosImageUrl", "Фото секции Видео", ContentFieldType.Image, "Секции"),
        new("PhotosImageUrl", "Фото секции Фото", ContentFieldType.Image, "Секции"),
        new("ReadMore", "Текст кнопки", ContentFieldType.Text, "Секции"),
        new("HeroTitle", "Hero Title", ContentFieldType.Text, "SEO"),
        new("HeroSubtitle", "Hero Subtitle", ContentFieldType.Text, "SEO"),
        new("MetaTitle", "Meta Title", ContentFieldType.Text, "SEO"),
        new("MetaDescription", "Meta Description", ContentFieldType.TextArea, "SEO"),
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
        try
        {
            var pages = await Api.GetAllSitePagesAsync();
            catalogPage = pages.FirstOrDefault(p => string.Equals(p.Slug, "blog", StringComparison.OrdinalIgnoreCase));
        }
        catch { catalogPage = null; }
    }

    private async Task LoadData()
    {
        loading = true;
        try
        {
            posts = await Api.GetAllBlogPostsAsync();
            ApplyFilter();
        }
        catch
        {
            posts = new();
            filtered = new();
        }
        loading = false;
    }

    private void SetCategory(string? cat)
    {
        category = cat;
        ApplyFilter();
    }

    private void ApplyFilter()
    {
        filtered = category == null ? posts : posts.Where(p => p.Category == category).ToList();
    }

    private string FilterClass(string? value) => category == value ? "active" : "";
    private string CategoryLabel(string cat) => cat switch { "articles" => "Статья", "videos" => "Видео", "photos" => "Фото", _ => cat };

    private void CreateNew() => Nav.NavigateTo("/admin/blog/new");
    private void Edit(Guid id) => Nav.NavigateTo($"/admin/blog/{id}/edit");

    private void ConfirmDelete(BlogPost p) => deleteTarget = p;
    private void CancelDelete() => deleteTarget = null;

    private async Task ExecuteDelete()
    {
        if (deleteTarget == null) return;
        var ok = await Api.DeleteBlogPostAsync(deleteTarget.Id);
        deleteTarget = null;
        if (ok)
        {
            ShowToast("Запись удалена", "success");
            await LoadData();
        }
        else ShowToast("Ошибка при удалении", "error");
    }

    private void ShowToast(string message, string type)
    {
        toast = message; toastType = type; StateHasChanged();
        toastTimer?.Dispose();
        toastTimer = new System.Threading.Timer(_ => { toast = null; InvokeAsync(StateHasChanged); }, null, 3000, System.Threading.Timeout.Infinite);
    }

    public void Dispose() => toastTimer?.Dispose();
}
