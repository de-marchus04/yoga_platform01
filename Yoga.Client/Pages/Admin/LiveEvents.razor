@page "/admin/live-events"
@layout Yoga.Client.Layout.AdminLayout
@inject Yoga.Client.Services.AdminApiService Api
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>Эфиры — Админ</PageTitle>

<div class="live-events-page">
    <div class="page-header">
        <h1>Трансляции (Live Events)</h1>
        <button class="btn-admin btn-admin-primary" @onclick="CreateNew">+ Новый эфир</button>
    </div>

    @if (loading)
    {
        <div class="admin-loading">Загрузка...</div>
    }
    else if (events.Count == 0)
    {
        <div class="admin-empty">Нет трансляций</div>
    }
    else
    {
        <div class="admin-table-wrap">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Название</th>
                        <th>Дата</th>
                        <th>Статус</th>
                        <th>Доступ</th>
                        <th>Опубл.</th>
                        <th>Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var ev in events)
                    {
                        <tr>
                            <td>@ev.Title</td>
                            <td>@ev.StartsAt.ToString("dd.MM.yyyy HH:mm")</td>
                            <td>
                                <span class="badge @StatusBadge(ev.Status)">@ev.Status</span>
                            </td>
                            <td>@ev.AccessPolicy</td>
                            <td>
                                @if (ev.IsPublished)
                                {
                                    <span class="badge badge-success">Да</span>
                                }
                                else
                                {
                                    <span class="badge badge-muted">Нет</span>
                                }
                            </td>
                            <td class="actions-cell">
                                <button class="btn-admin btn-admin-sm btn-admin-outline" @onclick="() => Edit(ev.Id)">✎</button>
                                <button class="btn-admin btn-admin-sm btn-admin-danger" @onclick="() => ConfirmDelete(ev)">✕</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    @if (deleteTarget != null)
    {
        <div class="modal-backdrop" @onclick="CancelDelete">
            <div class="modal-card" @onclick:stopPropagation="true">
                <h3>Удалить трансляцию?</h3>
                <p>«@deleteTarget.Title» будет удалена.</p>
                <div class="modal-actions">
                    <button class="btn-admin btn-admin-outline" @onclick="CancelDelete">Отмена</button>
                    <button class="btn-admin btn-admin-danger" @onclick="ExecuteDelete">Удалить</button>
                </div>
            </div>
        </div>
    }

    @if (!string.IsNullOrEmpty(toast))
    {
        <div class="admin-toast @toastType">@toast</div>
    }
</div>

@code {
    private List<LiveEventDto> events = new();
    private bool loading = true;
    private LiveEventDto? deleteTarget;
    private string? toast;
    private string toastType = "";
    private System.Threading.Timer? toastTimer;

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        loading = true;
        try { events = await Api.GetAllLiveEventsAsync(); }
        catch { events = new(); }
        loading = false;
    }

    private void CreateNew() => Nav.NavigateTo("/admin/live-events/new");
    private void Edit(Guid id) => Nav.NavigateTo($"/admin/live-events/{id}/edit");
    private void ConfirmDelete(LiveEventDto ev) => deleteTarget = ev;
    private void CancelDelete() => deleteTarget = null;

    private async Task ExecuteDelete()
    {
        if (deleteTarget == null) return;
        var ok = await Api.DeleteLiveEventAsync(deleteTarget.Id);
        deleteTarget = null;
        if (ok) { ShowToast("Трансляция удалена", "success"); await LoadData(); }
        else ShowToast("Ошибка при удалении", "error");
    }

    private string StatusBadge(string s) => s switch
    {
        "Scheduled" => "badge-info",
        "Live" => "badge-success",
        "Ended" => "badge-muted",
        "Cancelled" => "badge-muted",
        _ => ""
    };

    private void ShowToast(string message, string type)
    {
        toast = message; toastType = type; StateHasChanged();
        toastTimer?.Dispose();
        toastTimer = new System.Threading.Timer(_ => { toast = null; InvokeAsync(StateHasChanged); }, null, 3000, System.Threading.Timeout.Infinite);
    }

    public void Dispose() => toastTimer?.Dispose();
}
