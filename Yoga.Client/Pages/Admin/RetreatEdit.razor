@page "/admin/retreats/new"
@page "/admin/retreats/{Id:guid}/edit"
@layout Yoga.Client.Layout.AdminLayout
@inject Yoga.Client.Services.AdminApiService Api
@inject NavigationManager Nav

<PageTitle>@(IsNew ? "Новый ретрит" : "Редактирование ретрита") — Админ</PageTitle>

<div class="edit-page">
    <div class="page-header">
        <h1>@(IsNew ? "Новый ретрит" : "Редактирование ретрита")</h1>
    </div>

    @if (loading)
    {
        <div class="admin-loading">Загрузка...</div>
    }
    else
    {
        <div class="form-card">
            <h3 class="section-title">Метаданные</h3>
            <div class="admin-form-group">
                <label>Название (основное)</label>
                <input class="admin-input" @bind="model.Title" placeholder="Название ретрита" />
            </div>

            <div class="admin-form-group">
                <label>Локация</label>
                <input class="admin-input" @bind="model.Location" placeholder="Город, Страна" />
            </div>

            <div class="form-row">
                <div class="admin-form-group">
                    <label>Дата начала</label>
                    <input class="admin-input" type="date" @bind="model.StartDate" />
                </div>
                <div class="admin-form-group">
                    <label>Дата окончания</label>
                    <input class="admin-input" type="date" @bind="model.EndDate" />
                </div>
            </div>

            <div class="admin-form-group">
                <label>Цена</label>
                <input class="admin-input" @bind="model.PriceLabel" placeholder="от €1200" />
            </div>

            <div class="admin-form-group">
                <label>URL изображения</label>
                <div style="display:flex; gap:0.5rem;">
                    <input class="admin-input" style="flex:1" @bind="model.ImageUrl" placeholder="https://..." />
                    <button type="button" class="btn-admin btn-admin-outline" @onclick="() => showMediaPicker = true">📁</button>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(model.ImageUrl))
            {
                <div class="image-preview">
                    <img src="@model.ImageUrl" alt="Preview" />
                </div>
            }

            <div class="admin-form-group checkbox-group">
                <label>
                    <input type="checkbox" @bind="model.IsActive" />
                    Активен (виден на сайте)
                </label>
            </div>

            @if (!string.IsNullOrEmpty(error))
            {
                <div class="form-error">@error</div>
            }

            <div class="form-actions">
                <button class="btn-admin btn-admin-outline" @onclick="Cancel">Отмена</button>
                <button class="btn-admin btn-admin-primary" disabled="@saving" @onclick="Save">
                    @(saving ? "Сохранение..." : "Сохранить метаданные")
                </button>
            </div>
        </div>

        @if (!IsNew)
        {
            <Yoga.Client.Components.Admin.TranslationEditor
                EntityType="Retreat"
                EntityId="model.Id"
                Fields="retreatFields" />
        }
        else
        {
            <div class="form-card" style="margin-top:1.5rem;">
                <p class="admin-text-muted">Сначала сохраните ретрит, чтобы редактировать переводы контента.</p>
            </div>
        }
    }
</div>

@if (showMediaPicker)
{
    <Yoga.Client.Components.Admin.MediaPicker
        EntityType="Retreat"
        OnSelected="OnMediaSelected"
        OnClose="() => showMediaPicker = false" />
}

@code {
    [Parameter] public Guid? Id { get; set; }
    private bool showMediaPicker;
    private bool IsNew => Id == null;

    private static readonly string[] retreatFields = { "Title", "Description", "Location", "PriceLabel", "Program" };

    private Retreat model = new() { StartDate = DateTime.UtcNow, EndDate = DateTime.UtcNow.AddDays(7) };
    private bool loading;
    private bool saving;
    private string? error;

    protected override async Task OnInitializedAsync()
    {
        if (!IsNew)
        {
            loading = true;
            try
            {
                var retreats = await Api.GetAllRetreatsAsync();
                var found = retreats.FirstOrDefault(r => r.Id == Id);
                if (found != null)
                    model = found;
                else
                    error = "Ретрит не найден";
            }
            catch
            {
                error = "Ошибка загрузки";
            }
            loading = false;
        }
    }

    private async Task Save()
    {
        if (string.IsNullOrWhiteSpace(model.Title))
        {
            error = "Название обязательно";
            return;
        }

        saving = true;
        error = null;

        try
        {
            HttpResponseMessage response;
            if (IsNew)
            {
                response = await Api.CreateRetreatAsync(model);
            }
            else
            {
                response = await Api.UpdateRetreatAsync(model.Id, model);
            }

            if (response.IsSuccessStatusCode)
            {
                if (IsNew)
                {
                    var created = await response.Content.ReadFromJsonAsync<Retreat>();
                    if (created != null)
                        Nav.NavigateTo($"/admin/retreats/{created.Id}/edit");
                    else
                        Nav.NavigateTo("/admin/retreats");
                }
            }
            else
            {
                error = $"Ошибка сервера: {response.StatusCode}";
            }
        }
        catch (Exception ex)
        {
            error = $"Ошибка: {ex.Message}";
        }
        saving = false;
    }

    private void Cancel() => Nav.NavigateTo("/admin/retreats");

    private void OnMediaSelected(string url)
    {
        model.ImageUrl = url;
        showMediaPicker = false;
    }
}
