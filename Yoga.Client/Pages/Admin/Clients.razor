@page "/admin/clients"
@layout Yoga.Client.Layout.AdminLayout
@inject Yoga.Client.Services.AdminApiService Api
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>Клиенты — Админ</PageTitle>

<div class="clients-page">
    <div class="page-header">
        <h1>Клиенты</h1>
        <button class="btn-admin btn-admin-primary" @onclick="CreateNew">+ Новый клиент</button>
    </div>

    <div class="admin-form-group" style="max-width:400px;margin-bottom:1rem;">
        <input class="admin-input" placeholder="Поиск по имени или email" @bind="search" @bind:event="oninput" @onkeypress="OnSearch" />
    </div>

    @if (loading)
    {
        <div class="admin-loading">Загрузка...</div>
    }
    else if (customers.Count == 0)
    {
        <div class="admin-empty">Клиенты не найдены</div>
    }
    else
    {
        <div class="admin-table-wrap">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Имя</th>
                        <th>Email</th>
                        <th>Телефон</th>
                        <th>Подписка</th>
                        <th>Статус</th>
                        <th>Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in customers)
                    {
                        <tr>
                            <td>@c.FullName</td>
                            <td>@c.Email</td>
                            <td>@(c.Phone ?? "—")</td>
                            <td>
                                @if (c.Subscription != null && c.Subscription.IsActive)
                                {
                                    <span class="badge badge-success">@c.Subscription.Tier</span>
                                }
                                else
                                {
                                    <span class="badge badge-muted">Нет</span>
                                }
                            </td>
                            <td>
                                @if (c.IsActive)
                                {
                                    <span class="badge badge-success">Активен</span>
                                }
                                else
                                {
                                    <span class="badge badge-muted">Отключён</span>
                                }
                            </td>
                            <td class="actions-cell">
                                <button class="btn-admin btn-admin-sm btn-admin-outline" @onclick="() => Edit(c.Id)">✎</button>
                                <button class="btn-admin btn-admin-sm @(c.IsActive ? "btn-admin-danger" : "btn-admin-primary")" @onclick="() => ToggleActive(c)">
                                    @(c.IsActive ? "✕" : "✓")
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="admin-pagination">
            @if (currentPage > 1)
            {
                <button class="btn-admin btn-admin-outline" @onclick="PrevPage">← Назад</button>
            }
            <span>Страница @currentPage</span>
            @if (customers.Count == pageSize)
            {
                <button class="btn-admin btn-admin-outline" @onclick="NextPage">Далее →</button>
            }
        </div>
    }

    @if (!string.IsNullOrEmpty(toast))
    {
        <div class="admin-toast @toastType">@toast</div>
    }
</div>

@code {
    private List<CustomerDto> customers = new();
    private bool loading = true;
    private string search = "";
    private int currentPage = 1;
    private const int pageSize = 20;
    private string? toast;
    private string toastType = "";
    private System.Threading.Timer? toastTimer;

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        loading = true;
        try { customers = await Api.GetCustomersAsync(currentPage, pageSize, string.IsNullOrWhiteSpace(search) ? null : search); }
        catch { customers = new(); }
        loading = false;
    }

    private void CreateNew() => Nav.NavigateTo("/admin/clients/new");
    private void Edit(Guid id) => Nav.NavigateTo($"/admin/clients/{id}/edit");

    private async Task ToggleActive(CustomerDto c)
    {
        var ok = await Api.ToggleCustomerActiveAsync(c.Id, !c.IsActive);
        if (ok) { ShowToast(c.IsActive ? "Клиент отключён" : "Клиент активирован", "success"); await LoadData(); }
        else ShowToast("Ошибка", "error");
    }

    private async Task OnSearch(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") { currentPage = 1; await LoadData(); }
    }

    private async Task PrevPage() { currentPage--; await LoadData(); }
    private async Task NextPage() { currentPage++; await LoadData(); }

    private void ShowToast(string message, string type)
    {
        toast = message; toastType = type; StateHasChanged();
        toastTimer?.Dispose();
        toastTimer = new System.Threading.Timer(_ => { toast = null; InvokeAsync(StateHasChanged); }, null, 3000, System.Threading.Timeout.Infinite);
    }

    public void Dispose() => toastTimer?.Dispose();
}
