@page "/admin/consultations/new"
@page "/admin/consultations/{Id:guid}/edit"
@layout Yoga.Client.Layout.AdminLayout
@inject Yoga.Client.Services.AdminApiService Api
@inject NavigationManager Nav

<PageTitle>@(IsNew ? "Новая консультация" : "Редактирование консультации") — Админ</PageTitle>

<div class="edit-page">
    <div class="page-header">
        <h1>@(IsNew ? "Новая консультация" : "Редактирование консультации")</h1>
    </div>

    @if (loading)
    {
        <div class="admin-loading">Загрузка...</div>
    }
    else
    {
        <div class="form-card">
            <h3 class="section-title">Метаданные</h3>
            <div class="form-row">
                <div class="admin-form-group">
                    <label>Slug</label>
                    <input class="admin-input" @bind="model.Slug" placeholder="energy" />
                </div>
                <div class="admin-form-group">
                    <label>Порядок сортировки</label>
                    <input class="admin-input" type="number" @bind="model.SortOrder" />
                </div>
            </div>

            <div class="admin-form-group checkbox-group">
                <label>
                    <input type="checkbox" @bind="model.IsActive" />
                    Активна (видна на сайте)
                </label>
                <label>
                    <input type="checkbox" @bind="model.IsOnline" />
                    Онлайн формат
                </label>
                <label>
                    <input type="checkbox" @bind="model.IsOffline" />
                    Офлайн формат
                </label>
            </div>

            <div class="admin-form-group">
                <label>Трансляция для авто-доступа</label>
                <InputSelect class="admin-input" @bind-Value="model.LiveEventId">
                    <option value="">Без авто-доступа</option>
                    @foreach (var liveEvent in liveEvents.OrderByDescending(item => item.StartsAt))
                    {
                        <option value="@liveEvent.Id">@LiveEventLabel(liveEvent)</option>
                    }
                </InputSelect>
                <div class="admin-text-muted" style="margin-top:0.35rem;">
                    При успешной обработке онлайн-заявки доступ к выбранной трансляции будет выдан автоматически.
                </div>
            </div>

            @if (!string.IsNullOrEmpty(error))
            {
                <div class="form-error">@error</div>
            }

            <div class="form-actions">
                <button class="btn-admin btn-admin-outline" @onclick="Cancel">Отмена</button>
                <button class="btn-admin btn-admin-primary" disabled="@saving" @onclick="Save">
                    @(saving ? "Сохранение..." : "Сохранить метаданные")
                </button>
            </div>
        </div>

        @if (!IsNew)
        {
            <Yoga.Client.Components.Admin.TranslationEditor
                EntityType="Consultation"
                EntityId="model.Id"
                Fields="consultationFields" />
        }
        else
        {
            <div class="form-card" style="margin-top:1.5rem;">
                <p class="admin-text-muted">Сначала сохраните консультацию, чтобы редактировать контент.</p>
            </div>
        }
    }
</div>

@code {
    [Parameter] public Guid? Id { get; set; }
    private bool IsNew => Id == null;

    private static readonly string[] consultationFields = { "Title", "Subtitle", "Eyebrow", "Description", "Quote", "Benefits", "ImageUrl", "Duration", "Format", "LanguageOffered", "PriceLabel", "ForWhom", "CtaHeading", "CtaText" };

    private Consultation model = new();
    private List<LiveEventDto> liveEvents = new();
    private bool loading;
    private bool saving;
    private string? error;

    protected override async Task OnInitializedAsync()
    {
        await LoadLiveEvents();

        if (!IsNew)
        {
            loading = true;
            try
            {
                var all = await Api.GetAllConsultationsAsync();
                var found = all.FirstOrDefault(c => c.Id == Id);
                if (found != null) model = found;
                else error = "Консультация не найдена";
            }
            catch { error = "Ошибка загрузки"; }
            loading = false;
        }
    }

    private async Task LoadLiveEvents()
    {
        try
        {
            liveEvents = await Api.GetAllLiveEventsAsync();
        }
        catch
        {
            liveEvents = new();
        }
    }

    private async Task Save()
    {
        if (string.IsNullOrWhiteSpace(model.Slug)) { error = "Slug обязателен"; return; }
        saving = true;
        error = null;
        try
        {
            HttpResponseMessage response;
            if (IsNew) response = await Api.CreateConsultationAsync(model);
            else response = await Api.UpdateConsultationAsync(model.Id, model);

            if (response.IsSuccessStatusCode)
            {
                if (IsNew)
                {
                    var created = await response.Content.ReadFromJsonAsync<Consultation>();
                    if (created != null)
                        Nav.NavigateTo($"/admin/consultations/{created.Id}/edit");
                    else
                        Nav.NavigateTo("/admin/consultations");
                }
            }
            else error = $"Ошибка сервера: {response.StatusCode}";
        }
        catch (Exception ex) { error = $"Ошибка: {ex.Message}"; }
        saving = false;
    }

    private void Cancel() => Nav.NavigateTo("/admin/consultations");

    private static string LiveEventLabel(LiveEventDto liveEvent) =>
        $"{liveEvent.StartsAt:dd.MM.yyyy HH:mm} — {liveEvent.Title}";
}
