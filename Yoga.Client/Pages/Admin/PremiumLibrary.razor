@page "/admin/premium-library"
@layout Yoga.Client.Layout.AdminLayout
@inject Yoga.Client.Services.AdminApiService Api
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>Premium-библиотека — Админ</PageTitle>

<div class="premium-library-page">
    <div class="page-header">
        <h1>Premium-библиотека</h1>
        <button class="btn-admin btn-admin-primary" @onclick="CreateNew">+ Добавить ресурс</button>
    </div>

    @if (loading)
    {
        <div class="admin-loading">Загрузка...</div>
    }
    else if (resources.Count == 0)
    {
        <div class="admin-empty">Ресурсы не найдены</div>
    }
    else
    {
        <div class="admin-table-wrap">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Название</th>
                        <th>Тип</th>
                        <th>Категория</th>
                        <th>Мин. тариф</th>
                        <th>Порядок</th>
                        <th>Статус</th>
                        <th>Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in resources)
                    {
                        <tr>
                            <td>@r.Title</td>
                            <td>@r.ResourceType</td>
                            <td>@(r.Category ?? "—")</td>
                            <td>@(r.MinimumTier ?? "Все")</td>
                            <td>@r.SortOrder</td>
                            <td>
                                <span class="badge @(r.IsActive ? "badge-success" : "badge-muted")">
                                    @(r.IsActive ? "Активен" : "Скрыт")
                                </span>
                            </td>
                            <td class="actions-cell">
                                <button class="btn-admin btn-admin-sm btn-admin-outline" @onclick="() => Edit(r.Id)">✎</button>
                                <button class="btn-admin btn-admin-sm btn-admin-danger" @onclick="() => ConfirmDelete(r)">✕</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    @if (deleteTarget != null)
    {
        <div class="modal-backdrop" @onclick="CancelDelete">
            <div class="modal-card" @onclick:stopPropagation="true">
                <h3>Удалить ресурс?</h3>
                <p>«@deleteTarget.Title» будет удалён.</p>
                <div class="modal-actions">
                    <button class="btn-admin btn-admin-outline" @onclick="CancelDelete">Отмена</button>
                    <button class="btn-admin btn-admin-danger" @onclick="ExecuteDelete">Удалить</button>
                </div>
            </div>
        </div>
    }

    @if (!string.IsNullOrEmpty(toast))
    {
        <div class="admin-toast @toastType">@toast</div>
    }
</div>

@code {
    private List<PremiumResourceDto> resources = new();
    private bool loading = true;
    private PremiumResourceDto? deleteTarget;
    private string? toast;
    private string toastType = "";
    private System.Threading.Timer? toastTimer;

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        loading = true;
        try { resources = await Api.GetAllPremiumResourcesAsync(); }
        catch { resources = new(); }
        loading = false;
    }

    private void CreateNew() => Nav.NavigateTo("/admin/premium-library/new");
    private void Edit(Guid id) => Nav.NavigateTo($"/admin/premium-library/{id}/edit");
    private void ConfirmDelete(PremiumResourceDto r) => deleteTarget = r;
    private void CancelDelete() => deleteTarget = null;

    private async Task ExecuteDelete()
    {
        if (deleteTarget == null) return;
        var ok = await Api.DeletePremiumResourceAsync(deleteTarget.Id);
        deleteTarget = null;
        if (ok) { ShowToast("Ресурс удалён", "success"); await LoadData(); }
        else ShowToast("Ошибка при удалении", "error");
    }

    private void ShowToast(string message, string type)
    {
        toast = message; toastType = type; StateHasChanged();
        toastTimer?.Dispose();
        toastTimer = new System.Threading.Timer(_ => { toast = null; InvokeAsync(StateHasChanged); }, null, 3000, System.Threading.Timeout.Infinite);
    }

    public void Dispose() => toastTimer?.Dispose();
}
