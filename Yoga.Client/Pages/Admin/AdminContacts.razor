@page "/admin/contacts-page"
@layout Yoga.Client.Layout.AdminLayout
@inject Yoga.Client.Services.AdminApiService Api

<PageTitle>Контакты — Админ</PageTitle>

<div class="edit-page">
    <div class="page-header">
        <h1>Страница «Контакты»</h1>
    </div>

    @if (loading)
    {
        <div class="admin-loading">Загрузка...</div>
    }
    else if (sitePage == null)
    {
        <div class="form-error">Страница «contacts» не найдена</div>
    }
    else
    {
        <div class="split-view">
            <div class="split-view-editor">
                <Yoga.Client.Components.Admin.ContentEditor
                    EntityType="SitePage"
                    EntityId="sitePage.Id"
                    Fields="AllFields"
                    OnValuesChanged="OnPreviewUpdate" />
            </div>
            <div class="split-view-preview">
                <Yoga.Client.Components.Admin.LivePreview @ref="preview"
                    PreviewPath="/contacts"
                    Language="ru" />
            </div>
        </div>
    }
</div>

@code {
    private SitePage? sitePage;
    private bool loading = true;
    private Yoga.Client.Components.Admin.LivePreview? preview;

    private static readonly ContentField[] AllFields = new ContentField[]
    {
        // Hero
        new("HeroTitle", "Заголовок", ContentFieldType.Text, "Hero"),
        new("HeroSubtitle", "Подзаголовок", ContentFieldType.Text, "Hero"),
        new("HeroImageUrl", "Фото героя", ContentFieldType.Image, "Hero"),

        // Telegram
        new("TelegramUrl", "Telegram — URL", ContentFieldType.Text, "Telegram"),
        new("TelegramHandle", "Telegram — Юзернейм", ContentFieldType.Text, "Telegram"),
        new("TelegramDesc", "Telegram — Описание", ContentFieldType.TextArea, "Telegram"),

        // WhatsApp
        new("WhatsAppUrl", "WhatsApp — URL", ContentFieldType.Text, "WhatsApp"),
        new("WhatsAppPhone", "WhatsApp — Телефон", ContentFieldType.Text, "WhatsApp"),
        new("WhatsAppDesc", "WhatsApp — Описание", ContentFieldType.TextArea, "WhatsApp"),

        // Instagram
        new("InstagramUrl", "Instagram — URL", ContentFieldType.Text, "Instagram"),
        new("InstagramHandle", "Instagram — Юзернейм", ContentFieldType.Text, "Instagram"),
        new("InstagramDesc", "Instagram — Описание", ContentFieldType.TextArea, "Instagram"),

        // YouTube
        new("YouTubeUrl", "YouTube — URL", ContentFieldType.Text, "YouTube"),
        new("YouTubeHandle", "YouTube — Канал", ContentFieldType.Text, "YouTube"),

        // SEO
        new("MetaTitle", "Meta Title", ContentFieldType.Text, "SEO"),
        new("MetaDescription", "Meta Description", ContentFieldType.TextArea, "SEO"),
        new("Content", "Дополнительный контент", ContentFieldType.RichText, "SEO"),
    };

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var all = await Api.GetAllSitePagesAsync();
            sitePage = all.FirstOrDefault(p => string.Equals(p.Slug, "contacts", StringComparison.OrdinalIgnoreCase));
        }
        catch { sitePage = null; }
        loading = false;
    }

    private async Task OnPreviewUpdate(Dictionary<string, string> values)
    {
        if (preview != null)
            await preview.SendUpdate(values);
    }
}
