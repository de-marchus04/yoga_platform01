@page "/admin/about-page"
@layout Yoga.Client.Layout.AdminLayout
@inject Yoga.Client.Services.AdminApiService Api

<PageTitle>О нас — Админ</PageTitle>

<div class="edit-page">
    <div class="page-header">
        <h1>Страница «О нас»</h1>
    </div>

    @if (loading)
    {
        <div class="admin-loading">Загрузка...</div>
    }
    else if (sitePage == null)
    {
        <div class="form-error">Страница «about» не найдена</div>
    }
    else
    {
        <div class="split-view">
            <div class="split-view-editor">
                <Yoga.Client.Components.Admin.ContentEditor
                    EntityType="SitePage"
                    EntityId="sitePage.Id"
                    Fields="AllFields"
                    OnValuesChanged="OnPreviewUpdate" />
            </div>
            <div class="split-view-preview">
                <Yoga.Client.Components.Admin.LivePreview @ref="preview"
                    PreviewPath="/about"
                    Language="ru" />
            </div>
        </div>
    }
</div>

@code {
    private SitePage? sitePage;
    private bool loading = true;
    private Yoga.Client.Components.Admin.LivePreview? preview;

    private static readonly ContentField[] AllFields = new ContentField[]
    {
        // Hero
        new("HeroTitle", "Заголовок", ContentFieldType.Text, "Hero"),
        new("HeroSubtitle", "Подзаголовок", ContentFieldType.Text, "Hero"),
        new("HeroImageUrl", "Фото героя", ContentFieldType.Image, "Hero"),

        // Основатель 1
        new("Founder1Name", "Имя", ContentFieldType.Text, "Основатель 1"),
        new("Founder1Role", "Роль", ContentFieldType.Text, "Основатель 1"),
        new("Founder1Text1", "Текст 1", ContentFieldType.TextArea, "Основатель 1"),
        new("Founder1Text2", "Текст 2", ContentFieldType.TextArea, "Основатель 1"),
        new("Founder1ImageUrl", "Фото", ContentFieldType.Image, "Основатель 1"),

        // Основатель 2
        new("Founder2Name", "Имя", ContentFieldType.Text, "Основатель 2"),
        new("Founder2Role", "Роль", ContentFieldType.Text, "Основатель 2"),
        new("Founder2Text1", "Текст 1", ContentFieldType.TextArea, "Основатель 2"),
        new("Founder2Text2", "Текст 2", ContentFieldType.TextArea, "Основатель 2"),
        new("Founder2ImageUrl", "Фото", ContentFieldType.Image, "Основатель 2"),

        // Основатель 3
        new("Founder3Name", "Имя", ContentFieldType.Text, "Основатель 3"),
        new("Founder3Role", "Роль", ContentFieldType.Text, "Основатель 3"),
        new("Founder3Text1", "Текст 1", ContentFieldType.TextArea, "Основатель 3"),
        new("Founder3Text2", "Текст 2", ContentFieldType.TextArea, "Основатель 3"),
        new("Founder3ImageUrl", "Фото", ContentFieldType.Image, "Основатель 3"),

        // Философия
        new("Phil1Title", "Принцип 1 — Заголовок", ContentFieldType.Text, "Философия"),
        new("Phil1Text", "Принцип 1 — Текст", ContentFieldType.TextArea, "Философия"),
        new("Phil2Title", "Принцип 2 — Заголовок", ContentFieldType.Text, "Философия"),
        new("Phil2Text", "Принцип 2 — Текст", ContentFieldType.TextArea, "Философия"),
        new("Phil3Title", "Принцип 3 — Заголовок", ContentFieldType.Text, "Философия"),
        new("Phil3Text", "Принцип 3 — Текст", ContentFieldType.TextArea, "Философия"),

        // SEO
        new("MetaTitle", "Meta Title", ContentFieldType.Text, "SEO"),
        new("MetaDescription", "Meta Description", ContentFieldType.TextArea, "SEO"),
        new("Content", "Дополнительный контент", ContentFieldType.RichText, "SEO"),
    };

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var all = await Api.GetAllSitePagesAsync();
            sitePage = all.FirstOrDefault(p => string.Equals(p.Slug, "about", StringComparison.OrdinalIgnoreCase));
        }
        catch { sitePage = null; }
        loading = false;
    }

    private async Task OnPreviewUpdate(Dictionary<string, string> values)
    {
        if (preview != null)
            await preview.SendUpdate(values);
    }
}
