@page "/admin/leads"
@layout Yoga.Client.Layout.AdminLayout
@inject Yoga.Client.Services.AdminApiService Api
@implements IDisposable

<PageTitle>Заявки — Админ</PageTitle>

<div class="leads-page">
    <div class="page-header">
        <h1>Заявки</h1>
        @if (result != null)
        {
            <span class="total-count">Всего: @result.TotalCount</span>
        }
    </div>

    <div class="admin-filters">
        <button class="filter-btn @FilterClass(null)" @onclick="() => SetFilter(null)">Все</button>
        <button class="filter-btn @FilterClass("unprocessed")" @onclick='() => SetFilter("unprocessed")'>Необработанные</button>
        <button class="filter-btn @FilterClass("processed")" @onclick='() => SetFilter("processed")'>Обработанные</button>
    </div>

    @if (loading)
    {
        <div class="admin-loading">Загрузка...</div>
    }
    else if (result == null || result.Items.Count == 0)
    {
        <div class="admin-empty">Заявки не найдены</div>
    }
    else
    {
        <div class="admin-table-wrap">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Имя</th>
                        <th>Контакт / Мессенджер</th>
                        <th>Цель (Формат)</th>
                        <th>Комментарий / Заметки</th>
                        <th>Дата</th>
                        <th>Статус</th>
                        <th>Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var lead in result.Items)
                    {
                        <tr class="@(lead.IsProcessed ? "row-processed" : "")">
                            <td>@lead.Name</td>
                            <td>
                                <div>@lead.ContactDetails</div>
                                @if (!string.IsNullOrEmpty(lead.Messager))
                                {
                                    <small class="admin-text-muted">@lead.Messager</small>
                                }
                            </td>
                            <td>
                                @if (lead.CourseId.HasValue)
                                {
                                    <div><span class="badge badge-info">Курс</span> @lead.CourseSlug</div>
                                }
                                else if (lead.ConsultationId.HasValue)
                                {
                                    <div><span class="badge badge-info">Консульт.</span> @lead.ConsultationSlug</div>
                                }
                                else if (lead.RetreatId.HasValue)
                                {
                                    <div><span class="badge badge-info">Ретрит</span> @lead.RetreatTitle</div>
                                }
                                else
                                {
                                    <div><span class="badge badge-secondary">Общая</span></div>
                                }
                                
                                @if (!string.IsNullOrEmpty(lead.TargetFormat))
                                {
                                    <small class="admin-text-muted">Формат: @lead.TargetFormat</small>
                                }
                            </td>
                            <td class="comment-cell">
                                @if (!string.IsNullOrEmpty(lead.Comment))
                                {
                                    <div><strong>Клиент:</strong> @lead.Comment</div>
                                }
                                @if (!string.IsNullOrEmpty(lead.AdminNotes))
                                {
                                    <div class="admin-text-muted" style="margin-top: 4px; padding-top: 4px; border-top: 1px solid #eee;">
                                        <strong>Admin:</strong> @lead.AdminNotes
                                    </div>
                                }
                            </td>
                            <td class="nowrap">@lead.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                            <td>
                                <select class="admin-input" style="padding: 2px 4px; width: 110px;" value="@lead.Status" @onchange="@(e => ChangeStatus(lead.Id, e.Value?.ToString() ?? "Входящая"))">
                                    <option value="Входящая">Входящая</option>
                                    <option value="В работе">В работе</option>
                                    <option value="Успешно">Успешно</option>
                                    <option value="Отказ">Отказ</option>
                                </select>
                            </td>
                            <td class="actions-cell">
                                <button class="btn-admin btn-admin-sm btn-admin-outline"
                                        title="Добавить заметку"
                                        @onclick="() => EditNotes(lead)">
                                    ✎
                                </button>
                                <button class="btn-admin btn-admin-sm btn-admin-danger"
                                        title="Удалить"
                                        @onclick="() => ConfirmDelete(lead)">
                                    ✕
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (totalPages > 1)
        {
            <div class="admin-pagination">
                <button class="btn-admin btn-admin-outline" disabled="@(page <= 1)" @onclick="() => GoToPage(page - 1)">←</button>
                @for (int i = 1; i <= totalPages; i++)
                {
                    var p = i;
                    <button class="btn-admin @(p == page ? "btn-admin-primary" : "btn-admin-outline")" @onclick="() => GoToPage(p)">@p</button>
                }
                <button class="btn-admin btn-admin-outline" disabled="@(page >= totalPages)" @onclick="() => GoToPage(page + 1)">→</button>
            </div>
        }
    }

    @if (deleteTarget != null)
    {
        <div class="modal-backdrop" @onclick="CancelDelete">
            <div class="modal-card" @onclick:stopPropagation="true">
                <h3>Удалить заявку?</h3>
                <p>Заявка от <strong>@deleteTarget.Name</strong> (@deleteTarget.ContactDetails) будет удалена безвозвратно.</p>
                <div class="modal-actions">
                    <button class="btn-admin btn-admin-outline" @onclick="CancelDelete">Отмена</button>
                    <button class="btn-admin btn-admin-danger" @onclick="ExecuteDelete">Удалить</button>
                </div>
            </div>
        </div>
    }

    @if (editNotesTarget != null)
    {
        <div class="modal-backdrop" @onclick="CancelEditNotes">
            <div class="modal-card" @onclick:stopPropagation="true">
                <h3>Заметки администратора</h3>
                <p>Заявка от <strong>@editNotesTarget.Name</strong></p>
                <div class="admin-form-group">
                    <textarea class="admin-input" @bind="editNotesText" rows="4" placeholder="Ваши заметки..."></textarea>
                </div>
                <div class="modal-actions">
                    <button class="btn-admin btn-admin-outline" @onclick="CancelEditNotes">Отмена</button>
                    <button class="btn-admin btn-admin-primary" @onclick="SaveNotes">Сохранить</button>
                </div>
            </div>
        </div>
    }

    @if (!string.IsNullOrEmpty(toast))
    {
        <div class="admin-toast @toastType">@toast</div>
    }
</div>

@code {
    private PaginatedResult<LeadSummaryDto>? result;
    private bool loading = true;
    private string? filter;
    private int page = 1;
    private const int PageSize = 20;
    private int totalPages => result == null ? 1 : (int)Math.Ceiling((double)result.TotalCount / PageSize);

    private LeadSummaryDto? deleteTarget;
    private LeadSummaryDto? editNotesTarget;
    private string editNotesText = "";
    
    private string? toast;
    private string toastType = "";
    private System.Threading.Timer? toastTimer;

    private string FilterClass(string? value) => filter == value ? "active" : "";

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        loading = true;
        StateHasChanged();
        try
        {
            result = await Api.GetLeadsAsync(page, PageSize, filter);
        }
        catch
        {
            result = null;
        }
        loading = false;
        StateHasChanged();
    }

    private async Task SetFilter(string? newFilter)
    {
        filter = newFilter;
        page = 1;
        await LoadData();
    }

    private async Task GoToPage(int newPage)
    {
        page = newPage;
        await LoadData();
    }

    private async Task ChangeStatus(Guid id, string newStatus)
    {
        var ok = await Api.UpdateLeadStatusAsync(id, newStatus);
        if (ok)
        {
            ShowToast("Статус обновлен", "success");
            await LoadData();
        }
        else
        {
            ShowToast("Ошибка при обновлении статуса", "error");
        }
    }

    private void EditNotes(LeadSummaryDto lead)
    {
        editNotesTarget = lead;
        editNotesText = lead.AdminNotes ?? "";
    }

    private void CancelEditNotes()
    {
        editNotesTarget = null;
    }

    private async Task SaveNotes()
    {
        if (editNotesTarget == null) return;
        var ok = await Api.UpdateLeadNotesAsync(editNotesTarget.Id, editNotesText);
        if (ok)
        {
            ShowToast("Заметки сохранены", "success");
            await LoadData();
        }
        else
        {
            ShowToast("Ошибка при сохранении", "error");
        }
        editNotesTarget = null;
    }

    private async Task ToggleProcessed(Guid id, bool processed)
    {
        var ok = await Api.MarkLeadProcessedAsync(id, processed);
        if (ok)
        {
            ShowToast(processed ? "Заявка обработана" : "Заявка возвращена", "success");
            await LoadData();
        }
        else
        {
            ShowToast("Ошибка при обновлении", "error");
        }
    }

    private void ConfirmDelete(LeadSummaryDto lead) => deleteTarget = lead;
    private void CancelDelete() => deleteTarget = null;

    private async Task ExecuteDelete()
    {
        if (deleteTarget == null) return;
        var ok = await Api.DeleteLeadAsync(deleteTarget.Id);
        deleteTarget = null;
        if (ok)
        {
            ShowToast("Заявка удалена", "success");
            await LoadData();
        }
        else
        {
            ShowToast("Ошибка при удалении", "error");
        }
    }

    private void ShowToast(string message, string type)
    {
        toast = message;
        toastType = type;
        StateHasChanged();
        toastTimer?.Dispose();
        toastTimer = new System.Threading.Timer(_ =>
        {
            toast = null;
            InvokeAsync(StateHasChanged);
        }, null, 3000, System.Threading.Timeout.Infinite);
    }

    public void Dispose()
    {
        toastTimer?.Dispose();
    }
}
