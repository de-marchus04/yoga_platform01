@page "/admin/premium-library/new"
@page "/admin/premium-library/{Id:guid}/edit"
@layout Yoga.Client.Layout.AdminLayout
@inject Yoga.Client.Services.AdminApiService Api
@inject NavigationManager Nav

<PageTitle>@(IsNew ? "Новый ресурс" : "Редактирование ресурса") — Админ</PageTitle>

<div class="edit-page">
    <div class="page-header">
        <h1>@(IsNew ? "Новый ресурс" : "Редактирование ресурса")</h1>
    </div>

    @if (loading)
    {
        <div class="admin-loading">Загрузка...</div>
    }
    else
    {
        <div class="form-card">
            <div class="form-row">
                <div class="admin-form-group">
                    <label>Название</label>
                    <input class="admin-input" @bind="title" />
                </div>
                <div class="admin-form-group">
                    <label>Тип</label>
                    <select class="admin-input" @bind="resourceType">
                        <option value="video">Видео</option>
                        <option value="guide">Гайд</option>
                        <option value="masterclass">Мастер-класс</option>
                        <option value="audio">Аудио</option>
                        <option value="document">Документ</option>
                    </select>
                </div>
            </div>

            <div class="admin-form-group">
                <label>Описание</label>
                <textarea class="admin-input" rows="3" @bind="description"></textarea>
            </div>

            <div class="form-row">
                <div class="admin-form-group">
                    <label>URL медиа</label>
                    <input class="admin-input" @bind="mediaUrl" placeholder="https://..." />
                </div>
                <div class="admin-form-group">
                    <label>Длительность (минуты)</label>
                    <input class="admin-input" type="number" @bind="durationMinutes" />
                </div>
            </div>

            <div class="form-row">
                <div class="admin-form-group">
                    <label>Категория</label>
                    <input class="admin-input" @bind="category" />
                </div>
                <div class="admin-form-group">
                    <label>Мин. тариф</label>
                    <select class="admin-input" @bind="minimumTier">
                        <option value="">Все подписчики</option>
                        <option value="Premium">Premium</option>
                        <option value="Vip">VIP</option>
                    </select>
                </div>
            </div>

            <div class="admin-form-group">
                <label>Порядок сортировки</label>
                <input class="admin-input" type="number" @bind="sortOrder" style="max-width:150px;" />
            </div>

            @if (!string.IsNullOrEmpty(error))
            {
                <div class="form-error">@error</div>
            }

            <div class="form-actions">
                <button class="btn-admin btn-admin-outline" @onclick="Cancel">Отмена</button>
                <button class="btn-admin btn-admin-primary" disabled="@saving" @onclick="Save">
                    @(saving ? "Сохранение..." : "Сохранить")
                </button>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public Guid? Id { get; set; }
    private bool IsNew => Id == null;

    private string title = "", resourceType = "video";
    private string? description, mediaUrl, category, minimumTier;
    private int durationMinutes, sortOrder;
    private bool loading, saving;
    private string? error;

    protected override async Task OnInitializedAsync()
    {
        if (!IsNew)
        {
            loading = true;
            try
            {
                var all = await Api.GetAllPremiumResourcesAsync();
                var found = all.FirstOrDefault(r => r.Id == Id);
                if (found != null)
                {
                    title = found.Title;
                    description = found.Description;
                    resourceType = found.ResourceType;
                    mediaUrl = found.MediaUrl;
                    durationMinutes = found.Duration.HasValue ? (int)found.Duration.Value.TotalMinutes : 0;
                    category = found.Category;
                    minimumTier = found.MinimumTier;
                    sortOrder = found.SortOrder;
                }
                else error = "Ресурс не найден";
            }
            catch { error = "Ошибка загрузки"; }
            loading = false;
        }
    }

    private async Task Save()
    {
        if (string.IsNullOrWhiteSpace(title)) { error = "Название обязательно"; return; }
        saving = true; error = null;
        try
        {
            var duration = durationMinutes > 0 ? TimeSpan.FromMinutes(durationMinutes) : (TimeSpan?)null;
            var tier = string.IsNullOrEmpty(minimumTier) ? null : minimumTier;
            var request = new CreatePremiumResourceRequest(title, description, resourceType, mediaUrl, duration, tier, category, sortOrder);

            HttpResponseMessage r;
            if (IsNew) r = await Api.CreatePremiumResourceAsync(request);
            else r = await Api.UpdatePremiumResourceAsync(Id!.Value, request);

            if (r.IsSuccessStatusCode) Nav.NavigateTo("/admin/premium-library");
            else error = $"Ошибка: {r.StatusCode}";
        }
        catch (Exception ex) { error = ex.Message; }
        saving = false;
    }

    private void Cancel() => Nav.NavigateTo("/admin/premium-library");
}
