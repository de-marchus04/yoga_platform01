@page "/admin/settings"
@layout Yoga.Client.Layout.AdminLayout
@inject Yoga.Client.Services.AdminApiService Api
@implements IDisposable

<PageTitle>Настройки — Админ</PageTitle>

<div class="settings-page">
    <div class="page-header">
        <h1>Настройки</h1>
    </div>

    <div class="settings-section">
        <h2>Администраторы</h2>
        <button class="btn-admin btn-admin-primary btn-admin-sm" @onclick="() => showCreate = true" style="margin-bottom:16px">+ Добавить администратора</button>

        @if (loadingUsers)
        {
            <div class="admin-loading">Загрузка...</div>
        }
        else
        {
            <div class="admin-table-wrap">
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th>Логин</th>
                            <th>Имя</th>
                            <th>Email</th>
                            <th>Создан</th>
                            <th>Последний вход</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var u in users)
                        {
                            <tr>
                                <td>@u.Username</td>
                                <td>@(u.DisplayName ?? "—")</td>
                                <td>@(u.Email ?? "—")</td>
                                <td class="nowrap">@u.CreatedAt.ToString("dd.MM.yyyy")</td>
                                <td class="nowrap">@(u.LastLoginAt?.ToString("dd.MM.yyyy HH:mm") ?? "—")</td>
                                <td>
                                    @if (users.Count > 1)
                                    {
                                        <button class="btn-admin btn-admin-sm btn-admin-danger" @onclick="() => ConfirmDeleteUser(u)">✕</button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>

    <div class="settings-section">
        <h2>Смена пароля</h2>
        <div class="form-card" style="max-width:640px;">
            <div class="admin-form-group">
                <label>Текущий пароль</label>
                <input class="admin-input" type="password" @bind="currentPassword" autocomplete="current-password" />
            </div>
            <div class="admin-form-group">
                <label>Новый пароль</label>
                <input class="admin-input" type="password" @bind="newOwnPassword" autocomplete="new-password" />
            </div>
            <div class="admin-form-group">
                <label>Подтверждение нового пароля</label>
                <input class="admin-input" type="password" @bind="confirmOwnPassword" autocomplete="new-password" />
            </div>
            <p class="admin-text-muted" style="margin-top:-4px;">Минимум 12 символов. Не используйте bootstrap-пароль на production.</p>
            @if (!string.IsNullOrEmpty(passwordError))
            {
                <div class="form-error">@passwordError</div>
            }
            <div class="form-actions">
                <button class="btn-admin btn-admin-primary" @onclick="ChangeOwnPassword" disabled="@passwordChanging">@(passwordChanging ? "Сохранение..." : "Сменить пароль")</button>
            </div>
        </div>
    </div>

    @if (showCreate)
    {
        <div class="modal-backdrop" @onclick="() => showCreate = false">
            <div class="modal-card" @onclick:stopPropagation="true">
                <h3>Новый администратор</h3>
                <div class="admin-form-group">
                    <label>Логин</label>
                    <input class="admin-input" @bind="newUsername" />
                </div>
                <div class="admin-form-group">
                    <label>Пароль</label>
                    <input class="admin-input" type="password" @bind="newPassword" />
                </div>
                <div class="admin-form-group">
                    <label>Отображаемое имя</label>
                    <input class="admin-input" @bind="newDisplayName" />
                </div>
                <div class="admin-form-group">
                    <label>Email</label>
                    <input class="admin-input" type="email" @bind="newEmail" />
                </div>
                @if (!string.IsNullOrEmpty(createError))
                {
                    <div class="form-error">@createError</div>
                }
                <div class="modal-actions">
                    <button class="btn-admin btn-admin-outline" @onclick="() => showCreate = false">Отмена</button>
                    <button class="btn-admin btn-admin-primary" @onclick="CreateUser">Создать</button>
                </div>
            </div>
        </div>
    }

    @if (deleteUserTarget != null)
    {
        <div class="modal-backdrop" @onclick="() => deleteUserTarget = null">
            <div class="modal-card" @onclick:stopPropagation="true">
                <h3>Удалить администратора?</h3>
                <p>Пользователь «@deleteUserTarget.Username» будет удалён.</p>
                <div class="modal-actions">
                    <button class="btn-admin btn-admin-outline" @onclick="() => deleteUserTarget = null">Отмена</button>
                    <button class="btn-admin btn-admin-danger" @onclick="ExecuteDeleteUser">Удалить</button>
                </div>
            </div>
        </div>
    }

    @if (!string.IsNullOrEmpty(toast))
    {
        <div class="admin-toast @toastType">@toast</div>
    }
</div>

@code {
    private List<AdminUserDto> users = new();
    private bool loadingUsers = true;
    private bool showCreate;
    private string newUsername = "";
    private string newPassword = "";
    private string? newDisplayName;
    private string? newEmail;
    private string? createError;
    private string currentPassword = "";
    private string newOwnPassword = "";
    private string confirmOwnPassword = "";
    private string? passwordError;
    private bool passwordChanging;
    private AdminUserDto? deleteUserTarget;
    private string? toast;
    private string toastType = "";
    private System.Threading.Timer? toastTimer;

    protected override async Task OnInitializedAsync() => await LoadUsers();

    private async Task LoadUsers()
    {
        loadingUsers = true;
        try { users = await Api.GetAdminUsersAsync(); }
        catch { users = new(); }
        loadingUsers = false;
    }

    private async Task CreateUser()
    {
        if (string.IsNullOrWhiteSpace(newUsername) || string.IsNullOrWhiteSpace(newPassword))
        {
            createError = "Логин и пароль обязательны";
            return;
        }
        createError = null;

        var request = new CreateAdminUserRequest(newUsername, newPassword, newDisplayName, newEmail);
        var response = await Api.CreateAdminUserAsync(request);
        if (response.IsSuccessStatusCode)
        {
            showCreate = false;
            newUsername = ""; newPassword = ""; newDisplayName = null; newEmail = null;
            ShowToast("Администратор создан", "success");
            await LoadUsers();
        }
        else
        {
            createError = response.StatusCode == System.Net.HttpStatusCode.Conflict
                ? "Пользователь с таким логином уже существует"
                : $"Ошибка: {response.StatusCode}";
        }
    }

    private void ConfirmDeleteUser(AdminUserDto u) => deleteUserTarget = u;

    private async Task ChangeOwnPassword()
    {
        passwordError = null;

        if (string.IsNullOrWhiteSpace(currentPassword) || string.IsNullOrWhiteSpace(newOwnPassword) || string.IsNullOrWhiteSpace(confirmOwnPassword))
        {
            passwordError = "Заполните все поля для смены пароля";
            return;
        }

        if (newOwnPassword.Length < 12)
        {
            passwordError = "Новый пароль должен содержать минимум 12 символов";
            return;
        }

        if (newOwnPassword != confirmOwnPassword)
        {
            passwordError = "Подтверждение пароля не совпадает";
            return;
        }

        passwordChanging = true;
        var (success, error) = await Api.ChangeAdminPasswordAsync(new ChangePasswordRequest(currentPassword, newOwnPassword));
        passwordChanging = false;

        if (!success)
        {
            passwordError = error ?? "Не удалось сменить пароль";
            return;
        }

        currentPassword = "";
        newOwnPassword = "";
        confirmOwnPassword = "";
        ShowToast("Пароль обновлён", "success");
    }

    private async Task ExecuteDeleteUser()
    {
        if (deleteUserTarget == null) return;
        var response = await Api.DeleteAdminUserAsync(deleteUserTarget.Id);
        deleteUserTarget = null;
        if (response)
        {
            ShowToast("Администратор удалён", "success");
            await LoadUsers();
        }
        else ShowToast("Ошибка удаления", "error");
    }

    private void ShowToast(string message, string type)
    {
        toast = message; toastType = type; StateHasChanged();
        toastTimer?.Dispose();
        toastTimer = new System.Threading.Timer(_ => { toast = null; InvokeAsync(StateHasChanged); }, null, 3000, System.Threading.Timeout.Infinite);
    }

    public void Dispose() => toastTimer?.Dispose();
}
