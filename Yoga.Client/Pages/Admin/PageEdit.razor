@page "/admin/pages/{Slug}/edit"
@layout Yoga.Client.Layout.AdminLayout
@inject Yoga.Client.Services.AdminApiService Api
@inject NavigationManager Nav

<PageTitle>Редактирование страницы «@Slug» — Админ</PageTitle>

<div class="edit-page">
    <div class="page-header">
        <h1>Страница: @Slug</h1>
    </div>

    @if (loading)
    {
        <div class="admin-loading">Загрузка...</div>
    }
    else if (sitePage == null)
    {
        <div class="form-error">Страница «@Slug» не найдена</div>
    }
    else
    {
        <div class="form-card">
            <h3 class="section-title">Информация</h3>
            <div class="admin-form-group">
                <label>Slug</label>
                <input class="admin-input" value="@sitePage.Slug" disabled />
            </div>
        </div>

        <Yoga.Client.Components.Admin.TranslationEditor
            EntityType="SitePage"
            EntityId="sitePage.Id"
            Fields="GetFieldsForSlug()" />
    }

    <div class="form-actions" style="margin-top:1rem;">
        <button class="btn-admin btn-admin-outline" @onclick="GoBack">← Назад к списку</button>
    </div>
</div>

@code {
    [Parameter] public string Slug { get; set; } = "";

    private SitePage? sitePage;
    private bool loading = true;

    protected override async Task OnParametersSetAsync()
    {
        loading = true;
        sitePage = null;

        var normalizedSlug = (Slug ?? string.Empty).Trim();

        if (string.Equals(normalizedSlug, "home", StringComparison.OrdinalIgnoreCase))
        {
            Nav.NavigateTo("/admin/pages/home", replace: true);
            return;
        }

        try
        {
            var all = await Api.GetAllSitePagesAsync();
            sitePage = all.FirstOrDefault(p => string.Equals(p.Slug, normalizedSlug, StringComparison.OrdinalIgnoreCase));
        }
        catch
        {
            sitePage = null;
        }

        loading = false;
    }

    private string[] GetFieldsForSlug() => Slug switch
    {
        "home" => new[] { 
            "HeroTitle", "HeroSubtitle", "HeroEyebrow", "HeroText", "HeroImage", 
            "Stats1Label", "Stats1Value", "Stats2Label", "Stats2Value", "Stats3Label", "Stats3Value", "Stats4Label", "Stats4Value",
            "Dir1Title", "Dir1Text", "Dir1LinkText", "Dir2Title", "Dir2Text", "Dir2LinkText", "Dir3Title", "Dir3Text", "Dir3LinkText",
            "QuoteText", "QuoteAuthor",
            "Format1Title", "Format1Text", "Format1Cta", "Format1Image", "Format2Title", "Format2Text", "Format2Cta", "Format2Image",
            "Review1Quote", "Review1Author", "Review1Program", "Review2Quote", "Review2Author", "Review2Program", "Review3Quote", "Review3Author", "Review3Program",
            "MetaTitle", "MetaDescription", "Content" 
        },
        "about" => new[] {
            "HeroTitle", "HeroSubtitle", "HeroImageUrl",
            "Founder1Name", "Founder1Role", "Founder1Text1", "Founder1Text2", "Founder1ImageUrl",
            "Founder2Name", "Founder2Role", "Founder2Text1", "Founder2Text2", "Founder2ImageUrl",
            "Founder3Name", "Founder3Role", "Founder3Text1", "Founder3Text2", "Founder3ImageUrl",
            "Phil1Title", "Phil1Text", "Phil2Title", "Phil2Text", "Phil3Title", "Phil3Text",
            "MetaTitle", "MetaDescription", "Content"
        },
        "contacts" => new[] {
            "HeroTitle", "HeroSubtitle", "HeroImageUrl",
            "TelegramUrl", "TelegramHandle", "TelegramDesc",
            "WhatsAppUrl", "WhatsAppPhone", "WhatsAppDesc",
            "InstagramUrl", "InstagramHandle", "InstagramDesc",
            "YouTubeUrl", "YouTubeHandle",
            "MetaTitle", "MetaDescription", "Content"
        },
        "courses" => new[] {
            "HeroImageUrl", "Eyebrow", "H1", "Intro", "H2", "CardCta",
            "HeroTitle", "HeroSubtitle", "MetaTitle", "MetaDescription"
        },
        "consultations" => new[] {
            "HeroImageUrl", "Eyebrow", "H1", "Intro", "H2", "CardCta",
            "HeroTitle", "HeroSubtitle", "MetaTitle", "MetaDescription"
        },
        "blog" => new[] {
            "HeroImageUrl", "Eyebrow", "H1", "Intro", "H2",
            "ArticlesImageUrl", "VideosImageUrl", "PhotosImageUrl", "ReadMore",
            "HeroTitle", "HeroSubtitle", "MetaTitle", "MetaDescription"
        },
        "retreats" => new[] {
            "HeroImageUrl", "Eyebrow",
            "ActualH1", "ActualIntro", "ActualImageUrl",
            "UpcomingH1", "UpcomingIntro", "UpcomingImageUrl",
            "PastH1", "PastIntro", "PastImageUrl",
            "CardCta", "HeroTitle", "HeroSubtitle", "MetaTitle", "MetaDescription"
        },
        _ => new[] { "HeroTitle", "HeroSubtitle", "Content", "MetaTitle", "MetaDescription" }
    };

    private void GoBack() => Nav.NavigateTo("/admin/pages");
}
