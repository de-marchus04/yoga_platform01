@page "/admin/login"
@layout MainLayout
@inject AdminAuthService Auth
@inject NavigationManager Nav
@inject IConfiguration Config

<PageTitle>Вход — shakti.ashram Admin</PageTitle>

<section class="auth-section admin-auth-section">
    <div class="auth-visual">
        <div class="auth-visual-overlay"></div>
        <div class="auth-visual-content">
            <span class="brand-lockup auth-brand">
                <span class="brand-mark" aria-hidden="true">
                    <svg viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg" focusable="false">
                        <circle cx="32" cy="32" r="28.5" />
                        <path d="M32 13.5c4.9 6.2 7.4 11.9 7.4 17.1 0 6.1-2.5 11.1-7.4 15.2-4.9-4.1-7.4-9.1-7.4-15.2 0-5.2 2.5-10.9 7.4-17.1Z" />
                        <path d="M24.2 24.1c-6 1.2-10.1 4.7-12.5 10.5 6.8.3 12.2 2.8 16.3 7.6" />
                        <path d="M39.8 24.1c6 1.2 10.1 4.7 12.5 10.5-6.8.3-12.2 2.8-16.3 7.6" />
                        <path d="M20.2 33.2c-4.6 1.1-7.9 4-9.8 8.6 5.4.1 9.8 1.9 13.1 5.3" />
                        <path d="M43.8 33.2c4.6 1.1 7.9 4 9.8 8.6-5.4.1-9.8 1.9-13.1 5.3" />
                        <path d="M21.4 49.6c3.3-2.9 6.9-4.3 10.6-4.3 3.8 0 7.3 1.4 10.6 4.3" />
                        <path d="M28.8 54.2c.9-2.3 2-3.9 3.2-4.8 1.2.9 2.3 2.5 3.2 4.8" />
                        <path d="M32 22.1c1.7 1.4 2.5 3.2 2.5 5.3S33.7 31.3 32 32.7c-1.7-1.4-2.5-3.2-2.5-5.3s.8-3.9 2.5-5.3Z" />
                    </svg>
                </span>
                <span class="brand-wordmark">
                    <span class="brand-prefix">sha</span><span class="brand-rest">kti.ashram</span>
                </span>
            </span>
            <p class="auth-visual-tagline">Панель управления</p>
        </div>
    </div>

    <div class="auth-form-panel">
        <div class="auth-card">
            <div class="auth-eyebrow">Администратор</div>
            <h1>Войти</h1>
            <div class="auth-divider"></div>

            @if (!string.IsNullOrEmpty(deploymentWarning))
            {
                <div class="auth-error">@deploymentWarning</div>
            }
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="auth-error">@errorMessage</div>
            }

            <EditForm Model="@loginModel" OnValidSubmit="HandleLogin">
                <div class="auth-field">
                    <label class="auth-label" for="admin-username">Имя пользователя</label>
                    <input id="admin-username" type="text" class="auth-input" @bind="loginModel.Username" required autocomplete="username" />
                </div>
                <div class="auth-field">
                    <label class="auth-label" for="admin-password">Пароль</label>
                    <input id="admin-password" type="password" class="auth-input" @bind="loginModel.Password" required autocomplete="current-password" />
                </div>
                <button type="submit" class="auth-submit" disabled="@isLoading">
                    @(isLoading ? "ВХОД..." : "ВОЙТИ")
                </button>
            </EditForm>
        </div>
    </div>
</section>

@code {
    private LoginModel loginModel = new();
    private string? errorMessage;
    private string? deploymentWarning;
    private bool isLoading;

    private class LoginModel
    {
        public string Username { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
    }

    private async Task HandleLogin()
    {
        isLoading = true;
        errorMessage = null;

        var (success, error) = await Auth.LoginAsync(loginModel.Username, loginModel.Password);
        if (success)
        {
            Nav.NavigateTo("/admin");
        }
        else
        {
            errorMessage = error ?? "Ошибка входа";
        }

        isLoading = false;
    }

    protected override void OnInitialized()
    {
        if (!Uri.TryCreate(Nav.Uri, UriKind.Absolute, out var currentUri))
        {
            return;
        }

        var publicBaseUrl = Config["Api:PublicBaseUrl"];
        Uri? apiUri = null;
        var isLocalHost = currentUri.IsLoopback
            || string.Equals(currentUri.Host, "localhost", StringComparison.OrdinalIgnoreCase)
            || string.Equals(currentUri.Host, "127.0.0.1", StringComparison.OrdinalIgnoreCase);

        if (!isLocalHost && !Uri.TryCreate(publicBaseUrl, UriKind.Absolute, out apiUri))
        {
            deploymentWarning = "Этот deploy не содержит корректный внешний Api.PublicBaseUrl. Логин не заработает, пока frontend не будет перевыпущен с реальным HTTPS-адресом backend API.";
            return;
        }

        if (!isLocalHost && apiUri is not null && !string.Equals(apiUri.Scheme, Uri.UriSchemeHttps, StringComparison.OrdinalIgnoreCase))
        {
            deploymentWarning = "Текущий Api.PublicBaseUrl не использует HTTPS. Для Vercel-hosted frontend это приведет к сбоям авторизации и блокировке mixed content.";
        }
    }
}
