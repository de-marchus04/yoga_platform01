@page "/admin/login"
@layout MainLayout
@inject AdminAuthService Auth
@inject NavigationManager Nav
@inject IConfiguration Config

<PageTitle>Вход — shakti.ashram Admin</PageTitle>

<div class="login-page">
    <div class="login-card">
        <div class="login-brand" aria-label="shakti.ashram">
            <span class="brand-wordmark">
                <span class="brand-prefix">sha</span><span class="brand-rest">kti.ashram</span>
            </span>
        </div>
        <h2>Панель управления</h2>
        <p class="login-subtitle">Вход для администраторов. Если сайт открыт на Vercel, эта страница требует рабочий внешний API, а не локальный адрес.</p>

        @if (!string.IsNullOrEmpty(deploymentWarning))
        {
            <div class="login-error">@deploymentWarning</div>
        }

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="login-error">@errorMessage</div>
        }

        <EditForm Model="@loginModel" OnValidSubmit="HandleLogin">
            <div class="admin-form-group">
                <label>Имя пользователя</label>
                <input type="text" class="admin-input" @bind="loginModel.Username" required autocomplete="username" />
            </div>

            <div class="admin-form-group">
                <label>Пароль</label>
                <input type="password" class="admin-input" @bind="loginModel.Password" required autocomplete="current-password" />
            </div>

            <button type="submit" class="btn-admin login-submit" disabled="@isLoading">
                @(isLoading ? "ВХОД..." : "ВОЙТИ")
            </button>
        </EditForm>
    </div>
</div>

@code {
    private LoginModel loginModel = new();
    private string? errorMessage;
    private string? deploymentWarning;
    private bool isLoading;

    private class LoginModel
    {
        public string Username { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
    }

    private async Task HandleLogin()
    {
        isLoading = true;
        errorMessage = null;

        var (success, error) = await Auth.LoginAsync(loginModel.Username, loginModel.Password);
        if (success)
        {
            Nav.NavigateTo("/admin");
        }
        else
        {
            errorMessage = error ?? "Ошибка входа";
        }

        isLoading = false;
    }

    protected override void OnInitialized()
    {
        if (!Uri.TryCreate(Nav.Uri, UriKind.Absolute, out var currentUri))
        {
            return;
        }

        var publicBaseUrl = Config["Api:PublicBaseUrl"];
        Uri? apiUri = null;
        var isLocalHost = currentUri.IsLoopback
            || string.Equals(currentUri.Host, "localhost", StringComparison.OrdinalIgnoreCase)
            || string.Equals(currentUri.Host, "127.0.0.1", StringComparison.OrdinalIgnoreCase);

        if (!isLocalHost && !Uri.TryCreate(publicBaseUrl, UriKind.Absolute, out apiUri))
        {
            deploymentWarning = "Этот deploy не содержит корректный внешний Api.PublicBaseUrl. Логин не заработает, пока frontend не будет перевыпущен с реальным HTTPS-адресом backend API.";
            return;
        }

        if (!isLocalHost && apiUri is not null && !string.Equals(apiUri.Scheme, Uri.UriSchemeHttps, StringComparison.OrdinalIgnoreCase))
        {
            deploymentWarning = "Текущий Api.PublicBaseUrl не использует HTTPS. Для Vercel-hosted frontend это приведет к сбоям авторизации и блокировке mixed content.";
        }
    }
}
