@page "/admin/courses/new"
@page "/admin/courses/{Id:guid}/edit"
@layout Yoga.Client.Layout.AdminLayout
@inject Yoga.Client.Services.AdminApiService Api
@inject NavigationManager Nav

<PageTitle>@(IsNew ? "Новый курс" : "Редактирование курса") — Админ</PageTitle>

<div class="edit-page">
    <div class="page-header">
        <h1>@(IsNew ? "Новый курс" : "Редактирование курса")</h1>
    </div>

    @if (loading)
    {
        <div class="admin-loading">Загрузка...</div>
    }
    else
    {
        <div class="form-card">
            <h3 class="section-title">Метаданные</h3>
            <div class="form-row">
                <div class="admin-form-group">
                    <label>Slug</label>
                    <input class="admin-input" @bind="model.Slug" placeholder="yoga" />
                </div>
                <div class="admin-form-group">
                    <label>Порядок сортировки</label>
                    <input class="admin-input" type="number" @bind="model.SortOrder" />
                </div>
            </div>

            <div class="admin-form-group checkbox-group">
                <label>
                    <input type="checkbox" @bind="model.IsActive" />
                    Активен (виден на сайте)
                </label>
                <label>
                    <input type="checkbox" @bind="model.IsOnline" />
                    Онлайн формат
                </label>
                <label>
                    <input type="checkbox" @bind="model.IsOffline" />
                    Офлайн формат
                </label>
            </div>

            <div class="admin-form-group">
                <label>Трансляция для авто-доступа</label>
                <InputSelect class="admin-input" @bind-Value="model.LiveEventId">
                    <option value="">Без авто-доступа</option>
                    @foreach (var liveEvent in liveEvents.OrderByDescending(item => item.StartsAt))
                    {
                        <option value="@liveEvent.Id">@LiveEventLabel(liveEvent)</option>
                    }
                </InputSelect>
                <div class="admin-text-muted" style="margin-top:0.35rem;">
                    При успешной обработке онлайн-заявки доступ к выбранной трансляции будет выдан автоматически.
                </div>
            </div>

            @if (!string.IsNullOrEmpty(error))
            {
                <div class="form-error">@error</div>
            }

            <div class="form-actions">
                <button class="btn-admin btn-admin-outline" @onclick="Cancel">Отмена</button>
                <button class="btn-admin btn-admin-primary" disabled="@saving" @onclick="Save">
                    @(saving ? "Сохранение..." : "Сохранить метаданные")
                </button>
            </div>
        </div>

        @if (!IsNew)
        {
            <div class="split-view">
                <div class="split-view-editor">
                    <Yoga.Client.Components.Admin.ContentEditor
                        EntityType="Course"
                        EntityId="model.Id"
                        Fields="courseContentFields" />

                    @* Модули курса *@
                    <div class="form-card" style="margin-top:1.5rem;">
                        <h3 class="section-title">Модули курса</h3>
                        @if (model.Modules.Any())
                        {
                            @foreach (var mod in model.Modules.OrderBy(m => m.SortOrder))
                            {
                                <div class="module-card">
                                    <div class="form-row">
                                        <div class="admin-form-group" style="flex:0 0 100px;">
                                            <label>Порядок</label>
                                            <input class="admin-input" type="number" @bind="mod.SortOrder" />
                                        </div>
                                        <div style="display:flex;align-items:flex-end;padding-bottom:4px;">
                                            <button class="btn-admin btn-admin-danger" @onclick="() => RemoveModule(mod)">✕</button>
                                        </div>
                                    </div>
                                    <Yoga.Client.Components.Admin.ContentEditor
                                        EntityType="CourseModule"
                                        EntityId="mod.Id"
                                        Fields="moduleContentFields" />

                                    @* Уроки внутри модуля *@
                                    <div style="margin-top:0.75rem; padding-left:1rem; border-left:3px solid var(--a-border, #333);">
                                        <h4 style="margin:0 0 0.5rem; font-size:0.85rem; color:var(--a-text-muted,#888);">Уроки</h4>
                                        @foreach (var lesson in mod.Lessons.OrderBy(l => l.SortOrder))
                                        {
                                            <div class="module-card" style="margin-bottom:0.75rem;">
                                                <div class="form-row">
                                                    <div class="admin-form-group" style="flex:0 0 80px;">
                                                        <label>№</label>
                                                        <input class="admin-input" type="number" @bind="lesson.SortOrder" />
                                                    </div>
                                                    <div style="display:flex;align-items:flex-end;padding-bottom:4px;">
                                                        <button class="btn-admin btn-admin-danger btn-admin-sm" @onclick="() => RemoveLesson(mod, lesson)">✕</button>
                                                    </div>
                                                </div>
                                                <Yoga.Client.Components.Admin.ContentEditor
                                                    EntityType="CourseLesson"
                                                    EntityId="lesson.Id"
                                                    Fields="lessonContentFields" />
                                            </div>
                                        }
                                        <button class="btn-admin btn-admin-outline btn-admin-sm" @onclick="() => AddLesson(mod)">+ Добавить урок</button>
                                    </div>
                                </div>
                            }
                        }
                        <button class="btn-admin btn-admin-outline" @onclick="AddModule">+ Добавить модуль</button>
                        <div class="form-actions" style="margin-top:1rem;">
                            <button class="btn-admin btn-admin-primary" disabled="@savingModules" @onclick="SaveModules">
                                @(savingModules ? "Сохранение..." : "Сохранить структуру")
                            </button>
                        </div>
                    </div>
                </div>
                <div class="split-view-preview">
                    <Yoga.Client.Components.Admin.LivePreview
                        PreviewPath="@($"/courses/{model.Slug}")"
                        Language="ru" />
                </div>
            </div>
        }
        else
        {
            <div class="form-card" style="margin-top:1.5rem;">
                <p class="admin-text-muted">Сначала сохраните курс, чтобы редактировать контент и модули.</p>
            </div>
        }
    }
</div>

@code {
    [Parameter] public Guid? Id { get; set; }
    private bool IsNew => Id == null;

    private static readonly ContentField[] courseContentFields = new ContentField[]
    {
        new("Title", "Заголовок", ContentFieldType.Text, "Основное"),
        new("Subtitle", "Подзаголовок", ContentFieldType.Text, "Основное"),
        new("Eyebrow", "Надзаголовок", ContentFieldType.Text, "Основное"),
        new("Description", "Описание", ContentFieldType.RichText, "Основное"),
        new("ImageUrl", "Фото Hero", ContentFieldType.Image, "Фото"),
        new("PresentationImage1Url", "Презентационное фото 1", ContentFieldType.Image, "Фото"),
        new("PresentationImage2Url", "Презентационное фото 2", ContentFieldType.Image, "Фото"),
        new("InstructorImageUrl", "Фото инструктора", ContentFieldType.Image, "Инструктор"),
        new("InstructorName", "Имя инструктора", ContentFieldType.Text, "Инструктор"),
        new("InstructorBio", "Об инструкторе", ContentFieldType.TextArea, "Инструктор"),
        new("Duration", "Длительность", ContentFieldType.Text, "Детали"),
        new("Level", "Уровень", ContentFieldType.Text, "Детали"),
        new("Format", "Формат", ContentFieldType.Text, "Детали"),
        new("Schedule", "Расписание", ContentFieldType.Text, "Детали"),
        new("Benefits", "Преимущества (через |)", ContentFieldType.TextArea, "Для кого", "Пункт1|Пункт2|Пункт3"),
        new("ForWhom", "Для кого", ContentFieldType.ForWhom, "Для кого"),
        new("CtaHeading", "CTA заголовок", ContentFieldType.Text, "CTA"),
        new("CtaText", "CTA текст", ContentFieldType.TextArea, "CTA"),
    };
    private static readonly ContentField[] moduleContentFields = new ContentField[]
    {
        new("Title", "Заголовок модуля", ContentFieldType.Text, "Модуль"),
        new("Description", "Описание модуля", ContentFieldType.TextArea, "Модуль"),
        new("ImageUrl", "Изображение модуля", ContentFieldType.Image, "Модуль"),
    };
    private static readonly ContentField[] lessonContentFields = new ContentField[]
    {
        new("Title", "Название урока", ContentFieldType.Text, "Урок"),
        new("Theory", "Теория", ContentFieldType.TextArea, "Урок"),
        new("Practice", "Практика 🧘", ContentFieldType.TextArea, "Урок"),
        new("Assignment", "Задание 📌", ContentFieldType.TextArea, "Урок"),
    };

    private Course model = new();
    private List<LiveEventDto> liveEvents = new();
    private bool loading;
    private bool saving;
    private bool savingModules;
    private string? error;

    protected override async Task OnInitializedAsync()
    {
        await LoadLiveEvents();

        if (!IsNew)
        {
            loading = true;
            try
            {
                var all = await Api.GetAllCoursesAsync();
                var found = all.FirstOrDefault(c => c.Id == Id);
                if (found != null) model = found;
                else error = "Курс не найден";
            }
            catch { error = "Ошибка загрузки"; }
            loading = false;
        }
    }

    private async Task LoadLiveEvents()
    {
        try
        {
            liveEvents = await Api.GetAllLiveEventsAsync();
        }
        catch
        {
            liveEvents = new();
        }
    }

    private async Task Save()
    {
        if (string.IsNullOrWhiteSpace(model.Slug)) { error = "Slug обязателен"; return; }
        saving = true;
        error = null;
        try
        {
            HttpResponseMessage response;
            if (IsNew) response = await Api.CreateCourseAsync(model);
            else response = await Api.UpdateCourseAsync(model.Id, model);

            if (response.IsSuccessStatusCode)
            {
                if (IsNew)
                {
                    var created = await response.Content.ReadFromJsonAsync<Course>();
                    if (created != null)
                        Nav.NavigateTo($"/admin/courses/{created.Id}/edit");
                    else
                        Nav.NavigateTo("/admin/courses");
                }
            }
            else error = $"Ошибка сервера: {response.StatusCode}";
        }
        catch (Exception ex) { error = $"Ошибка: {ex.Message}"; }
        saving = false;
    }

    private void AddModule()
    {
        var mod = new CourseModule
        {
            CourseId = model.Id,
            SortOrder = model.Modules.Count + 1
        };
        model.Modules.Add(mod);
    }

    private void RemoveModule(CourseModule mod) => model.Modules.Remove(mod);

    private void AddLesson(CourseModule mod)
    {
        var lesson = new CourseLesson
        {
            CourseModuleId = mod.Id,
            SortOrder = mod.Lessons.Count + 1
        };
        mod.Lessons.Add(lesson);
    }

    private void RemoveLesson(CourseModule mod, CourseLesson lesson) => mod.Lessons.Remove(lesson);

    private async Task SaveModules()
    {
        savingModules = true;
        error = null;
        try
        {
            var response = await Api.UpdateCourseAsync(model.Id, model);
            if (!response.IsSuccessStatusCode)
                error = $"Ошибка сохранения модулей: {response.StatusCode}";
        }
        catch (Exception ex) { error = $"Ошибка: {ex.Message}"; }
        savingModules = false;
    }

    private void Cancel() => Nav.NavigateTo("/admin/courses");

    private static string LiveEventLabel(LiveEventDto liveEvent) =>
        $"{liveEvent.StartsAt:dd.MM.yyyy HH:mm} — {liveEvent.Title}";
}
