@page "/admin/audit"
@layout Yoga.Client.Layout.AdminLayout
@inject Yoga.Client.Services.AdminApiService Api

<PageTitle>Аудит — Админ</PageTitle>

<div class="leads-page">
    <div class="page-header">
        <h1>Аудит действий</h1>
        @if (result != null)
        {
            <span class="total-count">Всего: @result.TotalCount</span>
        }
    </div>

    <div class="form-card" style="margin-bottom:1rem;">
        <div class="form-row">
            <div class="admin-form-group">
                <label>Действие</label>
                <select class="admin-input" @bind="actionFilter">
                    <option value="">Все</option>
                    @foreach (var action in actionOptions)
                    {
                        <option value="@action">@action</option>
                    }
                </select>
            </div>
            <div class="admin-form-group">
                <label>Сущность</label>
                <input class="admin-input" @bind="entityTypeFilter" placeholder="Lead, Customer, LiveEvent..." />
            </div>
            <div class="admin-form-group">
                <label>ID сущности</label>
                <input class="admin-input" @bind="entityIdInput" placeholder="GUID" />
            </div>
        </div>

        <div class="form-actions">
            <button class="btn-admin btn-admin-outline" @onclick="ResetFilters">Сбросить</button>
            <button class="btn-admin btn-admin-primary" @onclick="ApplyFilters">Применить</button>
        </div>
    </div>

    @if (loading)
    {
        <div class="admin-loading">Загрузка...</div>
    }
    else if (!string.IsNullOrWhiteSpace(error))
    {
        <div class="form-error">@error</div>
    }
    else if (result == null || result.Items.Count == 0)
    {
        <div class="admin-empty">Записи аудита не найдены</div>
    }
    else
    {
        <div class="admin-table-wrap">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Когда</th>
                        <th>Админ</th>
                        <th>Действие</th>
                        <th>Сущность</th>
                        <th>Описание</th>
                        <th>Источник</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var entry in result.Items)
                    {
                        <tr>
                            <td class="nowrap">@entry.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                            <td>@(string.IsNullOrWhiteSpace(entry.AdminIdentifier) ? "system" : entry.AdminIdentifier)</td>
                            <td><span class="badge badge-info">@entry.Action</span></td>
                            <td>
                                <div>@entry.EntityType</div>
                                @if (entry.EntityId.HasValue)
                                {
                                    <small class="admin-text-muted">@entry.EntityId</small>
                                }
                            </td>
                            <td>
                                <div>@entry.Summary</div>
                                @if (!string.IsNullOrWhiteSpace(entry.MetadataJson))
                                {
                                    <details style="margin-top:0.35rem;">
                                        <summary class="admin-text-muted" style="cursor:pointer;">metadata</summary>
                                        <pre style="white-space:pre-wrap; word-break:break-word; margin:0.5rem 0 0; font-size:0.78rem;">@entry.MetadataJson</pre>
                                    </details>
                                }
                            </td>
                            <td>
                                <div>@(string.IsNullOrWhiteSpace(entry.IpAddress) ? "-" : entry.IpAddress)</div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (totalPages > 1)
        {
            <div class="admin-pagination">
                <button class="btn-admin btn-admin-outline" disabled="@(page <= 1)" @onclick="() => GoToPage(page - 1)">←</button>
                @for (int i = 1; i <= totalPages; i++)
                {
                    var currentPage = i;
                    <button class="btn-admin @(currentPage == page ? "btn-admin-primary" : "btn-admin-outline")" @onclick="() => GoToPage(currentPage)">@currentPage</button>
                }
                <button class="btn-admin btn-admin-outline" disabled="@(page >= totalPages)" @onclick="() => GoToPage(page + 1)">→</button>
            </div>
        }
    }
</div>

@code {
    private static readonly string[] actionOptions =
    {
        "lead-processed-flag-updated",
        "lead-status-updated",
        "lead-notes-updated",
        "customer-created-from-lead",
        "access-granted-from-lead",
        "access-grant-created",
        "access-grant-revoked",
        "admin-user-created",
        "admin-user-deleted",
        "admin-password-changed",
        "PublicContentReset",
        "premium-resource-created",
        "premium-resource-updated",
        "premium-resource-deleted",
        "media-uploaded",
        "media-updated",
        "media-deleted",
        "live-event-created",
        "live-event-updated",
        "live-event-deleted"
    };

    private PaginatedResult<AdminAuditLogDto>? result;
    private bool loading = true;
    private string? error;
    private string actionFilter = string.Empty;
    private string entityTypeFilter = string.Empty;
    private string entityIdInput = string.Empty;
    private int page = 1;
    private const int PageSize = 50;
    private int totalPages => result == null ? 1 : (int)Math.Ceiling((double)result.TotalCount / PageSize);

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        loading = true;
        error = null;
        StateHasChanged();

        try
        {
            Guid? entityId = null;
            if (!string.IsNullOrWhiteSpace(entityIdInput))
            {
                if (!Guid.TryParse(entityIdInput, out var parsed))
                {
                    error = "ID сущности должен быть в формате GUID.";
                    result = null;
                    return;
                }

                entityId = parsed;
            }

            result = await Api.GetAuditLogsAsync(
                page,
                PageSize,
                string.IsNullOrWhiteSpace(actionFilter) ? null : actionFilter,
                string.IsNullOrWhiteSpace(entityTypeFilter) ? null : entityTypeFilter,
                entityId);
        }
        catch (Exception ex)
        {
            error = ex.Message;
            result = null;
        }
        finally
        {
            loading = false;
            StateHasChanged();
        }
    }

    private async Task ApplyFilters()
    {
        page = 1;
        await LoadData();
    }

    private async Task ResetFilters()
    {
        actionFilter = string.Empty;
        entityTypeFilter = string.Empty;
        entityIdInput = string.Empty;
        page = 1;
        await LoadData();
    }

    private async Task GoToPage(int newPage)
    {
        page = newPage;
        await LoadData();
    }
}