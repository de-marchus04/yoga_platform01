@page "/terms"
@inject LocalizationService Loc

<PageTitle>@Loc["terms.title"]</PageTitle>

<LegalDocument Eyebrow="Terms" Title="@Loc["terms.title"]" Intro="@Loc["terms.intro"]" EffectiveDate="@EffectiveDate" ContactLine="@Loc["terms.contact"]">
    <section class="legal-card">
        <h2>@Loc["terms.s1.title"]</h2>
        <p>@Loc["terms.s1.p1"]</p>
        <p>@Loc["terms.s1.p2"]</p>
    </section>

    <section class="legal-card">
        <h2>@Loc["terms.s2.title"]</h2>
        <p>@Loc["terms.s2.p1"]</p>
        <ul>
            <li>@Loc["terms.s2.li1"]</li>
            <li>@Loc["terms.s2.li2"]</li>
            <li>@Loc["terms.s2.li3"]</li>
        </ul>
    </section>

    <section class="legal-card">
        <h2>@Loc["terms.s3.title"]</h2>
        <p>@Loc["terms.s3.p1"]</p>
        <p><span class="legal-accent">@Loc["terms.s3.p2"]</span></p>
    </section>

    <section class="legal-card">
        <h2>@Loc["terms.s4.title"]</h2>
        <p>@Loc["terms.s4.p1"]</p>
        <ul>
            <li>@Loc["terms.s4.li1"]</li>
            <li>@Loc["terms.s4.li2"]</li>
            <li>@Loc["terms.s4.li3"]</li>
        </ul>
    </section>

    <section class="legal-card">
        <h2>@Loc["terms.s5.title"]</h2>
        <p>@Loc["terms.s5.p1"]</p>
        <p>@Loc["terms.s5.p2"]</p>
    </section>

    <section class="legal-card">
        <h2>@Loc["terms.s6.title"]</h2>
        <p>@Loc["terms.s6.p1"]</p>
    </section>
</LegalDocument>

@code {
    private static readonly DateOnly EffectiveDate = new(2026, 3, 18);
}