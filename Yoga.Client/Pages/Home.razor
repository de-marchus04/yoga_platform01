            </a>
            <a href="/blog/articles" class="blog-card reveal reveal-d1">
                <span class="blog-tag">@Loc["page.home.blog.2.tag"]</span>
                <h3>@Loc["page.home.blog.2.h3"]</h3>
                <p>@Loc["page.home.blog.2.text"]</p>
                <span class="blog-read-more">@Loc["page.home.blog.readmore"]</span>
            </a>
            <a href="/blog/articles" class="blog-card reveal reveal-d2">
                <span class="blog-tag">@Loc["page.home.blog.3.tag"]</span>
                <h3>@Loc["page.home.blog.3.h3"]</h3>
