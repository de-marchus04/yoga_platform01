            <div class="section-divider"></div>
        </div>
        <div class="directions-grid">
            <a href="/courses" class="direction-block reveal">
                <div class="direction-number">@Loc["page.home.directions.01"]</div>
                <h3>@F("Dir1Title", Loc["page.home.directions.01.h3"])</h3>
                <p>@F("Dir1Text", Loc["page.home.directions.01.text"])</p>
                <span class="direction-link">@F("Dir1LinkText", Loc["page.home.directions.01.link"])</span>
            </a>
            <a href="/consultations" class="direction-block reveal reveal-d1">
                <div class="direction-number">@Loc["page.home.directions.02"]</div>
                <h3>@F("Dir2Title", Loc["page.home.directions.02.h3"])</h3>
                <p>@F("Dir2Text", Loc["page.home.directions.02.text"])</p>
                <span class="direction-link">@F("Dir2LinkText", Loc["page.home.directions.02.link"])</span>
            </a>
            <a href="/retreats/actual" class="direction-block reveal reveal-d2">
                <div class="direction-number">@Loc["page.home.directions.03"]</div>
                <h3>@F("Dir3Title", Loc["page.home.directions.03.h3"])</h3>
                <p>@F("Dir3Text", Loc["page.home.directions.03.text"])</p>
                <span class="direction-link">@F("Dir3LinkText", Loc["page.home.directions.03.link"])</span>
            </a>
        </div>
    </div>
</section>

<section class="quote-section">
    <div class="container">
        <blockquote class="philosophy-quote reveal">
            <p>@((MarkupString)F("QuoteText", $"{Loc["page.home.quote.line1"]}<br/>{Loc["page.home.quote.line2"]}"))</p>
            <footer>@F("QuoteAuthor", Loc["page.home.quote.by"])</footer>
        </blockquote>
    </div>
</section>

<section class="formats-section">
    <div class="format-block format-online reveal">
        <div class="format-content">
            <p class="section-eyebrow">@Loc["page.home.formats.eyebrow1"]</p>
            <h2>@F("Format1Title", Loc["page.home.formats.h2.1"])</h2>
            <div class="section-divider" style="margin:2rem 0;"></div>
            <p>@F("Format1Text", Loc["page.home.formats.text1"])</p>
            <a href="/courses" class="btn btn-outline">@F("Format1Cta", Loc["page.home.formats.cta1"])</a>
        </div>
    </div>
    <div class="format-block format-offline reveal reveal-d1">
        <div class="format-content">
            <p class="section-eyebrow">@Loc["page.home.formats.eyebrow2"]</p>
            <h2>@F("Format2Title", Loc["page.home.formats.h2.2"])</h2>
            <div class="section-divider" style="margin:2rem 0;"></div>
