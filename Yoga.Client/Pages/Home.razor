<section class="cta-section">
    <div class="cta-overlay reveal">
        <p class="section-eyebrow" style="color:rgba(255,255,255,0.45);">@Loc["page.home.cta.eyebrow"]</p>
        <h2>@Loc["page.home.cta.h2"]</h2>
