@page "/"
@inject Yoga.Client.Services.ApiService ApiService
@inject LocalizationService Loc
@implements IDisposable

<PageTitle>@(F("MetaTitle", Loc["page.home.title"]))</PageTitle>

<HeadContent>
    <meta name="description" content="@(F("MetaDescription", "Эксклюзивные авторские ретриты и программы обучения. Погружение в тишину и возврат к себе."))" />
    <meta property="og:title" content="@(F("MetaTitle", "shakti.ashram | Премиальные Ретриты"))" />
    <meta property="og:description" content="@(F("MetaDescription", "Бутиковые туры и практики осознанности. Забронируйте свое место."))" />
    <meta property="og:image" content="https://www.medisha.space/img/og-preview.jpg" />
    <meta property="og:type" content="website" />
</HeadContent>

<section class="hero">
    <div class="hero-text">
        <p class="hero-eyebrow">@(F("HeroEyebrow", "SHAKTI.ASHRAM"))</p>
        <h1>@(F("HeroTitle", Loc["page.home.hero.h1.line1"]))<br/><em>@(F("HeroSubtitle", Loc["page.home.hero.h1.em"]))</em></h1>
        <div class="hero-gold-line"></div>
        <p>@(F("HeroText", Loc["page.home.hero.text"]))</p>
        <button class="btn btn-primary" style="align-self:flex-start" @onclick="OpenLeadModal">@Loc["page.home.hero.cta"]</button>
    </div>
    <div class="hero-photo">
        <img src="@(F("HeroImage", "https://images.unsplash.com/photo-1544367567-0f2fcb009e0b?auto=format&fit=crop&w=1400&q=80"))" alt="Йога ретрит" width="1400" height="934" fetchpriority="high" decoding="async" />
    </div>
</section>

@if (!string.IsNullOrEmpty(F("Content")))
{
    <section class="story-section">
        <div class="container">
            @((MarkupString)F("Content"))
        </div>
    </section>
}

<section class="stats-section">
    <div class="container stats-grid">
        <div class="stat-item reveal">
            <span class="stat-number">@F("Stats1Value", "12+")</span>
            <span class="stat-label">@F("Stats1Label", Loc["page.home.stats.retreats"])</span>
        </div>
        <div class="stat-item reveal reveal-d1">
            <span class="stat-number">@F("Stats2Value", "300+")</span>
            <span class="stat-label">@F("Stats2Label", Loc["page.home.stats.members"])</span>
        </div>
        <div class="stat-item reveal reveal-d2">
            <span class="stat-number">@F("Stats3Value", "5")</span>
            <span class="stat-label">@F("Stats3Label", Loc["page.home.stats.countries"])</span>
        </div>
        <div class="stat-item reveal reveal-d3">
            <span class="stat-number">@F("Stats4Value", "8")</span>
            <span class="stat-label">@F("Stats4Label", Loc["page.home.stats.years"])</span>
        </div>
    </div>
</section>

<section class="retreats-section" id="retreats">
    <div class="container">
        <div class="section-header reveal">
            <p class="section-eyebrow">@Loc["page.home.retreats.eyebrow"]</p>
            <h2>@Loc["page.home.retreats.h2"]</h2>
            <div class="section-divider"></div>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="error-text">
                <strong>Данные временно недоступны:</strong> @errorMessage
            </div>
        }

        @if (retreats == null)
        {
            <div class="retreat-showcase reveal">
                <div class="retreat-photo skeleton" style="min-height:400px;"></div>
                <div class="retreat-info">
                    <div class="skeleton skeleton-text" style="width:30%; margin-bottom:1rem;"></div>
                    <div class="skeleton skeleton-title" style="margin-bottom:1.5rem;"></div>
                    <div class="skeleton skeleton-text" style="width:80%; margin-bottom:0.6rem;"></div>
                    <div class="skeleton skeleton-text" style="width:60%; margin-bottom:2rem;"></div>
                    <div class="skeleton skeleton-text" style="height:3rem; width:50%;"></div>
                </div>
            </div>
        }
        else if (!retreats.Any() && string.IsNullOrEmpty(errorMessage))
        {
            <div style="text-align:center;color:var(--text-muted);max-width:760px;margin:0 auto;">
                <p style="margin-bottom:1rem;">Раздел ретритов очищен и готов к новому наполнению.</p>
                <p>Сюда нужно добавить активные программы с названием, локацией, датами, кратким описанием результата, ключевым визуалом и CTA для отправки заявки.</p>
            </div>
        }
        else
        {
            int ri = 0;
            foreach (var retreat in retreats)
            {
                ri++;
                var imgUrl = !string.IsNullOrEmpty(retreat.ImageUrl)
                    ? ApiService.ResolveMediaUrl(retreat.ImageUrl)
                    : "https://images.unsplash.com/photo-1545205597-3d9d02c29597?auto=format&fit=crop&w=1200&q=80";
                <div class="retreat-showcase @(ri % 2 == 0 ? "retreat-showcase--reversed" : "") reveal">
                    <div class="retreat-photo">
                        <img src="@imgUrl" alt="@retreat.Title" loading="lazy" />
                    </div>
                    <div class="retreat-info">
                        <p class="retreat-location">@retreat.Location</p>
                        <p class="retreat-dates">@retreat.StartDate.ToString("dd MMM yyyy") — @retreat.EndDate.ToString("dd MMM yyyy")</p>
                        <h3>@retreat.Title</h3>
                        <div class="retreat-divider"></div>
                        <p class="retreat-description">@retreat.Description</p>
                        @if (!string.IsNullOrEmpty(retreat.PriceLabel))
                        {
                            <p class="retreat-price">@retreat.PriceLabel</p>
                        }
                        <button class="btn btn-outline" @onclick="() => OpenLeadModalForRetreat(retreat)">@Loc["page.home.retreats.cta"]</button>
                    </div>
                </div>
            }
        }
    </div>
</section>

