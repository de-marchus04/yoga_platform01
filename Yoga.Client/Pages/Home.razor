@page "/"
@inject Yoga.Client.Services.ApiService ApiService
@inject LocalizationService Loc
@implements IDisposable

<PageTitle>@(F("MetaTitle", Loc["page.home.title"]))</PageTitle>

<HeadContent>
    <meta name="description" content="@(F("MetaDescription", "Эксклюзивные авторские ретриты и программы обучения. Погружение в тишину и возврат к себе."))" />
    <meta property="og:title" content="@(F("MetaTitle", "shakti.ashram | Премиальные Ретриты"))" />
    <meta property="og:description" content="@(F("MetaDescription", "Бутиковые туры и практики осознанности. Забронируйте свое место."))" />
    <meta property="og:image" content="https://www.medisha.space/img/og-preview.jpg" />
    <meta property="og:type" content="website" />
</HeadContent>

<section class="hero">
    <div class="hero-text">
        <p class="hero-eyebrow">@(F("HeroEyebrow", "SHAKTI.ASHRAM"))</p>
        <h1>@(F("HeroTitle", Loc["page.home.hero.h1.line1"]))<br/><em>@(F("HeroSubtitle", Loc["page.home.hero.h1.em"]))</em></h1>
        <div class="hero-gold-line"></div>
        <p>@(F("HeroText", Loc["page.home.hero.text"]))</p>
        <button class="btn btn-primary" style="align-self:flex-start" @onclick="OpenLeadModal">@Loc["page.home.hero.cta"]</button>
    </div>
    <div class="hero-photo">
        <img src="@(F("HeroImage", "https://images.unsplash.com/photo-1544367567-0f2fcb009e0b?auto=format&fit=crop&w=1400&q=80"))" alt="Йога ретрит" width="1400" height="934" fetchpriority="high" decoding="async" />
    </div>
</section>

@if (!string.IsNullOrEmpty(F("Content")))
{
    <section class="story-section">
        <div class="container">
            @((MarkupString)F("Content"))
        </div>
    </section>
}

<section class="stats-section">
    <div class="container stats-grid">
        <div class="stat-item reveal">
            <span class="stat-number">@F("Stats1Value", "12+")</span>
            <span class="stat-label">@F("Stats1Label", Loc["page.home.stats.retreats"])</span>
        </div>
        <div class="stat-item reveal reveal-d1">
            <span class="stat-number">@F("Stats2Value", "300+")</span>
            <span class="stat-label">@F("Stats2Label", Loc["page.home.stats.members"])</span>
        </div>
        <div class="stat-item reveal reveal-d2">
            <span class="stat-number">@F("Stats3Value", "5")</span>
            <span class="stat-label">@F("Stats3Label", Loc["page.home.stats.countries"])</span>
        </div>
        <div class="stat-item reveal reveal-d3">
            <span class="stat-number">@F("Stats4Value", "8")</span>
            <span class="stat-label">@F("Stats4Label", Loc["page.home.stats.years"])</span>
        </div>
    </div>
</section>

<section class="directions-section">
    <div class="container">
        <div class="section-header reveal">
            <p class="section-eyebrow">@Loc["page.home.directions.eyebrow"]</p>
            <h2>@Loc["page.home.directions.h2"]</h2>
            <div class="section-divider"></div>
        </div>
        <div class="directions-grid">
            <a href="/courses" class="direction-block reveal">
                <div class="direction-number">@Loc["page.home.directions.01"]</div>
                <h3>@F("Dir1Title", Loc["page.home.directions.01.h3"])</h3>
                <p>@F("Dir1Text", Loc["page.home.directions.01.text"])</p>
                <span class="direction-link">@F("Dir1LinkText", Loc["page.home.directions.01.link"])</span>
            </a>
            <a href="/consultations" class="direction-block reveal reveal-d1">
                <div class="direction-number">@Loc["page.home.directions.02"]</div>
                <h3>@F("Dir2Title", Loc["page.home.directions.02.h3"])</h3>
                <p>@F("Dir2Text", Loc["page.home.directions.02.text"])</p>
                <span class="direction-link">@F("Dir2LinkText", Loc["page.home.directions.02.link"])</span>
            </a>
            <a href="/consultations" class="direction-block reveal reveal-d2">
                <div class="direction-number">@Loc["page.home.directions.03"]</div>
                <h3>@F("Dir3Title", Loc["page.home.directions.03.h3"])</h3>
                <p>@F("Dir3Text", Loc["page.home.directions.03.text"])</p>
                <span class="direction-link">@F("Dir3LinkText", Loc["page.home.directions.03.link"])</span>
            </a>
        </div>
    </div>
</section>

<section class="quote-section">
    <div class="container">
        <blockquote class="philosophy-quote reveal">
            <p>@((MarkupString)F("QuoteText", $"{Loc["page.home.quote.line1"]}<br/>{Loc["page.home.quote.line2"]}"))</p>
            <footer>@F("QuoteAuthor", Loc["page.home.quote.by"])</footer>
        </blockquote>
    </div>
</section>

<section class="formats-section">
    <div class="format-block format-online reveal">
        <div class="format-content">
            <p class="section-eyebrow">@Loc["page.home.formats.eyebrow1"]</p>
            <h2>@F("Format1Title", Loc["page.home.formats.h2.1"])</h2>
            <div class="section-divider" style="margin:2rem 0;"></div>
            <p>@F("Format1Text", Loc["page.home.formats.text1"])</p>
            <a href="/courses" class="btn btn-outline">@F("Format1Cta", Loc["page.home.formats.cta1"])</a>
        </div>
    </div>
    <div class="format-block format-offline reveal reveal-d1">
        <div class="format-content">
            <p class="section-eyebrow">@Loc["page.home.formats.eyebrow2"]</p>
            <h2>@F("Format2Title", Loc["page.home.formats.h2.2"])</h2>
            <div class="section-divider" style="margin:2rem 0;"></div>
            <p>@F("Format2Text", Loc["page.home.formats.text2"])</p>
            <a href="/consultations" class="btn btn-outline">@F("Format2Cta", Loc["page.home.formats.cta2"])</a>
        </div>
    </div>
</section>

<section class="reviews-section">
    <div class="container">
        <div class="section-header reveal">
            <p class="section-eyebrow">@Loc["page.home.reviews.eyebrow"]</p>
            <h2>@Loc["page.home.reviews.h2"]</h2>
            <div class="section-divider"></div>
        </div>
        <div class="reviews-grid">
            <div class="review-card reveal">
                <p class="review-quote">@F("Review1Quote", Loc["page.home.reviews.1.quote"])</p>
                <div class="review-author">
                    <span class="review-name">@F("Review1Author", Loc["page.home.reviews.1.name"])</span>
                    <span class="review-program">@F("Review1Program", Loc["page.home.reviews.1.program"])</span>
                </div>
            </div>
            <div class="review-card reveal reveal-d1">
                <p class="review-quote">@F("Review2Quote", Loc["page.home.reviews.2.quote"])</p>
                <div class="review-author">
                    <span class="review-name">@F("Review2Author", Loc["page.home.reviews.2.name"])</span>
                    <span class="review-program">@F("Review2Program", Loc["page.home.reviews.2.program"])</span>
                </div>
            </div>
            <div class="review-card reveal reveal-d2">
                <p class="review-quote">@F("Review3Quote", Loc["page.home.reviews.3.quote"])</p>
                <div class="review-author">
                    <span class="review-name">@F("Review3Author", Loc["page.home.reviews.3.name"])</span>
                    <span class="review-program">@F("Review3Program", Loc["page.home.reviews.3.program"])</span>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="cta-section">
    <div class="cta-overlay reveal">
        <p class="section-eyebrow" style="color:rgba(255,255,255,0.45);">@Loc["page.home.cta.eyebrow"]</p>
        <h2>@Loc["page.home.cta.h2"]</h2>
        <p>@Loc["page.home.cta.text"]</p>
        <button class="btn btn-primary" @onclick="OpenLeadModal">@Loc["page.home.cta.btn"]</button>
    </div>
</section>

@code {
    private Yoga.Shared.DTOs.SitePageDto? pageData;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        try
        {
            pageData = await ApiService.GetSitePageAsync("home", Loc.CurrentLang);
        }
        catch { }
    }

    private string F(string field, string fallback = "")
    {
        var val = pageData?.Fields != null && pageData.Fields.TryGetValue(field, out var v) && !string.IsNullOrWhiteSpace(v) ? v.Trim() : fallback;
        return field.Contains("Image", StringComparison.OrdinalIgnoreCase) ? ApiService.ResolveMediaUrl(val) : val;
    }

    private void OpenLeadModal()
    {
        ModalService.Show<LeadModal>();
    }

    protected override void OnInitialized()
    {
        Loc.OnLanguageChanged += Refresh;
    }

    private async void Refresh()
    {
        await LoadDataAsync();
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Loc.OnLanguageChanged -= Refresh;
    }
}
