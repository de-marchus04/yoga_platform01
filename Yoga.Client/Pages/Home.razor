        <button class="btn btn-primary" @onclick="OpenLeadModal">@Loc["page.home.cta.btn"]</button>
    </div>
</section>

@code {
    private List<Yoga.Shared.DTOs.RetreatDto>? retreats;
    private string? errorMessage;
    private Yoga.Shared.DTOs.SitePageDto? pageData;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        try
        {
            retreats = await CatalogState.GetActiveRetreatsAsync(Loc.CurrentLang);
            errorMessage = null;
        }
        catch (Exception ex)
        {
            errorMessage = "Публичный сайт не смог получить данные из API. Укажите абсолютный production API URL для внешнего frontend-hosting и проверьте CORS/SSL на backend.";
            Console.WriteLine(ex.Message);
            retreats = new List<Yoga.Shared.DTOs.RetreatDto>();
        }

        try
        {
            pageData = await ApiService.GetSitePageAsync("home", Loc.CurrentLang);
        }
        catch { }
    }

    private string F(string field, string fallback = "")
    {
        var val = pageData?.Fields != null && pageData.Fields.TryGetValue(field, out var v) && !string.IsNullOrWhiteSpace(v) ? v.Trim() : fallback;
        return field.Contains("Image", StringComparison.OrdinalIgnoreCase) ? ApiService.ResolveMediaUrl(val) : val;
    }

    private void OpenLeadModal()
    {
        ModalService.Show<LeadModal>();
    }

    private void OpenLeadModalForRetreat(Yoga.Shared.DTOs.RetreatDto retreat)
    {
        ModalService.Show<LeadModal>(new Dictionary<string, object>
        {
            { "ContextTitle", retreat.Title },
            { "TargetRetreatId", retreat.Id }
        });
    }


    protected override void OnInitialized()
    {
        Loc.OnLanguageChanged += Refresh;
    }

    private async void Refresh()
    {
        await LoadDataAsync();
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Loc.OnLanguageChanged -= Refresh;
    }
}
