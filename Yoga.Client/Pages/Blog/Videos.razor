@page "/blog/videos"
@inject LocalizationService Loc
@inject ApiService Api
@implements IDisposable

<PageTitle>@Loc["page.blog.videos.title"]</PageTitle>

<section class="page-hero">
    <div class="page-hero-bg" style="background-image: url('https://images.unsplash.com/photo-1611162616475-46b635cb6868?auto=format&fit=crop&w=1600&q=80');"></div>
    <div class="page-hero-overlay"></div>
    <div class="container page-hero-content">
        <p class="section-eyebrow" style="color:var(--accent);">@Loc["page.blog.videos.eyebrow"]</p>
        <h1>@Loc["page.blog.videos.h1"]</h1>
        <div class="section-divider" style="margin:2rem 0;"></div>
        <p>@Loc["page.blog.videos.intro"]</p>
    </div>
</section>

<section style="padding:8rem 0;">
    <div class="container">
        @if (loading)
        {
            <div style="text-align:center;padding:4rem 0;opacity:0.5;">...</div>
        }
        else if (!posts.Any())
        {
            <div style="text-align:center;padding:4rem 0;color:var(--text-muted);">Видео появится совсем скоро</div>
        }
        else
        {
            <div class="section-filter-bar">
                <button class="filter-tab @(activeSection == "" ? "active" : "")" @onclick="() => SetSection(string.Empty)">Все</button>
                @foreach (var sec in SectionDefs)
                {
                    var s = sec;
                    <button class="filter-tab @(activeSection == s.Key ? "active" : "")" @onclick="() => SetSection(s.Key)">@s.Name</button>
                }
            </div>

            @foreach (var sec in VisibleSections)
            {
                var secPosts = GetPostsForSection(sec.Key);
                @if (secPosts.Any())
                {
                    <div class="section-group">
                        <div class="section-group-header">
                            <span class="section-group-title">@sec.Name</span>
                            <div class="section-group-tags">
                                @foreach (var link in sec.Links)
                                {
                                    <a href="@link.Url" class="section-tag-link">@link.Label</a>
                                }
                            </div>
                        </div>
                        <div class="video-grid" style="margin-top:2rem;">
                            @foreach (var post in secPosts.Take(6))
                            {
                                var p = post;
                                <a href="/blog/@p.Slug" class="video-card reveal">
                                    <div class="video-card-thumb">
                                        <img src="@GetThumbnail(p.MediaUrl)" alt="@p.Title" loading="lazy" />
                                        <div class="video-card-play"></div>
                                    </div>
                                    <div class="video-card-body">
                                        @if (!string.IsNullOrEmpty(p.Tag))
                                        {
                                            <span class="video-tag">@p.Tag</span>
                                        }
                                        <h3>@p.Title</h3>
                                        @if (!string.IsNullOrEmpty(p.Excerpt))
                                        {
                                            <span class="video-duration">@p.Excerpt</span>
                                        }
                                    </div>
                                </a>
                            }
                        </div>
                    </div>
                }
            }
        }
    </div>
</section>

@code {
    private record SecDef(string Key, string Name, List<(string Label, string Url)> Links);

    private static readonly List<SecDef> SectionDefs = new()
    {
        new("courses", "Курсы", new() {
            ("Пранаяма", "/courses/pranayama"),
            ("Медитация", "/courses/meditation"),
            ("Йога", "/courses/yoga")
        }),
        new("consultations", "Консультации", new() {
            ("Энергетика", "/consultations/energy"),
            ("Аюрведа", "/consultations/ayurveda"),
            ("Духовность", "/consultations/spirituality")
        }),
        new("retreats", "Ретриты", new() {
            ("Актуальные", "/retreats/actual"),
            ("Предстоящие", "/retreats/upcoming"),
            ("Прошедшие", "/retreats/past")
        }),
    };

    private List<BlogPostDto> posts = new();
    private bool loading = true;
    private string activeSection = "";

    private IEnumerable<SecDef> VisibleSections =>
        string.IsNullOrEmpty(activeSection) ? SectionDefs : SectionDefs.Where(s => s.Key == activeSection);

    private List<BlogPostDto> GetPostsForSection(string key) =>
        posts.Where(p => p.Sections.Any(s => s.Equals(key, StringComparison.OrdinalIgnoreCase))).ToList();

    private static string GetThumbnail(string? url)
    {
        if (string.IsNullOrEmpty(url))
            return "https://images.unsplash.com/photo-1611162616475-46b635cb6868?auto=format&fit=crop&w=800&q=80";
        if (url.Contains("youtube.com/watch?v="))
        {
            var id = url.Split("v=")[1].Split('&')[0];
            return $"https://img.youtube.com/vi/{id}/hqdefault.jpg";
        }
        if (url.Contains("youtu.be/"))
        {
            var id = url.Split("youtu.be/")[1].Split('?')[0];
            return $"https://img.youtube.com/vi/{id}/hqdefault.jpg";
        }
        return url;
    }

    protected override async Task OnInitializedAsync()
    {
        Loc.OnLanguageChanged += OnLangChanged;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        loading = true;
        StateHasChanged();
        posts = await Api.GetBlogPostsAsync(Loc.CurrentLang, "videos") ?? new();
        activeSection = "";
        loading = false;
    }

    private void SetSection(string s) { activeSection = s; }

    private void OnLangChanged() => InvokeAsync(async () => { await LoadAsync(); StateHasChanged(); });
    public void Dispose() => Loc.OnLanguageChanged -= OnLangChanged;
}
