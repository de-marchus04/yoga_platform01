@page "/blog/photos"
@inject LocalizationService Loc
@inject ApiService Api
@implements IDisposable

<PageTitle>@Loc["page.blog.photos.title"]</PageTitle>

<section class="page-hero">
    <div class="page-hero-bg" style="background-image: url('https://images.unsplash.com/photo-1506905925346-21bda4d32df4?auto=format&fit=crop&w=1600&q=80');"></div>
    <div class="page-hero-overlay"></div>
    <div class="container page-hero-content">
        <p class="section-eyebrow">@Loc["page.blog.photos.eyebrow"]</p>
        <h1>@Loc["page.blog.photos.h1"]</h1>
        <div class="section-divider" style="margin:2rem 0;"></div>
        <p>@Loc["page.blog.photos.intro"]</p>
    </div>
</section>

@if (loading)
{
    <div class="public-loading-state">Загружаем фотографии</div>
}
else
{
    <div class="section-filter-bar" style="max-width:1200px;margin:0 auto 3rem;padding:0 2rem;">
        <button class="filter-tab @(activeSection == "" ? "active" : "")" @onclick="() => SetSection(string.Empty)">Все</button>
        @foreach (var sec in SectionDefs)
        {
            var fs = sec;
            <button class="filter-tab @(activeSection == fs.Key ? "active" : "")" @onclick="() => SetSection(fs.Key)">@fs.Name</button>
        }
    </div>

    @if (!posts.Any())
    {
        <div style="text-align:center;padding:8rem 0;color:var(--text-muted);max-width:760px;margin:0 auto;">
            <p style="margin-bottom:1rem;">Фотогалерея очищена и ждёт новые визуальные материалы.</p>
            <p>Сюда нужно добавить фото по курсам, консультациям и ретритам, чтобы пользователь видел атмосферу, формат работы и реальный визуальный стиль проекта.</p>
        </div>
    }
    else
    {
    @foreach (var sec in SectionDefs.Where(s => string.IsNullOrEmpty(activeSection) || s.Key == activeSection))
    {
        var secPosts = posts.Where(p => p.Sections.Any(s => s.Equals(sec.Key, StringComparison.OrdinalIgnoreCase))).ToList();
        var s = sec;
        @if (secPosts.Any())
        {
            <div class="photo-section-block @(s.Reverse ? "reverse" : "")">
                <div class="container">
                    <div class="photo-section-header reveal">
                        <div>
                            <p class="section-eyebrow">@s.Eyebrow</p>
                            <h2>@s.Title</h2>
                        </div>
                        <a href="@s.IndexUrl" class="btn btn-outline">@Loc["section.back_to_list"] →</a>
                    </div>
                    <div class="photo-mosaic">
                        @foreach (var (post, pi) in secPosts.Take(4).Select((p, i) => (p, i)))
                        {
                            var photoPost = post;
                            <div class="photo-mosaic-item @(pi == 0 ? "featured" : "") reveal">
                                <img src="@(photoPost.MediaUrl != null ? Api.ResolveMediaUrl(photoPost.MediaUrl) : "https://images.unsplash.com/photo-1506905925346-21bda4d32df4?auto=format&fit=crop&w=900&q=80")"
                                     alt="@photoPost.Title" loading="lazy" />
                                <a href="/blog/@photoPost.Slug" class="photo-mosaic-label">
                                    <span>@s.Name</span>
                                    <strong>@photoPost.Title</strong>
                                </a>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    }
    }
}

@code {
    private record SecDef(string Key, string Name, string Eyebrow, string Title, string IndexUrl, bool Reverse);
    private string activeSection = "";
    private void SetSection(string s) { activeSection = s; }

    private static readonly List<SecDef> SectionDefs = new()
    {
        new("courses",       "Курсы",        "Направления обучения", "Авторские программы",   "/courses",       false),
        new("consultations", "Консультации", "Индивидуальная работа",    "Глубокое погружение",   "/consultations", true),
        new("retreats",      "Ретриты",      "Сакральные места силы", "Жизнь в практике",         "/retreats",      false),
        new("yagyas",        "Ягьи",         "Ведические церемонии", "Сила огня и мантр",       "/yagyas",        true),
    };

    private List<BlogPostDto> posts = new();
    private bool loading = true;

    protected override async Task OnInitializedAsync()
    {
        Loc.OnLanguageChanged += OnLangChanged;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        loading = true;
        StateHasChanged();
        posts = await Api.GetBlogPostsAsync(Loc.CurrentLang, "photos") ?? new();
        loading = false;
    }

    private void OnLangChanged() => InvokeAsync(async () => { await LoadAsync(); StateHasChanged(); });
    public void Dispose() => Loc.OnLanguageChanged -= OnLangChanged;
}
