@page "/courses"
@inject LocalizationService Loc
@inject ApiService Api
@implements IDisposable

<PageTitle>@Loc["page.courses.title"]</PageTitle>

<div class="arc-library">
    @* ── Hero: editorial cover ── *@
    <section class="arc-library__hero">
        <div class="container arc-library__hero-grid">
            <div class="arc-library__hero-text">
                <p class="section-eyebrow">@F("Eyebrow", Loc["page.courses.eyebrow"])</p>
                <h1>@F("H1", Loc["page.courses.h1"])</h1>
                <div class="section-divider"></div>
                <p class="arc-library__curator-note">@F("Intro", Loc["page.courses.intro"])</p>
            </div>
            <div class="arc-library__accent" aria-hidden="true">
                <span class="arc-library__accent-dot"></span>
                <span class="arc-library__accent-dot"></span>
                <span class="arc-library__accent-dot"></span>
            </div>
        </div>
    </section>

    @* ── Catalog: library shelf ── *@
    <section class="arc-library__catalog">
        <div class="container">
            @if (loading)
            {
                <div class="public-loading-state">@Loc["common.loading"]</div>
            }
            else if (!courses.Any())
            {
                <p class="arc-library__empty">@Loc["page.courses.sub"]</p>
            }
            else
            {
                <div class="arc-library__shelf">
                    @foreach (var (c, i) in courses.Select((x, idx) => (x, idx)))
                    {
                        var course = c;
                        var num = (i + 1).ToString("D2");
                        <a class="arc-library__card @(i % 2 == 0 ? "arc-library__card--wide" : "")" href="/courses/@CanonicalCourseSlug(course.Slug)">
                            <div class="arc-library__card-photo">
                                <img src="@(!string.IsNullOrEmpty(course.ImageUrl) ? Api.ResolveMediaUrl(course.ImageUrl) : "https://images.unsplash.com/photo-1506126279646-a697353d3166?auto=format&fit=crop&w=800&q=80")" alt="@DisplayCourseTitle(course)" loading="lazy" />
                            </div>
                            <div class="arc-library__card-body">
                                <span class="arc-library__card-num">@num</span>
                                @if (!string.IsNullOrEmpty(course.Eyebrow))
                                {
                                    <span class="arc-library__card-eyebrow">@course.Eyebrow</span>
                                }
                                <h3>@DisplayCourseTitle(course)</h3>
                                <p class="arc-library__card-desc">@course.Subtitle</p>
                                <div class="arc-library__card-meta">
                                    @if (!string.IsNullOrEmpty(course.Level))
                                    {
                                        <span>@Loc["meta.level"]: @course.Level</span>
                                    }
                                    @if (!string.IsNullOrEmpty(course.Duration))
                                    {
                                        <span>@Loc["meta.duration"]: @course.Duration</span>
                                    }
                                    @if (!string.IsNullOrEmpty(course.Format))
                                    {
                                        <span>@Loc["meta.format"]: @course.Format</span>
                                    }
                                </div>
                                <span class="arc-library__card-cta">@F("CardCta", Loc["page.courses.card.cta"])</span>
                            </div>
                        </a>
                    }
                </div>
            }
        </div>
    </section>
</div>

@code {
    private List<CourseDto> courses = new();
    private bool loading = true;
    private SitePageDto? pageData;

    protected override async Task OnInitializedAsync()
    {
        Loc.OnLanguageChanged += OnLangChanged;
        await Task.WhenAll(LoadAsync(), LoadPage());
    }

    private async Task LoadPage()
    {
        try { pageData = await Api.GetSitePageAsync("courses", Loc.CurrentLang); }
        catch { pageData = null; }
    }

    private string F(string field, string fallback = "")
    {
        var val = pageData?.Fields != null && pageData.Fields.TryGetValue(field, out var v) && !string.IsNullOrEmpty(v) ? v : fallback;
        return field.Contains("Image", StringComparison.OrdinalIgnoreCase) ? Api.ResolveMediaUrl(val) : val;
    }

    private static string CanonicalCourseSlug(string slug) => slug switch
    {
        "pranayama" => "pranavidya",
        _ => slug
    };

    private string DisplayCourseTitle(CourseDto course) => CanonicalCourseSlug(course.Slug) switch
    {
        "pranavidya" => Loc.CurrentLang switch
        {
            "en" => "Pranavidya",
            "uk" => "Пранавід'я",
            _ => "Пранавидья"
        },
        _ => course.Title
    };

    private async Task LoadAsync()
    {
        loading = true;
        StateHasChanged();
        courses = await CatalogState.GetCoursesAsync(Loc.CurrentLang) ?? new();
        loading = false;
    }

    private void OnLangChanged() => InvokeAsync(async () => { await Task.WhenAll(LoadAsync(), LoadPage()); StateHasChanged(); });
    public void Dispose() => Loc.OnLanguageChanged -= OnLangChanged;
}
