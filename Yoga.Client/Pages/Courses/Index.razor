@page "/courses"
@inject LocalizationService Loc
@inject ApiService Api
@implements IDisposable

<PageTitle>@Loc["page.courses.title"]</PageTitle>

<section class="page-hero">
    <div class="page-hero-bg" style="background-image: url('@F("HeroImageUrl", "https://images.unsplash.com/photo-1506126279646-a697353d3166?auto=format&fit=crop&w=1600&q=80")');" ></div>
    <div class="page-hero-overlay"></div>
    <div class="container page-hero-content">
        <p class="section-eyebrow" style="color:var(--accent);">@F("Eyebrow", Loc["page.courses.eyebrow"])</p>
        <h1>@F("H1", Loc["page.courses.h1"])</h1>
        <div class="section-divider" style="margin:2rem 0;"></div>
        <p>@F("Intro", Loc["page.courses.intro"])</p>
    </div>
</section>

<section class="course-cards-section">
    <div class="container">
        <div class="section-header reveal">
            <p class="section-eyebrow">@F("Eyebrow", Loc["page.courses.eyebrow"])</p>
            <h2>@F("H2", Loc["page.courses.h2"])</h2>
            <div class="section-divider"></div>
        </div>
        @if (loading)
        {
            <div class="public-loading-state">Загружаем программы</div>
        }
        else if (!courses.Any())
        {
            <div style="text-align:center;padding:4rem 0;color:var(--text-muted);max-width:760px;margin:0 auto;">
                <p style="margin-bottom:1rem;">Каталог курсов очищен и ожидает новое наполнение.</p>
                <p>Сюда нужно добавить направления обучения с названием, обещанием результата, форматом, уровнем подготовки, длительностью, карточкой-обложкой и понятным CTA для входа в детальную страницу.</p>
            </div>
        }
        else
        {
            <div class="course-cards-grid">
                @foreach (var (c, i) in courses.Select((x, idx) => (x, idx)))
                {
                    var course = c;
                    var revealClass = i == 1 ? "reveal-d1" : i == 2 ? "reveal-d2" : "";
                    <ProductCard Url="@($"/courses/{CanonicalCourseSlug(course.Slug)}")"
                                 ImageUrl="@course.ImageUrl"
                                 Title="@DisplayCourseTitle(course)"
                                 Eyebrow="@course.Eyebrow"
                                 Description="@course.Subtitle"
                                 CtaText="@F("CardCta", Loc["page.courses.card.cta"])"
                                 RevealClass="@revealClass" />
                }
            </div>
        }
    </div>
</section>

@code {
    private List<CourseDto> courses = new();
    private bool loading = true;
    private SitePageDto? pageData;

    protected override async Task OnInitializedAsync()
    {
        Loc.OnLanguageChanged += OnLangChanged;
        await Task.WhenAll(LoadAsync(), LoadPage());
    }

    private async Task LoadPage()
    {
        try { pageData = await Api.GetSitePageAsync("courses", Loc.CurrentLang); }
        catch { pageData = null; }
    }

    private string F(string field, string fallback = "")
    {
        var val = pageData?.Fields != null && pageData.Fields.TryGetValue(field, out var v) && !string.IsNullOrEmpty(v) ? v : fallback;
        return field.Contains("Image", StringComparison.OrdinalIgnoreCase) ? Api.ResolveMediaUrl(val) : val;
    }

    private static string CanonicalCourseSlug(string slug) => slug switch
    {
        "pranayama" => "pranavidya",
        _ => slug
    };

    private string DisplayCourseTitle(CourseDto course) => CanonicalCourseSlug(course.Slug) switch
    {
        "pranavidya" => Loc.CurrentLang switch
        {
            "en" => "Pranavidya",
            "uk" => "Пранавід'я",
            _ => "Пранавидья"
        },
        _ => course.Title
    };

    private async Task LoadAsync()
    {
        loading = true;
        StateHasChanged();
        courses = await CatalogState.GetCoursesAsync(Loc.CurrentLang) ?? new();
        loading = false;
    }

    private void OnLangChanged() => InvokeAsync(async () => { await Task.WhenAll(LoadAsync(), LoadPage()); StateHasChanged(); });
    public void Dispose() => Loc.OnLanguageChanged -= OnLangChanged;
}
