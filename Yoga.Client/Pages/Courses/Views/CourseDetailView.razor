@using System.Text.RegularExpressions

@if (Loading)
{
    <section class="page-hero">
        <div class="container page-hero-content">
            <div class="skeleton" style="height: 1.5rem; width: 20%; margin-bottom: 2rem;"></div>
            <div class="skeleton" style="height: 4rem; width: 60%; margin-bottom: 2rem;"></div>
        </div>
    </section>
}
else if (Course == null)
{
    <section class="page-hero">
        <div class="container page-hero-content">
            <h1>@(Loc.CurrentLang == "uk" ? "Курс не знайдено" : "Course not found")</h1>
            <a href="/courses" class="btn btn-outline" style="margin-top:1.5rem; display:inline-flex;">@(Loc.CurrentLang == "uk" ? "До каталогу" : "Back to catalog")</a>
        </div>
    </section>
}
else
{
    <section class="page-hero">
        <div class="page-hero-bg" style="background-image: url('@(string.IsNullOrEmpty(Course.ImageUrl) ? "https://images.unsplash.com/photo-1506126279646-a697353d3166?auto=format&fit=crop&w=1600&q=80" : Img(Course.ImageUrl))');"></div>
        <div class="page-hero-overlay"></div>
        <div class="container page-hero-content">
            @if (!string.IsNullOrEmpty(Course.Eyebrow))
            {
                <p class="section-eyebrow">@Course.Eyebrow</p>
            }
            <h1>@DisplayTitle</h1>
            <div class="section-divider" style="margin:2rem 0;"></div>
            @if (!string.IsNullOrEmpty(Course.Subtitle))
            {
                <p>@Course.Subtitle</p>
            }
        </div>
    </section>

    @if (!string.IsNullOrEmpty(Course.Duration) || !string.IsNullOrEmpty(Course.Format) || !string.IsNullOrEmpty(Course.Level) || !string.IsNullOrEmpty(Course.Schedule))
    {
        <section class="format-strip">
            <div class="format-strip-grid">
                @if (!string.IsNullOrEmpty(Course.Schedule))
                {
                    <div class="format-strip-cell">
                        <span class="format-strip-label">@(Loc.CurrentLang == "uk" ? "Занять" : "Sessions")</span>
                        <span class="format-strip-value">@Course.Schedule</span>
                    </div>
                }
                @if (!string.IsNullOrEmpty(Course.Duration))
                {
                    <div class="format-strip-cell">
                        <span class="format-strip-label">@(Loc.CurrentLang == "uk" ? "Тривалість" : "Duration")</span>
                        <span class="format-strip-value">@Course.Duration</span>
                    </div>
                }
                @if (!string.IsNullOrEmpty(Course.Format))
                {
                    <div class="format-strip-cell">
                        <span class="format-strip-label">@(Loc.CurrentLang == "uk" ? "Формат" : "Format")</span>
                        <span class="format-strip-value">@Course.Format</span>
                    </div>
                }
                @if (!string.IsNullOrEmpty(Course.Level))
                {
                    <div class="format-strip-cell">
                        <span class="format-strip-label">@(Loc.CurrentLang == "uk" ? "Рівень" : "Level")</span>
                        <span class="format-strip-value">@Course.Level</span>
                    </div>
                }
            </div>
        </section>
    }

    <section class="overview-section">
        <div class="container">
            <div class="overview-grid">
                <div class="overview-left">
                    @if (!string.IsNullOrEmpty(Course?.Description))
                    {
                        <div class="overview-desc reveal">
                            @foreach (var para in Course.Description.Split('\n', StringSplitOptions.RemoveEmptyEntries))
                            {
                                <p>@para</p>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </section>

    @if (Course!.Modules.Count > 0)
    {
        <section class="program-section">
            <div class="container">
                <div class="section-header reveal">
                    <h2>@(Loc.CurrentLang == "uk" ? "Програма курсу" : "Course Program")</h2>
                    <div class="section-divider"></div>
                </div>
                <div class="program-list">
                    @{ int moduleNum = 0; }
                    @foreach (var mod in Course.Modules.OrderBy(m => m.SortOrder))
                    {
                        moduleNum++;
                        <details class="program-module program-module-expandable reveal">
                            <summary class="program-module-summary">
                                <span class="program-module-num">@moduleNum.ToString("D2")</span>
                                <div>
                                    <h3>@mod.Title</h3>
                                </div>
                                <span class="program-module-toggle">▾</span>
                            </summary>
                            <div class="program-lessons">
                                @if (!string.IsNullOrEmpty(mod.Description))
                                {
                                    <div class="module-desc">
                                        <p>@mod.Description</p>
                                    </div>
                                }
                                @foreach (var lesson in mod.Lessons.OrderBy(l => l.SortOrder))
                                {
                                    <div class="lesson-item">
                                        <h4 class="lesson-title">@lesson.Title</h4>
                                    </div>
                                }
                            </div>
                        </details>
                    }
                </div>
            </div>
        </section>
    }

    @if (!string.IsNullOrEmpty(Course.InstructorName))
    {
        <section class="instructor-section">
            <div class="container">
                <div class="section-header reveal">
                    <p class="section-eyebrow">@(Loc.CurrentLang == "uk" ? "Викладач" : "Instructor")</p>
                    <h2>@Course.InstructorName</h2>
                    <div class="section-divider"></div>
                </div>
                <div class="instructor-grid reveal">
                    @if (!string.IsNullOrEmpty(Course.InstructorImageUrl))
                    {
                        <div class="instructor-photo">
                            <img src="@Img(Course.InstructorImageUrl)" alt="@Course.InstructorName" loading="lazy" />
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(Course.InstructorBio))
                    {
                        <div class="instructor-bio">
                            @foreach (var para in Course.InstructorBio.Split('\n', StringSplitOptions.RemoveEmptyEntries))
                            {
                                <p>@para</p>
                            }
                        </div>
                    }
                </div>
            </div>
        </section>
    }

    <section class="page-cta">
        <div class="container" style="text-align:center;">
            @if (!string.IsNullOrEmpty(Course?.CtaHeading))
            {
                <h2>@Course?.CtaHeading</h2>
                <p>@Course?.CtaText</p>
            }
            else
            {
                <h2>@(Loc.CurrentLang == "uk" ? "Почати навчання" : "Start learning")</h2>
            }
            <button class="btn btn-primary" @onclick="OnCtaClick">@(Loc.CurrentLang == "uk" ? "Детальніше" : (Loc.CurrentLang == "ru" ? "Подробнее" : "Read more"))</button>
        </div>
    </section>
}

@code {
    [Parameter] public CourseDto? Course { get; set; }
    [Parameter] public bool Loading { get; set; }
    [Parameter] public string? DisplayTitle { get; set; }
    [Parameter] public EventCallback OnCtaClick { get; set; }
    
    [Inject] public LocalizationService Loc { get; set; } = default!;
    [Inject] public ApiService Api { get; set; } = default!;

    private string Img(string? u) => Api.ResolveMediaUrl(u);
}
