@page "/courses/{Slug}"
@using System.Text.RegularExpressions
@inject ApiService Api
@inject LocalizationService Loc
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>@(DisplayCourseTitle() ?? Loc["nav.courses"])</PageTitle>
<HeadContent>
    @if (course != null)
    {
        <meta name="description" content="@Truncate(course.Description, 160)" />
        <meta property="og:title" content="@course.Title — shakti.ashram" />
        <meta property="og:description" content="@Truncate(course.Description, 200)" />
        <meta property="og:type" content="website" />
        @if (!string.IsNullOrEmpty(course.ImageUrl))
        {
            <meta property="og:image" content="@course.ImageUrl" />
        }
    }
</HeadContent>

@if (loading)
{
    <section class="page-hero">
        <div class="container page-hero-content">
            <div class="skeleton" style="height: 1.5rem; width: 20%; margin-bottom: 2rem;"></div>
            <div class="skeleton" style="height: 4rem; width: 60%; margin-bottom: 2rem;"></div>
            <div class="skeleton" style="height: 1.5rem; width: 80%;"></div>
            <div class="skeleton" style="height: 1.5rem; width: 40%; margin-top: 0.5rem"></div>
        </div>
    </section>
}
else if (course == null)
{
    <section class="page-hero">
        <div class="container page-hero-content">
            <h1>@P("Карточка курса очищена", "Картку курсу очищено", "The course page has been cleared")</h1>
            <div class="section-divider" style="margin:2rem 0;"></div>
            <p style="max-width:760px; color:var(--text-muted);">@P("Сюда нужно добавить детальную программу курса: кому она подходит, какой результат обещает, как устроены модули, какой формат занятий и почему пользователь должен оставить заявку именно на этот продукт.", "Сюди потрібно додати детальну програму курсу: кому вона підходить, який результат обіцяє, як побудовані модулі, який формат занять і чому користувач має залишити заявку саме на цей продукт.", "Use this page for the full course offer: who it is for, what result it promises, how the modules are structured, what the format is, and why the user should apply for this specific product.")</p>
            <a href="/courses" class="btn btn-outline" style="margin-top:1.5rem; display:inline-flex;">@P("Вернуться к каталогу курсов", "Повернутися до каталогу курсів", "Back to the course catalog")</a>
        </div>
    </section>
}
else
{
    <section class="page-hero">
        <div class="page-hero-bg" style="background-image: url('@(string.IsNullOrEmpty(course.ImageUrl) ? "https://images.unsplash.com/photo-1506126279646-a697353d3166?auto=format&fit=crop&w=1600&q=80" : Img(course.ImageUrl))');"></div>
        <div class="page-hero-overlay"></div>
        <div class="container page-hero-content">
            @if (!string.IsNullOrEmpty(course.Eyebrow))
            {
                <p class="section-eyebrow" style="color:var(--accent);">@course.Eyebrow</p>
            }
            <div class="format-badges">
                @if (course.IsOnline)
                {
                    <span class="format-badge format-badge-online">Онлайн</span>
                }
                @if (course.IsOffline)
                {
                    <span class="format-badge format-badge-offline">Офлайн</span>
                }
            </div>
            <h1>@DisplayCourseTitle()</h1>
            <div class="section-divider" style="margin:2rem 0;"></div>
            @if (!string.IsNullOrEmpty(course.Subtitle))
            {
                <p>@course.Subtitle</p>
            }
        </div>
    </section>

    @if (!string.IsNullOrEmpty(course.Duration) || !string.IsNullOrEmpty(course.Format) || !string.IsNullOrEmpty(course.Level) || !string.IsNullOrEmpty(course.Schedule))
    {
        <section class="format-strip">
            <div class="format-strip-grid">
                @if (!string.IsNullOrEmpty(course.Schedule))
                {
                    <div class="format-strip-cell">
                        <span class="format-strip-label">Занятий</span>
                        <span class="format-strip-value">@course.Schedule</span>
                    </div>
                }
                @if (!string.IsNullOrEmpty(course.Duration))
                {
                    <div class="format-strip-cell">
                        <span class="format-strip-label">Длительность</span>
                        <span class="format-strip-value">@course.Duration</span>
                    </div>
                }
                @if (!string.IsNullOrEmpty(course.Format))
                {
                    <div class="format-strip-cell">
                        <span class="format-strip-label">Формат</span>
                        <span class="format-strip-value">@course.Format</span>
                    </div>
                }
                @if (!string.IsNullOrEmpty(course.Level))
                {
                    <div class="format-strip-cell">
                        <span class="format-strip-label">Уровень</span>
                        <span class="format-strip-value">@course.Level</span>
                    </div>
                }
            </div>
        </section>
    }

    <section class="overview-section">
        <div class="container">
            <div class="section-header reveal">
                <p class="section-eyebrow">@Loc["section.overview.eyebrow"]</p>
                <h2>@Loc["section.overview.h2"]</h2>
                <div class="section-divider"></div>
            </div>
            @{
                var descSections = ParseDescriptionSections();
            }
            @if (descSections.Aspects.Count > 0)
            {
                @if (!string.IsNullOrEmpty(descSections.Intro))
                {
                    <div class="overview-intro reveal">
                        @((MarkupString)descSections.Intro)
                    </div>
                }
                @if (HasPresImage1)
                {
                    <div class="overview-photo-full reveal">
                        <img src="@Img(course.PresentationImage1Url)" alt="" loading="lazy" />
                    </div>
                }
                <div class="overview-aspects-grid">
                    @{ int ai = 0; }
                    @foreach (var aspect in descSections.Aspects)
                    {
                        var dc = ai switch { 1 => "reveal-d1", 2 => "reveal-d2", _ => "" };
                        <div class="overview-aspect-card reveal @dc">
                            <h3>@aspect.Title</h3>
                            <div class="overview-aspect-body">@((MarkupString)aspect.Html)</div>
                        </div>
                        ai++;
                    }
                </div>
            }
            else
            {
                <div class="overview-grid @(HasPresImage1 ? "overview-grid-with-photo" : "")">
                    <div class="overview-left">
                        @if (!string.IsNullOrEmpty(course?.Description))
                        {
                            <div class="overview-desc reveal">
                                @if (course!.Description.Contains('<'))
                                {
                                    @((MarkupString)course.Description)
                                }
                                else
                                {
                                    @foreach (var para in course.Description.Split('\n', StringSplitOptions.RemoveEmptyEntries))
                                    {
                                        <p>@para</p>
                                    }
                                }
                            </div>
                        }
                    </div>
                    @if (HasPresImage1)
                    {
                        <div class="overview-photo reveal reveal-d1">
                            <img src="@Img(course?.PresentationImage1Url)" alt="" loading="lazy" />
                        </div>
                    }
                </div>
            }
        </div>
    </section>

    @if (RegularBenefits.Length > 0)
    {
        <section class="benefits-section">
            <div class="container">
                <div class="section-header reveal">
                    <p class="section-eyebrow">@Loc["section.benefits.h4"]</p>
                    <h2>@P("Что вы получите", "Що ви отримаєте", "What you'll get")</h2>
                    <div class="section-divider"></div>
                </div>
                <div class="benefits-grid">
                    @foreach (var benefit in RegularBenefits)
                    {
                        <div class="benefit-card reveal">
                            <span class="benefit-check"></span>
                            <span>@benefit</span>
                        </div>
                    }
                </div>
            </div>
        </section>
    }

    @if (course!.Modules.Count > 0)
    {
        <section class="program-section">
            <div class="container">
                <div class="section-header reveal">
                    <p class="section-eyebrow">@Loc["section.program.eyebrow"]</p>
                    <h2>@Loc["section.program.h2"]</h2>
                    <div class="section-divider"></div>
                </div>
                <div class="program-list">
                    @{ int moduleNum = 0; }
                    @foreach (var mod in course.Modules.OrderBy(m => m.SortOrder))
                    {
                        moduleNum++;
                        @if (mod.Lessons.Count > 0)
                        {
                            <details class="program-module program-module-expandable @(string.IsNullOrEmpty(mod.ImageUrl) ? "" : "has-image") reveal">
                                <summary class="program-module-summary">
                                    <span class="program-module-num">@moduleNum.ToString("D2")</span>
                                    <div>
                                        <h3>@mod.Title</h3>
                                        @if (!string.IsNullOrEmpty(mod.Description))
                                        {
                                            <div class="module-desc">
                                                @((MarkupString)RenderModuleDescription(mod.Description))
                                            </div>
                                        }
                                    </div>
                                    @if (!string.IsNullOrEmpty(mod.ImageUrl))
                                    {
                                        <div class="module-image">
                                            <img src="@Img(mod.ImageUrl)" alt="@mod.Title" loading="lazy" />
                                        </div>
                                    }
                                    <span class="program-module-toggle">▾</span>
                                </summary>
                                <div class="program-lessons">
                                    @foreach (var lesson in mod.Lessons.OrderBy(l => l.SortOrder))
                                    {
                                        <div class="lesson-item">
                                            <h4 class="lesson-title">@lesson.Title</h4>
                                            @if (!string.IsNullOrEmpty(lesson.Theory))
                                            {
                                                <div class="lesson-theory">
                                                    @foreach (var line in lesson.Theory.Split('\n', StringSplitOptions.RemoveEmptyEntries))
                                                    {
                                                        <p>@line</p>
                                                    }
                                                </div>
                                            }
                                            @if (!string.IsNullOrEmpty(lesson.Practice))
                                            {
                                                <div class="lesson-practice">
                                                    <span class="lesson-label">🧘 @P("Практика:", "Практика:", "Practice:")</span>
                                                    @foreach (var line in lesson.Practice.Split('\n', StringSplitOptions.RemoveEmptyEntries))
                                                    {
                                                        <p>@line</p>
                                                    }
                                                </div>
                                            }
                                            @if (!string.IsNullOrEmpty(lesson.Assignment))
                                            {
                                                <div class="lesson-assignment">
                                                    <span class="lesson-label">📌 @P("Задание:", "Завдання:", "Assignment:")</span>
                                                    @foreach (var line in lesson.Assignment.Split('\n', StringSplitOptions.RemoveEmptyEntries))
                                                    {
                                                        <p>@line</p>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                            </details>
                        }
                        else
                        {
                            <div class="program-module @(string.IsNullOrEmpty(mod.ImageUrl) ? "" : "has-image") reveal">
                                <span class="program-module-num">@moduleNum.ToString("D2")</span>
                                <div>
                                    <h3>@mod.Title</h3>
                                    @if (!string.IsNullOrEmpty(mod.Description))
                                    {
                                        <div class="module-desc">
                                            @((MarkupString)RenderModuleDescription(mod.Description))
                                        </div>
                                    }
                                </div>
                                @if (!string.IsNullOrEmpty(mod.ImageUrl))
                                {
                                    <div class="module-image">
                                        <img src="@Img(mod.ImageUrl)" alt="@mod.Title" loading="lazy" />
                                    </div>
                                }
                            </div>
                        }
                    }
                </div>
            </div>
        </section>
    }

    @if (HasPresImage2 || GoalBenefit != null)
    {
        <section class="course-showcase">
            <div class="container">
                <div class="showcase-layout">
                    @if (HasPresImage2)
                    {
                        <div class="showcase-photo reveal">
                            <img src="@Img(course.PresentationImage2Url)" alt="" loading="lazy" />
                        </div>
                    }
                    @if (GoalBenefit != null)
                    {
                        <div class="showcase-goal reveal reveal-d1">
                            <span class="showcase-goal-icon">🎯</span>
                            <h3>@P("Цель курса", "Мета курсу", "Course Goal")</h3>
                            <p>@GoalBenefit</p>
                        </div>
                    }
                </div>
            </div>
        </section>
    }

    @if (course.ForWhom.Length > 0)
    {
        <section class="for-whom-section">
            <div class="container">
                <div class="section-header reveal">
                    <p class="section-eyebrow">@Loc["section.forwhom.eyebrow"]</p>
                    <h2>@Loc["section.forwhom.h2"]</h2>
                    <div class="section-divider"></div>
                </div>
                <div class="for-whom-list">
                    @{ int fwIdx = 0; }
                    @foreach (var fw in course.ForWhom)
                    {
                        var delayClass = fwIdx switch { 1 => "reveal-d1", 2 => "reveal-d2", _ => "" };
                        var hasImg = !string.IsNullOrEmpty(fw.ImageUrl);
                        <div class="for-whom-item @(hasImg ? "has-photo" : "") reveal @delayClass">
                            @if (hasImg)
                            {
                                <div class="for-whom-photo">
                                    <img src="@Img(fw.ImageUrl)" alt="" loading="lazy" />
                                </div>
                            }
                            <div class="for-whom-content">
                                <h3>@fw.Title</h3>
                                @{ var fwLines = SplitForWhomText(fw.Text); }
                                @if (fwLines.Count > 1)
                                {
                                    <ul>
                                        @foreach (var line in fwLines)
                                        {
                                            <li>@line</li>
                                        }
                                    </ul>
                                }
                                else if (fwLines.Count == 1)
                                {
                                    <p>@fwLines[0]</p>
                                }
                            </div>
                        </div>
                        fwIdx++;
                    }
                </div>
            </div>
        </section>
    }

    @if (HasInstructor)
    {
        <section class="instructor-section">
            <div class="container">
                <div class="section-header reveal">
                    <p class="section-eyebrow">@P("Инструктор", "Інструктор", "Instructor")</p>
                    <h2>@course.InstructorName</h2>
                    <div class="section-divider"></div>
                </div>
                <div class="instructor-grid reveal">
                    @if (!string.IsNullOrEmpty(course.InstructorImageUrl))
                    {
                        <div class="instructor-photo">
                            <img src="@Img(course.InstructorImageUrl)" alt="@course.InstructorName" loading="lazy" />
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(course.InstructorBio))
                    {
                        <div class="instructor-bio">
                            @foreach (var para in course.InstructorBio.Split('\n', StringSplitOptions.RemoveEmptyEntries))
                            {
                                <p>@para</p>
                            }
                        </div>
                    }
                </div>
            </div>
        </section>
    }

    <RelatedBlog EntityId="course?.Id" Section="courses" />

    <section class="page-cta">
        <div class="container" style="text-align:center;">
            @if (!string.IsNullOrEmpty(course?.CtaHeading))
            {
                <span class="page-eyebrow">@Loc["section.cta.eyebrow"]</span>
                <h2>@course?.CtaHeading</h2>
                <p>@course?.CtaText</p>
            }
            else
            {
                <span class="page-eyebrow">@Loc["section.cta.eyebrow"]</span>
                <h2>@Loc["section.cta.h2"]</h2>
                <p>@Loc["section.cta.text"]</p>
            }
            <button class="btn btn-primary" @onclick="OpenModal">@Loc["section.cta.btn"]</button>
        </div>
    </section>
}



@code {
    [Parameter] public string Slug { get; set; } = "";

    private CourseDto? course;
    private bool loading = true;

    private bool HasPresImage1 => !string.IsNullOrEmpty(course?.PresentationImage1Url);
    private bool HasPresImage2 => !string.IsNullOrEmpty(course?.PresentationImage2Url);
    private bool HasInstructor => !string.IsNullOrEmpty(course?.InstructorName) || !string.IsNullOrEmpty(course?.InstructorImageUrl);

    private string Img(string? url)
    {
        if (string.IsNullOrEmpty(url) || url.StartsWith("http")) return url ?? "";
        return Api.ApiBaseUrl + url;
    }

    private string? GoalBenefit
    {
        get
        {
            var item = course?.Benefits.FirstOrDefault(b =>
                b.Contains("Цель курса") || b.Contains("Course Goal") || b.Contains("Мета курсу"));
            if (item == null) return null;
            // Explicit ranges — \p{L} unreliable in Blazor WASM invariant globalization
            var text = Regex.Replace(item.Trim(), @"^[^A-Za-zА-Яа-яЁёЄєІіЇїҐґ]+", "");
            foreach (var prefix in new[] { "Цель курса", "Course Goal", "Мета курсу" })
            {
                if (text.StartsWith(prefix, StringComparison.OrdinalIgnoreCase))
                {
                    text = text[prefix.Length..].Trim();
                    break;
                }
            }
            return string.IsNullOrWhiteSpace(text) ? null : text;
        }
    }

    private string[] RegularBenefits => course?.Benefits
        .Where(b => !b.Contains("Цель курса") && !b.Contains("Course Goal") && !b.Contains("Мета курсу"))
        .ToArray() ?? Array.Empty<string>();

    private (string? Intro, List<(string Title, string Html)> Aspects) ParseDescriptionSections()
    {
        if (course is null || string.IsNullOrEmpty(course.Description))
            return (null, new());

        var desc = course.Description;

        // Plain text (no HTML tags) — parse by "Title: body" lines
        if (!desc.Contains('<'))
            return ParsePlainTextSections(desc);

        var html = desc;

        // Tier 1: heading tags
        var matches = Regex.Matches(html, @"<h[2-4][^>]*>(.*?)</h[2-4]>",
            RegexOptions.IgnoreCase | RegexOptions.Singleline);
        if (matches.Count >= 2)
            return SplitByMatches(html, matches);

        // Tier 2: <strong>Title:</strong> patterns
        matches = Regex.Matches(html,
            @"<(?:strong|b)>([^<]{3,80}?):?\s*</(?:strong|b)>\s*:?",
            RegexOptions.IgnoreCase);
        if (matches.Count >= 2)
            return SplitByMatches(html, matches);

        // Tier 3: <p>Title: body</p> patterns (plain text in p tags)
        // Use explicit A-Z/А-Я ranges — \p{Lu}/\p{L} unreliable in Blazor WASM invariant globalization
        matches = Regex.Matches(html,
            @"<p[^>]*>\s*([A-ZА-ЯЁ][A-Za-zА-Яа-яЁё\s]{2,50}?)\s*:",
            RegexOptions.None);
        if (matches.Count >= 3)
            return SplitByMatches(html, matches);

        // Tier 4: Try extracting text from HTML and parsing as plain text
        var plainText = Regex.Replace(html, @"<[^>]+>", "\n");
        var plainResult = ParsePlainTextSections(plainText);
        if (plainResult.Aspects.Count >= 2) return plainResult;

        return (null, new());
    }

    private static (string? Intro, List<(string Title, string Html)> Aspects) ParsePlainTextSections(string text)
    {
        var lines = text.Split('\n', StringSplitOptions.RemoveEmptyEntries);
        var pattern = new Regex(@"^([A-ZА-ЯЁ][A-Za-zА-Яа-яЁё\s]{2,50}?):\s+(.+)");

        var intro = new List<string>();
        var aspects = new List<(string Title, string Html)>();
        bool inAspects = false;

        foreach (var rawLine in lines)
        {
            var trimmed = rawLine.Trim();
            if (string.IsNullOrWhiteSpace(trimmed)) continue;

            var match = pattern.Match(trimmed);
            if (match.Success)
            {
                inAspects = true;
                aspects.Add((match.Groups[1].Value.Trim(), $"<p>{match.Groups[2].Value.Trim()}</p>"));
            }
            else if (!inAspects)
            {
                intro.Add(trimmed);
            }
            else if (aspects.Count > 0)
            {
                aspects[^1] = (aspects[^1].Title, aspects[^1].Html + $" <p>{trimmed}</p>");
            }
        }

        if (aspects.Count < 2) return (null, new());

        var introHtml = intro.Count > 0
            ? string.Join("", intro.Select(l => $"<p>{System.Net.WebUtility.HtmlEncode(l)}</p>"))
            : null;
        return (introHtml, aspects);
    }

    private (string? Intro, List<(string Title, string Html)> Aspects) SplitByMatches(
        string html, MatchCollection matches)
    {
        var aspects = new List<(string Title, string Html)>();
        string? intro = null;

        for (int i = 0; i < matches.Count; i++)
        {
            var m = matches[i];
            if (i == 0 && m.Index > 0)
            {
                intro = CleanEmpty(html[..m.Index]);
                if (string.IsNullOrWhiteSpace(Regex.Replace(intro ?? "", @"<[^>]+>", "")))
                    intro = null;
            }

            var title = Regex.Replace(m.Groups[1].Value, @"<[^>]+>", "").Trim().TrimEnd(':');
            int bodyStart = m.Index + m.Length;
            int bodyEnd = i + 1 < matches.Count ? matches[i + 1].Index : html.Length;
            var body = CleanEmpty(html[bodyStart..bodyEnd]);

            if (!string.IsNullOrWhiteSpace(title) &&
                !string.IsNullOrWhiteSpace(Regex.Replace(body, @"<[^>]+>", "")))
                aspects.Add((title, body));
        }

        return (intro, aspects);
    }

    private static string CleanEmpty(string html)
        => Regex.Replace(html.Trim(), @"<p>\s*(<br\s*/?>)?\s*</p>", "").Trim();

    private static string RenderModuleDescription(string text)
    {
        var lines = text.Split('\n');
        var sb = new System.Text.StringBuilder();
        bool inList = false;

        foreach (var raw in lines)
        {
            var line = raw.Trim();
            if (string.IsNullOrWhiteSpace(line))
            {
                if (inList) { sb.Append("</ul>"); inList = false; }
                continue;
            }

            // Lesson heading: "Урок 1." / "Неделя 1." / "Модуль 1."
            if (Regex.IsMatch(line, @"^(Урок|Неделя|Модуль|Lesson|Week|Module)\s+\d", RegexOptions.IgnoreCase))
            {
                if (inList) { sb.Append("</ul>"); inList = false; }
                sb.Append($"<h4 class=\"mod-lesson-title\">{Enc(line)}</h4>");
                continue;
            }

            // Section label: "Практика:", "Задание:", "Темы:", "Фокус:", "Цель:"
            if (Regex.IsMatch(line, @"^(Практика|Задание|Темы|Фокус|Цель|Пранаяма|Асаны|Медитация|Practice|Assignment|Topics):", RegexOptions.IgnoreCase))
            {
                if (inList) { sb.Append("</ul>"); inList = false; }
                var colonIdx = line.IndexOf(':');
                var label = line[..colonIdx];
                var rest = line[(colonIdx + 1)..].Trim();
                sb.Append($"<p class=\"mod-section-label\"><strong>{Enc(label)}:</strong>");
                if (!string.IsNullOrEmpty(rest)) sb.Append($" {Enc(rest)}");
                sb.Append("</p>");
                continue;
            }

            // Regular line → bullet
            if (!inList) { sb.Append("<ul class=\"mod-bullets\">"); inList = true; }
            sb.Append($"<li>{Enc(line)}</li>");
        }

        if (inList) sb.Append("</ul>");
        return sb.ToString();

        static string Enc(string s) => System.Net.WebUtility.HtmlEncode(s);
    }

    private static List<string> SplitForWhomText(string text)
    {
        if (string.IsNullOrWhiteSpace(text)) return new();
        // Split by newlines first
        var lines = text.Split('\n', StringSplitOptions.RemoveEmptyEntries)
            .Select(l => l.Trim())
            .Where(l => l.Length > 0)
            .ToList();
        if (lines.Count > 1) return lines;
        // If single block, split where uppercase letter starts a new sentence (after space)
        var parts = Regex.Split(text.Trim(), @"(?<=\s)(?=[A-ZА-ЯЁ][a-zа-яё])")
            .Select(p => p.Trim())
            .Where(p => p.Length > 0)
            .ToList();
        return parts;
    }

    protected override async Task OnInitializedAsync()
    {
        Loc.OnLanguageChanged += Refresh;
        await LoadCourse();
    }

    protected override async Task OnParametersSetAsync()
    {
        await LoadCourse();
    }

    private async Task LoadCourse()
    {
        var requestedSlug = NormalizeSlug(Slug);
        var canonicalSlug = CanonicalCourseSlug(requestedSlug);
        if (!string.Equals(requestedSlug, canonicalSlug, StringComparison.Ordinal))
        {
            Nav.NavigateTo($"/courses/{canonicalSlug}", replace: true);
            return;
        }

        loading = true;
        try
        {
            course = await Api.GetCourseAsync(ApiCourseSlug(canonicalSlug), Loc.CurrentLang);
        }
        catch { course = null; }
        loading = false;
    }

    private string? DisplayCourseTitle()
    {
        if (course is null)
        {
            return null;
        }

        return CanonicalCourseSlug(NormalizeSlug(course.Slug)) == "pranavidya"
            ? CourseDisplayLabel()
            : course.Title;
    }

    private static string NormalizeSlug(string? slug) => slug?.Trim().ToLowerInvariant() ?? string.Empty;

    private static string CanonicalCourseSlug(string slug) => slug switch
    {
        "pranayama" => "pranavidya",
        _ => slug
    };

    private static string ApiCourseSlug(string slug) => slug switch
    {
        "pranavidya" => "pranayama",
        _ => slug
    };

    private string CourseDisplayLabel() => Loc.CurrentLang switch
    {
        "en" => "Pranavidya",
        "uk" => "Пранавід'я",
        _ => "Пранавидья"
    };

    private void OpenModal()
    {
        var parameters = new Dictionary<string, object>();
        var currentCourse = course;
        parameters["ContextTitle"] = currentCourse?.Title ?? "Курс";
        if (currentCourse is not null)
        {
            parameters["TargetCourseId"] = currentCourse.Id;
        }
        ModalService.Show<LeadModal>(parameters);
    }
    private async void Refresh()
    {
        await LoadCourse();
        await InvokeAsync(StateHasChanged);
    }

    private string P(string ru, string uk, string en) => Loc.CurrentLang switch
    {
        "uk" => uk,
        "en" => en,
        _ => ru
    };

    public void Dispose() => Loc.OnLanguageChanged -= Refresh;

    private static string Truncate(string? s, int max) =>
        string.IsNullOrEmpty(s) ? "" : s.Length <= max ? s : s[..max] + "…";
}
