@page "/consultations"
@inject LocalizationService Loc
@inject ApiService Api
@implements IDisposable

<PageTitle>@Loc["page.consultations.title"]</PageTitle>

<section class="page-hero">
    <div class="page-hero-bg" style="background-image: url('@F("HeroImageUrl", "https://images.unsplash.com/photo-1518611012118-696072aa579a?auto=format&fit=crop&w=1600&q=80")');" ></div>
    <div class="page-hero-overlay"></div>
    <div class="container page-hero-content">
        <p class="section-eyebrow" style="color:var(--accent);">@F("Eyebrow", Loc["page.consultations.eyebrow"])</p>
        <h1>@F("H1", Loc["page.consultations.h1"])</h1>
        <div class="section-divider" style="margin:2rem 0;"></div>
        <p>@F("Intro", Loc["page.consultations.intro"])</p>
    </div>
</section>

<section class="course-cards-section">
    <div class="container">
        <div class="section-header reveal">
            <p class="section-eyebrow">@F("Eyebrow", Loc["page.consultations.eyebrow"])</p>
            <h2>@F("H2", Loc["page.consultations.h2"])</h2>
            <div class="section-divider"></div>
        </div>
        @if (loading)
        {
            <div class="public-loading-state">Загружаем консультации</div>
        }
        else if (!string.IsNullOrEmpty(errorMessage))
        {
            <div style="text-align:center;padding:4rem 0;color:var(--text-muted);max-width:760px;margin:0 auto;">
                <p style="margin-bottom:1rem;">@errorMessage</p>
                <p>Сейчас вместо каталога нужно подключить публичный API и затем добавить консультации с кратким описанием, экспертной специализацией, изображением и CTA.</p>
            </div>
        }
        else if (!consultations.Any())
        {
            <div style="text-align:center;padding:4rem 0;color:var(--text-muted);max-width:760px;margin:0 auto;">
                <p style="margin-bottom:1rem;">Раздел подготовлен под новое наполнение.</p>
                <p>Сюда нужно добавить 3-6 консультаций: название направления, для кого подходит консультация, ожидаемый результат, короткую цитату-обещание и отдельное изображение для карточки.</p>
            </div>
        }
        else
        {
            <div class="course-cards-grid">
                @foreach (var (c, i) in consultations.Select((x, idx) => (x, idx)))
                {
                    var cons = c;
                    var revealClass = i == 1 ? "reveal-d1" : i == 2 ? "reveal-d2" : "";
                    <ProductCard Url="@($"/consultations/{CanonicalConsultationSlug(cons.Slug)}")"
                                 ImageUrl="@cons.ImageUrl"
                                 Title="@DisplayConsultationTitle(cons)"
                                 Eyebrow="@cons.Eyebrow"
                                 Description="@cons.Quote"
                                 CtaText="@F("CardCta", Loc["page.consultations.card.cta"])"
                                 RevealClass="@revealClass" />
                }
            </div>
        }
    </div>
</section>

@code {
    private List<ConsultationDto> consultations = new();
    private bool loading = true;
    private string? errorMessage;
    private SitePageDto? pageData;

    protected override async Task OnInitializedAsync()
    {
        Loc.OnLanguageChanged += OnLangChanged;
        await Task.WhenAll(LoadAsync(), LoadPage());
    }

    private async Task LoadPage()
    {
        try { pageData = await Api.GetSitePageAsync("consultations", Loc.CurrentLang); }
        catch { pageData = null; }
    }

    private string F(string field, string fallback = "")
    {
        var val = pageData?.Fields != null && pageData.Fields.TryGetValue(field, out var v) && !string.IsNullOrEmpty(v) ? v : fallback;
        return field.Contains("Image", StringComparison.OrdinalIgnoreCase) ? Api.ResolveMediaUrl(val) : val;
    }

    private static string CanonicalConsultationSlug(string slug) => slug;

    private string DisplayConsultationTitle(ConsultationDto consultation) => consultation.Title;

    private async Task LoadAsync()
    {
        loading = true;
        errorMessage = null;
        StateHasChanged();
        try
        {
            consultations = await CatalogState.GetConsultationsAsync(Loc.CurrentLang) ?? new();
        }
        catch
        {
            consultations = new();
            errorMessage = "Каталог консультаций не загрузился, потому что публичный frontend сейчас не может получить данные из backend API.";
        }
        loading = false;
    }

    private void OnLangChanged() => InvokeAsync(async () => { await Task.WhenAll(LoadAsync(), LoadPage()); StateHasChanged(); });
    public void Dispose() => Loc.OnLanguageChanged -= OnLangChanged;
}
