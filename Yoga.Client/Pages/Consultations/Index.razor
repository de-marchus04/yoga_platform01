@page "/consultations"
@inject LocalizationService Loc
@inject ApiService Api
@implements IDisposable

<PageTitle>@Loc["page.consultations.title"]</PageTitle>

<div class="arc-dossier">
    @* ── Hero: private, narrow, trust-building ── *@
    <section class="arc-dossier__hero">
        <div class="container arc-dossier__hero-inner">
            <p class="section-eyebrow">@F("Eyebrow", Loc["page.consultations.eyebrow"])</p>
            <h1>@F("H1", Loc["page.consultations.h1"])</h1>
            <div class="section-divider"></div>
            <p class="arc-dossier__hero-intro">@F("Intro", Loc["page.consultations.intro"])</p>
        </div>
    </section>

    @* ── How it works: 3 steps ── *@
    <section class="arc-dossier__steps">
        <div class="container">
            <div class="section-header">
                <p class="section-eyebrow">@Loc["consultations.how.eyebrow"]</p>
                <h2>@Loc["consultations.how.h2"]</h2>
                <div class="section-divider"></div>
            </div>
            <div class="arc-dossier__steps-grid">
                <div class="arc-dossier__step">
                    <span class="arc-dossier__step-num">01</span>
                    <h3>@Loc["consultations.how.step1.title"]</h3>
                    <p>@Loc["consultations.how.step1.text"]</p>
                </div>
                <div class="arc-dossier__step">
                    <span class="arc-dossier__step-num">02</span>
                    <h3>@Loc["consultations.how.step2.title"]</h3>
                    <p>@Loc["consultations.how.step2.text"]</p>
                </div>
                <div class="arc-dossier__step">
                    <span class="arc-dossier__step-num">03</span>
                    <h3>@Loc["consultations.how.step3.title"]</h3>
                    <p>@Loc["consultations.how.step3.text"]</p>
                </div>
            </div>
        </div>
    </section>

    @* ── Catalog: stacked dossier panels ── *@
    <section class="arc-dossier__catalog">
        <div class="container">
            @if (loading)
            {
                <div class="public-loading-state">@Loc["common.loading"]</div>
            }
            else if (!string.IsNullOrEmpty(errorMessage))
            {
                <p class="arc-dossier__empty">@errorMessage</p>
            }
            else if (!consultations.Any())
            {
                <p class="arc-dossier__empty">@Loc["page.consultations.intro"]</p>
            }
            else
            {
                <div class="arc-dossier__stack">
                    @foreach (var cons in consultations)
                    {
                        <a class="arc-dossier__panel" href="/consultations/@cons.Slug">
                            @if (!string.IsNullOrEmpty(cons.ImageUrl))
                            {
                                <div class="arc-dossier__panel-image">
                                    <img src="@Api.ResolveMediaUrl(cons.ImageUrl)" alt="@cons.Title" loading="lazy" />
                                </div>
                            }
                            <div class="arc-dossier__panel-body">
                                @if (!string.IsNullOrEmpty(cons.Eyebrow))
                                {
                                    <span class="arc-dossier__panel-eyebrow">@cons.Eyebrow</span>
                                }
                                <h3>@cons.Title</h3>
                                @if (!string.IsNullOrEmpty(cons.Quote))
                                {
                                    <blockquote class="arc-dossier__panel-quote">@cons.Quote</blockquote>
                                }
                                <div class="arc-dossier__panel-facets">
                                    @if (!string.IsNullOrEmpty(cons.Duration))
                                    {
                                        <span>@Loc["meta.duration"]: @cons.Duration</span>
                                    }
                                    @if (!string.IsNullOrEmpty(cons.Format))
                                    {
                                        <span>@Loc["meta.format"]: @cons.Format</span>
                                    }
                                </div>
                                <span class="btn btn-outline" style="margin-top: 1.5rem; text-decoration: none;">@(Loc.CurrentLang == "uk" ? "Детальніше" : (Loc.CurrentLang == "ru" ? "Подробнее" : "Read more"))</span>
                            </div>
                        </a>
                    }
                </div>
            }
        </div>
    </section>
</div>

@code {
    private List<ConsultationDto> consultations = new();
    private bool loading = true;
    private string? errorMessage;
    private SitePageDto? pageData;

    protected override async Task OnInitializedAsync()
    {
        Loc.OnLanguageChanged += OnLangChanged;
        await Task.WhenAll(LoadAsync(), LoadPage());
    }

    private async Task LoadPage()
    {
        try { pageData = await Api.GetSitePageAsync("consultations", Loc.CurrentLang); }
        catch { pageData = null; }
    }

    private string F(string field, string fallback = "")
    {
        var val = pageData?.Fields != null && pageData.Fields.TryGetValue(field, out var v) && !string.IsNullOrEmpty(v) ? v : fallback;
        return field.Contains("Image", StringComparison.OrdinalIgnoreCase) ? Api.ResolveMediaUrl(val) : val;
    }

    private async Task LoadAsync()
    {
        loading = true;
        errorMessage = null;
        StateHasChanged();
        try
        {
            consultations = await CatalogState.GetConsultationsAsync(Loc.CurrentLang) ?? new();
        }
        catch
        {
            consultations = new();
            errorMessage = null;
        }
        loading = false;
    }

    private void OnLangChanged() => InvokeAsync(async () => { await Task.WhenAll(LoadAsync(), LoadPage()); StateHasChanged(); });
    public void Dispose() => Loc.OnLanguageChanged -= OnLangChanged;
}
