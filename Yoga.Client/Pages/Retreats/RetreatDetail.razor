@page "/retreats/{Slug}"
@inject LocalizationService Loc
@inject ApiService Api
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>@(item?.Title != null ? $"{item.Title} | shakti.ashram" : (Loc.CurrentLang == "uk" ? "Ретрит" : "Retreat"))</PageTitle>

@if (loading)
{
    <section class="page-hero">
        <div class="container page-hero-content">
            <div class="skeleton" style="height: 1.5rem; width: 20%; margin-bottom: 2rem;"></div>
            <div class="skeleton" style="height: 4rem; width: 60%; margin-bottom: 2rem;"></div>
        </div>
    </section>
}
else if (item is null)
{
    <section class="page-hero">
        <div class="container page-hero-content">
            <h1>@(Loc.CurrentLang == "uk" ? "Ретрит не знайдено" : "Retreat not found")</h1>
            <a class="btn btn-outline" href="/retreats" style="margin-top:1.5rem; display:inline-flex;">@(Loc.CurrentLang == "uk" ? "До каталогу" : "Back to catalog")</a>
        </div>
    </section>
}
else
{
    <section class="page-hero">
        <div class="page-hero-bg" style="background-image: url('@(string.IsNullOrEmpty(item.ImageUrl) ? "https://images.unsplash.com/photo-1506126279646-a697353d3166?auto=format&fit=crop&w=1600&q=80" : Api.ResolveMediaUrl(item.ImageUrl))');"></div>
        <div class="page-hero-overlay"></div>
        <div class="container page-hero-content">
            @if (!string.IsNullOrEmpty(item.Eyebrow))
            {
                <p class="section-eyebrow">@item.Eyebrow</p>
            }
            <h1>@item.Title</h1>
            <div class="section-divider" style="margin:2rem 0;"></div>
            @if (!string.IsNullOrEmpty(item.Subtitle))
            {
                <p>@item.Subtitle</p>
            }
        </div>
    </section>

    @if (!string.IsNullOrEmpty(item.Duration) || !string.IsNullOrEmpty(item.Location) || !string.IsNullOrEmpty(item.Format) || item.EventStartDate.HasValue)
    {
        <section class="format-strip">
            <div class="format-strip-grid">
                @if (!string.IsNullOrEmpty(item.Duration))
                {
                    <div class="format-strip-cell">
                        <span class="format-strip-label">@(Loc.CurrentLang == "uk" ? "Тривалість" : "Duration")</span>
                        <span class="format-strip-value">@item.Duration</span>
                    </div>
                }
                @if (!string.IsNullOrEmpty(item.Location))
                {
                    <div class="format-strip-cell">
                        <span class="format-strip-label">@(Loc.CurrentLang == "uk" ? "Місце" : "Location")</span>
                        <span class="format-strip-value">@item.Location</span>
                    </div>
                }
                @if (!string.IsNullOrEmpty(item.Format))
                {
                    <div class="format-strip-cell">
                        <span class="format-strip-label">@(Loc.CurrentLang == "uk" ? "Формат" : "Format")</span>
                        <span class="format-strip-value">@item.Format</span>
                    </div>
                }
                @if (item.EventStartDate.HasValue)
                {
                    <div class="format-strip-cell">
                        <span class="format-strip-label">@(Loc.CurrentLang == "uk" ? "Дата" : "Date")</span>
                        <span class="format-strip-value">@FmtDateRange(item.EventStartDate, item.EventEndDate)</span>
                    </div>
                }
            </div>
        </section>
    }

    <section class="overview-section">
        <div class="container">
            <div class="overview-grid">
                <div class="overview-desc reveal">
                    @if (!string.IsNullOrEmpty(item.Description))
                    {
                        @foreach (var para in item.Description.Split('\n', StringSplitOptions.RemoveEmptyEntries))
                        {
                            <p>@para</p>
                        }
                    }
                </div>
            </div>
        </div>
    </section>

    <section class="page-cta">
        <div class="container" style="text-align:center;">
            @if (!string.IsNullOrEmpty(item.CtaHeading))
            {
                <h2>@item.CtaHeading</h2>
                <p>@item.CtaText</p>
            }
            else
            {
                <h2>@(Loc.CurrentLang == "uk" ? "Долучитися" : "Join")</h2>
            }
            <button class="btn btn-primary" @onclick="OpenModal">@(Loc.CurrentLang == "uk" ? "Детальніше" : (Loc.CurrentLang == "ru" ? "Подробнее" : "Read more"))</button>
        </div>
    </section>
}

@code {
    [Parameter] public string Slug { get; set; } = "";
    private Yoga.Shared.DTOs.RetreatDto? item;
    private bool loading = true;

    protected override async Task OnInitializedAsync()
    {
        Loc.OnLanguageChanged += Refresh;
        await LoadData();
    }

    protected override async Task OnParametersSetAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        loading = true;
        try { item = await Api.GetRetreatAsync(Slug, Loc.CurrentLang); }
        catch { item = null; }
        loading = false;
    }

    private void OpenModal()
    {
        var p = new Dictionary<string, object>();
        p["ContextTitle"] = item?.Title ?? "Ретрит";
        if (item != null) p["TargetRetreatId"] = item.Id;
        ModalService.Show<LeadModal>(p);
    }

    private void Refresh() { InvokeAsync(async () => { await LoadData(); StateHasChanged(); }); }
    public void Dispose() => Loc.OnLanguageChanged -= Refresh;

    private string FmtDateRange(DateTime? start, DateTime? end)
    {
        if (!start.HasValue) return "";
        if (!end.HasValue || start.Value.Date == end.Value.Date) return start.Value.ToString("dd.MM.yyyy");
        return $"{start.Value:dd.MM} - {end.Value:dd.MM.yyyy}";
    }
}
