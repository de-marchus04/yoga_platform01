    };

    protected override async Task OnInitializedAsync() => Loc.OnLanguageChanged += Refresh;

    protected override async Task OnParametersSetAsync()
    {
        var slug = string.IsNullOrWhiteSpace(RetreatSlug) ? null : RetreatSlug.Trim();
        if (slug == _loadedForSlug && Id == _loadedForId && retreat != null)
            return;
        _loadedForSlug = slug;
        _loadedForId = Id;
        await LoadData();
    }

    private static readonly Guid SpecialRetreatId = Guid.Parse("11111111-1111-1111-1111-111111111111");

    private async Task LoadData()
    {
        notFound = false;
        retreat = null;
        try
        {
            var slug = string.IsNullOrWhiteSpace(RetreatSlug) ? null : RetreatSlug.Trim();
            if (!string.IsNullOrEmpty(slug))
                retreat = await ApiService.GetRetreatBySlugAsync(slug, Loc.CurrentLang);
            else if (Id != Guid.Empty)
                retreat = await ApiService.GetRetreatByIdAsync(Id, Loc.CurrentLang);
            else
            {
                notFound = true;
                return;
            }

            if (retreat == null) { notFound = true; return; }
            ApplyRetreatOverride();
            if (string.IsNullOrEmpty(slug) && Id != Guid.Empty && !string.IsNullOrWhiteSpace(retreat.Slug))
                Nav.NavigateTo($"/retreats/{retreat.Slug}", replace: true);

            var all = await CatalogState.GetActiveRetreatsAsync(Loc.CurrentLang);
            otherRetreats = all.Where(x => x.Id != retreat.Id).Take(2).ToList();
        }
        catch
        {
            notFound = true;
        }
    }

