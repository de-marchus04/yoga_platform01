@page "/retreats/{RetreatSegment}"
@inject LocalizationService Loc
@inject Yoga.Client.Services.ApiService ApiService
@inject NavigationManager Nav
@inject IJSRuntime JS
@implements IAsyncDisposable
@using Yoga.Shared.DTOs
@using Yoga.Client.Helpers

<PageTitle>@(retreat?.Title ?? Loc["page.retreat.detail.loading"]) | shakti.ashram</PageTitle>
<HeadContent>
    @if (retreat != null)
    {
        <meta name="description" content="@Truncate(retreat.Description, 160)" />
        <meta property="og:title" content="@retreat.Title — shakti.ashram" />
        <meta property="og:description" content="@Truncate(retreat.Description, 200)" />
        <meta property="og:type" content="website" />
        @if (!string.IsNullOrEmpty(retreat.ImageUrl))
        {
            <meta property="og:image" content="@retreat.ImageUrl" />
        }
    }
</HeadContent>

@if (retreat == null && !notFound)
{
    <section class="rd2-hero" style="background:var(--section-bg-dark);">
        <div class="rd2-hero__inner">
            <div class="skeleton skeleton-title" style="height:1rem; width:15%; margin-bottom:1rem;"></div>
            <div class="skeleton" style="height:3rem; width:70%; margin-bottom:1.5rem;"></div>
            <div style="display:flex; gap:1rem;">
                <div class="skeleton" style="height:2rem; width:120px; border-radius:30px;"></div>
                <div class="skeleton" style="height:2rem; width:200px; border-radius:30px;"></div>
            </div>
        </div>
    </section>
}
else if (notFound)
{
    <div style="min-height:65vh; display:flex; align-items:center; justify-content:center; flex-direction:column; gap:2rem; text-align:center;">
        <div style="max-width:780px;">
            <h1>@P("Страница ретрита очищена", "Сторінку ретриту очищено", "The retreat page has been cleared")</h1>
            <div class="section-divider" style="margin:2rem auto;"></div>
            <p style="color:var(--text-muted);">@P("Сюда нужно добавить полноценное описание ретрита.", "Сюди потрібно додати повноцінний опис ретриту.", "Add a full retreat description here.")</p>
        </div>
        <a href="/retreats/actual" class="btn btn-outline">← @Loc["page.retreat.detail.back"]</a>
    </div>
}
else
{
    var r = retreat!;
    var heroImg = r.ImageUrl != null ? ApiService.ResolveMediaUrl(r.ImageUrl) : "https://images.unsplash.com/photo-1545205597-3d9d02c29597?auto=format&fit=crop&w=1600&q=80";
    var duration = (r.EndDate - r.StartDate).Days;

    <!-- 1. HERO -->
    <section id="rd2-hero" class="rd2-hero" style="background-image: url('@heroImg');">
        <a href="/retreats/actual" class="rd2-hero__breadcrumb">← @Loc["page.retreat.detail.back"]</a>
        <div class="rd2-hero__inner">
            <p class="section-eyebrow" style="color:var(--accent);">@Loc["page.retreats.eyebrow"]</p>
            <h1 class="rd2-hero__title">@r.Title</h1>
            @if (!string.IsNullOrEmpty(r.Description))
            {
                <p class="rd2-hero__subtitle">@Truncate(r.Description, 120)</p>
            }
            <div class="rd2-hero__meta">
                <span class="rd2-hero__pill">
                    <span class="rd2-hero__pill-icon"><RetreatMetaSvg Kind="pin" /></span>
                    @r.Location
                </span>
                <span class="rd2-hero__pill">
                    <span class="rd2-hero__pill-icon"><RetreatMetaSvg Kind="calendar" /></span>
                    @r.StartDate.ToString("dd MMM yyyy") — @r.EndDate.ToString("dd MMM yyyy")
                </span>
                @if (!string.IsNullOrWhiteSpace(r.PriceLabel))
                {
                    <span class="rd2-hero__pill">@r.PriceLabel</span>
                }
                @if (IsPast)
                {
                    <span class="rd2-hero__pill rd2-hero__pill--past">@Loc["page.retreat.past.badge"]</span>
                }
            </div>
        </div>
        <button type="button" class="rd2-hero__scroll" @onclick="ScrollToContentAsync" aria-label="@Loc["rd.scroll"]">
            <span class="rd2-hero__scroll-bounce" aria-hidden="true">
                <span>@Loc["rd.scroll"]</span>
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 9l6 6 6-6"/></svg>
            </span>
        </button>
    </section>

    <!-- Sticky booking bar: shown after the hero scrolls away so the main CTA stays reachable on long pages. -->
    @if (!IsPast)
    {
        <div id="rd2-sticky-bar" class="rd2-sticky-bar">
            <div class="container rd2-sticky-bar__inner">
                <span class="rd2-sticky-bar__title">@Truncate(r.Title, 50)</span>
                @if (!string.IsNullOrWhiteSpace(r.PriceLabel))
                {
                    <span class="rd2-sticky-bar__price">@r.PriceLabel</span>
                }
                <button type="button" class="rd2-sticky-bar__cta" @onclick="OpenModal">@Loc["rd.sticky.cta"]</button>
            </div>
        </div>
    }

    <!-- 3. QUICK FACTS -->
    <section id="rd2-content-start" class="rd2-facts">
        <div class="rd2-facts__grid">
            <div class="rd2-facts__item">
                <svg class="rd2-facts__icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
                <span class="rd2-facts__label">@Loc["rd.facts.duration"]</span>
                <span class="rd2-facts__value">@duration @Loc["rd.facts.days"]</span>
            </div>
            <div class="rd2-facts__item">
                <svg class="rd2-facts__icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                <span class="rd2-facts__label">@Loc["rd.facts.group"]</span>
                <span class="rd2-facts__value">@Loc["rd.facts.group_value"]</span>
            </div>
            <div class="rd2-facts__item">
                <svg class="rd2-facts__icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
                <span class="rd2-facts__label">@Loc["rd.facts.level"]</span>
                <span class="rd2-facts__value">@Loc["rd.facts.level_value"]</span>
            </div>
            <div class="rd2-facts__item">
                <svg class="rd2-facts__icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                <span class="rd2-facts__label">@Loc["rd.facts.language"]</span>
                <span class="rd2-facts__value">@Loc["rd.facts.language_value"]</span>
            </div>
        </div>
    </section>

    <!-- 4. ABOUT -->
    <section class="rd2-about">
        <div class="rd2-about__grid reveal">
            <div>
                <p class="rd2-about__eyebrow">@Loc["rd.about.eyebrow"]</p>
                <h2 class="rd2-about__title">@Loc["rd.about.h2"]</h2>
                <div class="section-divider" style="margin:1.5rem 0;"></div>
                <div class="rd2-about__desc">
                    @foreach (var block in SplitDescriptionBlocks(r.Description))
                    {
                        <p>@block</p>
                    }
                </div>
                <div class="rd2-about__for-whom">
                    <h3 class="rd2-about__for-whom-title">@Loc["rd.about.for_whom"]</h3>
                    <ul class="rd2-about__for-whom-list">
                        <li>@Loc["rd.about.whom1"]</li>
                        <li>@Loc["rd.about.whom2"]</li>
                        <li>@Loc["rd.about.whom3"]</li>
                        <li>@Loc["rd.about.whom4"]</li>
                    </ul>
                </div>
            </div>
            <div class="rd2-about__image">
                <img src="https://images.unsplash.com/photo-1506126279646-a697353d3166?auto=format&fit=crop&w=800&q=80" alt="@r.Title" loading="lazy" />
            </div>
        </div>
    </section>

    <!-- 5. FACILITATOR -->
    <section class="rd2-facilitator reveal">
        <div class="rd2-facilitator__inner">
            <div class="rd2-facilitator__photo">АУ</div>
            <h3 class="rd2-facilitator__name">@Loc["rd.facilitator.name"]</h3>
            <p class="rd2-facilitator__role">@Loc["rd.facilitator.role"]</p>
            <p class="rd2-facilitator__bio">@Loc["rd.facilitator.bio"]</p>
            <blockquote class="rd2-facilitator__quote">«@Loc["rd.facilitator.quote"]»</blockquote>
        </div>
    </section>

    <!-- 6. ITINERARY -->
    <section class="rd2-itinerary">
        <div class="rd2-itinerary__inner reveal">
            <p class="rd2-itinerary__eyebrow">@Loc["rd.itinerary.eyebrow"]</p>
            <h2 class="rd2-itinerary__title">@Loc["rd.itinerary.h2"]</h2>
            @if (!string.IsNullOrWhiteSpace(r.Program))
            {
                <div class="rd2-program-html">@((MarkupString)r.Program)</div>
            }
            else
            {
                <details class="rd2-itinerary__day" open>
                    <summary>
                        <span class="rd2-itinerary__day-chip">@P("День 1", "День 1", "Day 1")</span>
                        <span class="rd2-itinerary__day-title">@P("Прибытие и встреча", "Прибуття та зустріч", "Arrival & welcome")</span>
                        <svg class="rd2-itinerary__chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
                    </summary>
                    <div class="rd2-itinerary__content">
                        <div class="rd2-itinerary__timeline">
                            <div class="rd2-itinerary__block"><span class="rd2-itinerary__block-time">@Loc["rd.itinerary.afternoon"]</span><p class="rd2-itinerary__block-text">@P("Заселение, знакомство группы", "Заселення, знайомство групи", "Check-in, group introduction")</p></div>
                            <div class="rd2-itinerary__block"><span class="rd2-itinerary__block-time">@Loc["rd.itinerary.evening"]</span><p class="rd2-itinerary__block-text">@P("Вечерняя медитация при свечах", "Вечірня медитація при свічках", "Evening candlelight meditation")</p></div>
                        </div>
                    </div>
                </details>
                <details class="rd2-itinerary__day">
                    <summary>
                        <span class="rd2-itinerary__day-chip">@P("Дни 2–6", "Дні 2–6", "Days 2–6")</span>
                        <span class="rd2-itinerary__day-title">@P("Практики и погружение", "Практики та занурення", "Practices & immersion")</span>
                        <svg class="rd2-itinerary__chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
                    </summary>
                    <div class="rd2-itinerary__content">
                        <div class="rd2-itinerary__timeline">
                            <div class="rd2-itinerary__block"><span class="rd2-itinerary__block-time">@Loc["rd.itinerary.morning"]</span><p class="rd2-itinerary__block-text">@P("Утренняя пранаяма и йога", "Ранкова пранаяма та йога", "Morning pranayama & yoga")</p></div>
                            <div class="rd2-itinerary__block"><span class="rd2-itinerary__block-time">@Loc["rd.itinerary.afternoon"]</span><p class="rd2-itinerary__block-text">@P("Авторские лекции, экскурсии, время для себя", "Авторські лекції, екскурсії, час для себе", "Author talks, excursions, free time")</p></div>
                            <div class="rd2-itinerary__block"><span class="rd2-itinerary__block-time">@Loc["rd.itinerary.evening"]</span><p class="rd2-itinerary__block-text">@P("Групповая медитация, беседы у костра", "Групова медитація, бесіди біля вогнища", "Group meditation, fireside talks")</p></div>
                        </div>
                    </div>
                </details>
                <details class="rd2-itinerary__day">
                    <summary>
                        <span class="rd2-itinerary__day-chip">@P("День 7", "День 7", "Day 7")</span>
                        <span class="rd2-itinerary__day-title">@P("Интеграция и отъезд", "Інтеграція та від'їзд", "Integration & departure")</span>
                        <svg class="rd2-itinerary__chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
                    </summary>
                    <div class="rd2-itinerary__content">
                        <div class="rd2-itinerary__timeline">
                            <div class="rd2-itinerary__block"><span class="rd2-itinerary__block-time">@Loc["rd.itinerary.morning"]</span><p class="rd2-itinerary__block-text">@P("Финальный круг, церемония благодарности", "Фінальне коло, церемонія подяки", "Final circle, gratitude ceremony")</p></div>
                            <div class="rd2-itinerary__block"><span class="rd2-itinerary__block-time">@Loc["rd.itinerary.afternoon"]</span><p class="rd2-itinerary__block-text">@P("Индивидуальная беседа с куратором, возвращение", "Індивідуальна бесіда з куратором, повернення", "Personal talk with facilitator, departure")</p></div>
                        </div>
                    </div>
                </details>
            }
        </div>
    </section>

    <!-- 7. GALLERY -->
    <section class="rd2-gallery">
        <div class="rd2-gallery__inner reveal">
            <p class="rd2-gallery__eyebrow">@Loc["page.retreat.detail.gallery_eyebrow"]</p>
            <h2 class="rd2-gallery__title">@Loc["page.retreat.detail.gallery_h2"]</h2>
            <div class="rd2-gallery__grid">
                @{ int gi = 0; }
                @foreach (var img in GalleryImages)
                {
                    var idx = gi;
                    <div class="rd2-gallery__item" @onclick="() => OpenLightbox(idx)">
                        <img src="@img" alt="@r.Title" loading="lazy" />
                    </div>
                    gi++;
                }
            </div>
        </div>
    </section>

    <!-- 8. INCLUSIONS -->
    <section class="rd2-inclusions">
        <div class="rd2-inclusions__inner reveal">
            <p class="rd2-inclusions__eyebrow">@Loc["rd.included.eyebrow"]</p>
            <h2 class="rd2-inclusions__title">@Loc["rd.included.h2"]</h2>
            <div class="rd2-inclusions__grid">
                <div>
                    <h3 style="margin-bottom:1rem; font-family:var(--font-sans); font-size:0.85rem; text-transform:uppercase; letter-spacing:2px; color:var(--accent);">@Loc["rd.included.col1"]</h3>
                    <div>
                        <div class="rd2-inclusions__item"><span class="rd2-inclusions__icon rd2-inclusions__icon--yes">✓</span> @Loc["page.retreat.detail.included.1"]</div>
                        <div class="rd2-inclusions__item"><span class="rd2-inclusions__icon rd2-inclusions__icon--yes">✓</span> @Loc["page.retreat.detail.included.2"]</div>
                        <div class="rd2-inclusions__item"><span class="rd2-inclusions__icon rd2-inclusions__icon--yes">✓</span> @Loc["page.retreat.detail.included.3"]</div>
                        <div class="rd2-inclusions__item"><span class="rd2-inclusions__icon rd2-inclusions__icon--yes">✓</span> @Loc["page.retreat.detail.included.4"]</div>
                        <div class="rd2-inclusions__item"><span class="rd2-inclusions__icon rd2-inclusions__icon--yes">✓</span> @Loc["page.retreat.detail.included.5"]</div>
                        <div class="rd2-inclusions__item"><span class="rd2-inclusions__icon rd2-inclusions__icon--yes">✓</span> @Loc["page.retreat.detail.included.6"]</div>
                        <div class="rd2-inclusions__item"><span class="rd2-inclusions__icon rd2-inclusions__icon--yes">✓</span> @Loc["page.retreat.detail.included.7"]</div>
                    </div>
                </div>
                <div>
                    <h3 style="margin-bottom:1rem; font-family:var(--font-sans); font-size:0.85rem; text-transform:uppercase; letter-spacing:2px; color:var(--text-muted);">@Loc["rd.included.col2"]</h3>
                    <div>
                        <div class="rd2-inclusions__item"><span class="rd2-inclusions__icon rd2-inclusions__icon--no">✕</span> @Loc["rd.excluded.1"]</div>
                        <div class="rd2-inclusions__item"><span class="rd2-inclusions__icon rd2-inclusions__icon--no">✕</span> @Loc["rd.excluded.2"]</div>
                        <div class="rd2-inclusions__item"><span class="rd2-inclusions__icon rd2-inclusions__icon--no">✕</span> @Loc["rd.excluded.3"]</div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- 9. ACCOMMODATION -->
    <section class="rd2-accommodation">
        <div class="rd2-accommodation__inner reveal">
            <p class="rd2-accommodation__eyebrow">@Loc["rd.accommodation.eyebrow"]</p>
            <h2 class="rd2-accommodation__section-title">@Loc["rd.accommodation.h2"]</h2>
            <div class="rd2-accommodation__grid">
                <img class="rd2-accommodation__image" src="https://images.unsplash.com/photo-1582719478250-c89cae4dc85b?auto=format&fit=crop&w=800&q=80" alt="Accommodation" loading="lazy" />
                <div class="rd2-accommodation__body">
                    <p class="rd2-accommodation__desc">@Loc["rd.accommodation.desc"]</p>
                    <div class="rd2-accommodation__amenities">
                        <span class="rd2-accommodation__tag">@Loc["rd.accommodation.amenity1"]</span>
                        <span class="rd2-accommodation__tag">@Loc["rd.accommodation.amenity2"]</span>
                        <span class="rd2-accommodation__tag">@Loc["rd.accommodation.amenity3"]</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- 10. REVIEWS -->
    <section class="rd2-reviews">
        <div class="rd2-reviews__inner reveal">
            <p class="rd2-reviews__eyebrow">@Loc["rd.reviews.eyebrow"]</p>
            <h2 class="rd2-reviews__title">@Loc["rd.reviews.h2"]</h2>
            <div class="rd2-reviews__track">
                <div class="rd2-reviews__card">
                    <div class="rd2-reviews__header">
                        <div class="rd2-reviews__avatar">ЕМ</div>
                        <div><span class="rd2-reviews__stars">★★★★★</span><br/><span class="rd2-reviews__author">@P("Елена М.", "Олена М.", "Elena M.")</span></div>
                    </div>
                    <p class="rd2-reviews__quote">@P("После этого ретрита я вернулась другим человеком. Тишина, природа, глубина практик — всё на своём месте.", "Після цього ретриту я повернулася іншою людиною.", "After this retreat I came back a different person.")</p>
                </div>
                <div class="rd2-reviews__card">
                    <div class="rd2-reviews__header">
                        <div class="rd2-reviews__avatar">ИВ</div>
                        <div><span class="rd2-reviews__stars">★★★★★</span><br/><span class="rd2-reviews__author">@P("Ирина В.", "Ірина В.", "Irina V.")</span></div>
                    </div>
                    <p class="rd2-reviews__quote">@P("Первый раз попала на подобную программу и сразу поняла: это именно то, чего не хватало годами.", "Вперше потрапила на подібну програму і одразу зрозуміла: це саме те.", "First time at such a program and I immediately knew: this is it.")</p>
                </div>
                <div class="rd2-reviews__card">
                    <div class="rd2-reviews__header">
                        <div class="rd2-reviews__avatar">ДК</div>
                        <div><span class="rd2-reviews__stars">★★★★★</span><br/><span class="rd2-reviews__author">@P("Дмитрий К.", "Дмитро К.", "Dmitry K.")</span></div>
                    </div>
                    <p class="rd2-reviews__quote">@P("Организация на высоте, куратор всегда рядом. Тело и ум получили именно тот отдых, который нужен.", "Організація на висоті, куратор завжди поруч.", "Top-notch organization, the facilitator is always near.")</p>
                </div>
            </div>
        </div>
    </section>

    <!-- 11. FAQ -->
    <section class="rd2-faq">
        <div class="rd2-faq__inner reveal">
            <p class="rd2-faq__eyebrow">@Loc["rd.faq.eyebrow"]</p>
            <h2 class="rd2-faq__title">@Loc["rd.faq.h2"]</h2>
            <details class="rd2-faq__item">
                <summary>@Loc["rd.faq.q1"] <svg class="rd2-faq__chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg></summary>
                <p class="rd2-faq__answer">@Loc["rd.faq.a1"]</p>
            </details>
            <details class="rd2-faq__item">
                <summary>@Loc["rd.faq.q2"] <svg class="rd2-faq__chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg></summary>
                <p class="rd2-faq__answer">@Loc["rd.faq.a2"]</p>
            </details>
            <details class="rd2-faq__item">
                <summary>@Loc["rd.faq.q3"] <svg class="rd2-faq__chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg></summary>
                <p class="rd2-faq__answer">@Loc["rd.faq.a3"]</p>
            </details>
            <details class="rd2-faq__item">
                <summary>@Loc["rd.faq.q4"] <svg class="rd2-faq__chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg></summary>
                <p class="rd2-faq__answer">@Loc["rd.faq.a4"]</p>
            </details>
            <details class="rd2-faq__item">
                <summary>@Loc["rd.faq.q5"] <svg class="rd2-faq__chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg></summary>
                <p class="rd2-faq__answer">@Loc["rd.faq.a5"]</p>
            </details>
        </div>
    </section>

    <RelatedBlog EntityId="retreat?.Id" Section="retreats" />

    <!-- 12. OTHER RETREATS -->
    @if (otherRetreats.Any())
    {
        <section class="rd2-others">
            <div class="rd2-others__inner reveal">
                <p class="rd2-others__eyebrow">@Loc["page.retreat.detail.other_eyebrow"]</p>
                <h2 class="rd2-others__title">@Loc["page.retreat.detail.other_h2"]</h2>
                <div class="rd2-others__grid">
                    @foreach (var other in otherRetreats)
                    {
                        var o = other;
                        <a href="@RetreatUrls.DetailPath(o)" class="rd2-others__card reveal">
                            <img class="rd2-others__card-image" src="@(o.ImageUrl != null ? ApiService.ResolveMediaUrl(o.ImageUrl) : "https://images.unsplash.com/photo-1506905925346-21bda4d32df4?auto=format&fit=crop&w=600&q=80")" alt="@o.Title" loading="lazy" />
                            <div class="rd2-others__card-body">
                                <h4 class="rd2-others__card-title">@o.Title</h4>
                                <p class="rd2-others__card-meta"><span class="card-meta-icon"><RetreatMetaSvg Kind="pin" /></span> @o.Location</p>
                                <p class="rd2-others__card-meta"><span class="card-meta-icon"><RetreatMetaSvg Kind="calendar" /></span> @o.StartDate.ToString("dd MMM yyyy")</p>
                                <span class="rd2-others__card-link">@Loc["page.retreat.detail.other_cta"]</span>
                            </div>
                        </a>
                    }
                </div>
            </div>
        </section>
    }

    <!-- 13. CTA FOOTER -->
    @if (!IsPast)
    {
        <section class="rd2-cta-footer" style="background-image: url('https://images.unsplash.com/photo-1506905925346-21bda4d32df4?auto=format&fit=crop&w=1800&q=80');">
            <div class="rd2-cta-footer__inner">
                <h2 class="rd2-cta-footer__title">@Loc["rd.cta.h2"]</h2>
                <p class="rd2-cta-footer__subtitle">@Loc["rd.cta.text"]</p>
                <button type="button" class="rd2-cta-footer__btn" @onclick="OpenModal">@Loc["rd.sticky.cta"]</button>
            </div>
        </section>
    }

    <!-- 14. MOBILE CTA -->
    @if (!IsPast)
    {
        <div class="rd2-mobile-cta">
            <button type="button" class="btn btn-primary" style="width:100%;" @onclick="OpenModal">@Loc["rd.mobile.cta"]</button>
        </div>
    }

    <!-- LIGHTBOX -->
    @if (showLightbox)
    {
        <div class="rd2-lightbox rd2-lightbox--open" @onclick="CloseLightbox">
            <button class="rd2-lightbox__close" @onclick="CloseLightbox" @onclick:stopPropagation="true">✕</button>
            <button class="rd2-lightbox__prev" @onclick="PrevImage" @onclick:stopPropagation="true">‹</button>
            <img class="rd2-lightbox__img" src="@GalleryImages[lightboxIndex]" alt="" @onclick:stopPropagation="true" />
            <button class="rd2-lightbox__next" @onclick="NextImage" @onclick:stopPropagation="true">›</button>
            <span class="rd2-lightbox__counter">@(lightboxIndex + 1) / @GalleryImages.Count</span>
        </div>
    }
}

@code {
    [Parameter] public string? RetreatSegment { get; set; }

    private RetreatDto? retreat;
    private bool notFound = false;
    private List<RetreatDto> otherRetreats = new();
    private string? _loadedSegment;

    private bool showLightbox;
    private int lightboxIndex;
    private Guid? _stickyBarBoundForRetreatId;

    private bool IsPast => retreat?.EndDate.ToUniversalTime() < DateTime.UtcNow;

    private List<string> GalleryImages => new()
    {
        retreat?.ImageUrl != null ? ApiService.ResolveMediaUrl(retreat.ImageUrl) : "https://images.unsplash.com/photo-1545205597-3d9d02c29597?auto=format&fit=crop&w=800&q=80",
        "https://images.unsplash.com/photo-1506126279646-a697353d3166?auto=format&fit=crop&w=800&q=80",
        "https://images.unsplash.com/photo-1508672019048-805c876b67e2?auto=format&fit=crop&w=800&q=80",
        "https://images.unsplash.com/photo-1544367567-0f2fcb009e0b?auto=format&fit=crop&w=800&q=80",
        "https://images.unsplash.com/photo-1571019613454-1cb2f99b2d8b?auto=format&fit=crop&w=800&q=80",
        "https://images.unsplash.com/photo-1506905925346-21bda4d32df4?auto=format&fit=crop&w=800&q=80",
    };

    protected override Task OnInitializedAsync()
    {
        Loc.OnLanguageChanged += Refresh;
        return Task.CompletedTask;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (retreat == null || notFound || IsPast)
        {
            _stickyBarBoundForRetreatId = null;
            try { await JS.InvokeVoidAsync("ylRd2StickyDispose"); } catch { /* prerender / disconnected */ }
            return;
        }

        if (_stickyBarBoundForRetreatId == retreat.Id)
            return;
        _stickyBarBoundForRetreatId = retreat.Id;
        try { await JS.InvokeVoidAsync("ylRd2StickyInit"); } catch { /* prerender */ }
    }

    private async Task ScrollToContentAsync()
    {
        try { await JS.InvokeVoidAsync("ylScrollToElementId", "rd2-content-start"); } catch { }
    }

    protected override async Task OnParametersSetAsync()
    {
        var seg = string.IsNullOrWhiteSpace(RetreatSegment) ? null : RetreatSegment.Trim();
        if (seg == _loadedSegment && retreat != null)
            return;
        _loadedSegment = seg;
        await LoadData();
    }

    private async Task LoadData()
    {
        notFound = false;
        retreat = null;
        try
        {
            var seg = string.IsNullOrWhiteSpace(RetreatSegment) ? null : RetreatSegment.Trim();
            if (string.IsNullOrEmpty(seg))
            {
                notFound = true;
                return;
            }

            if (Guid.TryParse(seg, out _))
            {
                notFound = true;
                return;
            }

            retreat = await ApiService.GetRetreatBySlugAsync(seg, Loc.CurrentLang);
            if (retreat == null) { notFound = true; return; }
            if (!string.IsNullOrWhiteSpace(retreat.Slug) && !string.Equals(seg, retreat.Slug, StringComparison.OrdinalIgnoreCase))
                Nav.NavigateTo($"/retreats/{retreat.Slug}", replace: true);

            var all = await CatalogState.GetActiveRetreatsAsync(Loc.CurrentLang);
            otherRetreats = all.Where(x => x.Id != retreat.Id).Take(2).ToList();
        }
        catch
        {
            notFound = true;
        }
    }

    private void OpenLightbox(int index) { lightboxIndex = index; showLightbox = true; }
    private void CloseLightbox() => showLightbox = false;
    private void NextImage() => lightboxIndex = (lightboxIndex + 1) % GalleryImages.Count;
    private void PrevImage() => lightboxIndex = (lightboxIndex - 1 + GalleryImages.Count) % GalleryImages.Count;

    private async void Refresh()
    {
        _loadedSegment = null;
        await LoadData();
        await InvokeAsync(StateHasChanged);
    }

    private void OpenModal()
    {
        var parameters = new Dictionary<string, object>();
        parameters["ContextTitle"] = retreat?.Title ?? "Ретрит";
        if (retreat != null)
        {
            parameters["TargetRetreatId"] = retreat.Id;
        }
        ModalService.Show<LeadModal>(parameters);
    }

    private string P(string ru, string uk, string en) => Loc.CurrentLang switch
    {
        "uk" => uk,
        "en" => en,
        _ => ru
    };

    public async ValueTask DisposeAsync()
    {
        Loc.OnLanguageChanged -= Refresh;
        _stickyBarBoundForRetreatId = null;
        try { await JS.InvokeVoidAsync("ylRd2StickyDispose"); } catch { }
    }

    private static string Truncate(string? s, int max) =>
        string.IsNullOrEmpty(s) ? "" : s.Length <= max ? s : s[..max] + "…";

    private static IEnumerable<string> SplitDescriptionBlocks(string? description)
    {
        if (string.IsNullOrWhiteSpace(description))
            yield break;
        var parts = description.Split(new[] { "\r\n\r\n", "\n\n" }, StringSplitOptions.RemoveEmptyEntries);
        foreach (var p in parts)
        {
            var t = p.Trim();
            if (t.Length > 0)
                yield return t;
        }
    }
}
