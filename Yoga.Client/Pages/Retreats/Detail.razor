@page "/retreats/{Id:guid}"
@page "/retreats/{RetreatSlug}"
@inject LocalizationService Loc
@inject Yoga.Client.Services.ApiService ApiService
@inject NavigationManager Nav
@implements IDisposable
@using Yoga.Shared.DTOs
@using Yoga.Client.Helpers

<PageTitle>@(retreat?.Title ?? Loc["page.retreat.detail.loading"]) | shakti.ashram</PageTitle>
<HeadContent>
    @if (retreat != null)
    {
        <meta name="description" content="@Truncate(retreat.Description, 160)" />
        <meta property="og:title" content="@retreat.Title — shakti.ashram" />
        <meta property="og:description" content="@Truncate(retreat.Description, 200)" />
        <meta property="og:type" content="website" />
        @if (!string.IsNullOrEmpty(retreat.ImageUrl))
        {
            <meta property="og:image" content="@retreat.ImageUrl" />
        }
    }
</HeadContent>

@if (retreat == null && !notFound)
{
    <section class="rd2-hero">
        <div class="rd2-hero-overlay" style="background:var(--background);"></div>
        <div class="container rd2-hero-content">
            <div class="skeleton skeleton-title" style="height:1rem; width:15%; margin-bottom:1rem;"></div>
            <div class="skeleton" style="height:3rem; width:70%; margin-bottom:1.5rem;"></div>
            <div style="display:flex; gap:1rem;">
                <div class="skeleton" style="height:2rem; width:120px; border-radius:30px;"></div>
                <div class="skeleton" style="height:2rem; width:200px; border-radius:30px;"></div>
            </div>
        </div>
    </section>
}
else if (notFound)
{
    <div style="min-height:65vh; display:flex; align-items:center; justify-content:center; flex-direction:column; gap:2rem; text-align:center;">
        <div style="max-width:780px;">
            <h1>@P("Страница ретрита очищена", "Сторінку ретриту очищено", "The retreat page has been cleared")</h1>
            <div class="section-divider" style="margin:2rem auto;"></div>
            <p style="color:var(--text-muted);">@P("Сюда нужно добавить полноценное описание ретрита: локацию, даты, формат участия, программу по дням, ключевые визуалы, социальное доказательство и CTA для отправки заявки.", "Сюди потрібно додати повноцінний опис ретриту: локацію, дати, формат участі, програму по днях, ключові візуали, соціальний доказ і CTA для відправки заявки.", "Use this page for the full retreat offer: location, dates, participation format, day-by-day program, key visuals, social proof, and an application CTA.")</p>
        </div>
        <a href="/retreats/actual" class="btn btn-outline">← @Loc["page.retreat.detail.back"]</a>
    </div>
}
else
{
    var r = retreat!;
    var heroUrl = r.ImageUrl != null
        ? ApiService.ResolveMediaUrl(r.ImageUrl)
        : "https://images.unsplash.com/photo-1545205597-3d9d02c29597?auto=format&fit=crop&w=1600&q=80";
    var durationDays = (r.EndDate - r.StartDate).Days;

    <!-- ====== BREADCRUMB ====== -->
    <nav class="rd2-breadcrumb">
        <div class="container">
            <a href="/retreats/actual">@Loc["page.retreat.detail.back"]</a>
            <span class="rd2-breadcrumb-sep">/</span>
            <span class="rd2-breadcrumb-current">@r.Title</span>
        </div>
    </nav>

    <!-- ====== IMMERSIVE HERO (100vh) ====== -->
    <section class="rd2-hero" style="background-image: url('@heroUrl');">
        <div class="rd2-hero-overlay"></div>
        <div class="container rd2-hero-content">
            <div class="rd2-hero-center">
                <p class="rd2-hero-eyebrow">@Loc["page.retreats.eyebrow"]</p>
                <h1 class="rd2-hero-title">@r.Title</h1>
                @if (!string.IsNullOrWhiteSpace(r.Description))
                {
                    <p class="rd2-hero-subtitle">@Truncate(r.Description, 140)</p>
                }
            </div>
            <div class="rd2-hero-bottom">
                <div class="rd2-hero-pills">
                    <span class="rd2-pill">
                        <span class="rd2-pill-icon"><RetreatMetaSvg Kind="pin" /></span>
                        @r.Location
                    </span>
                    <span class="rd2-pill">
                        <span class="rd2-pill-icon"><RetreatMetaSvg Kind="calendar" /></span>
                        @r.StartDate.ToString("dd MMM yyyy") — @r.EndDate.ToString("dd MMM yyyy")
                    </span>
                    @if (!string.IsNullOrWhiteSpace(r.PriceLabel))
                    {
                        <span class="rd2-pill rd2-pill-price">@r.PriceLabel</span>
                    }
                    @if (IsPast)
                    {
                        <span class="rd2-pill rd2-pill-past">@Loc["page.retreat.past.badge"]</span>
                    }
                </div>
                <div class="rd2-scroll-indicator" aria-hidden="true">
                    <span class="rd2-chevron"></span>
                </div>
            </div>
        </div>
    </section>

    <!-- ====== STICKY BOOKING BAR ====== -->
    @if (!IsPast)
    {
        <div class="rd2-sticky-bar">
            <div class="container rd2-sticky-bar-inner">
                <span class="rd2-sticky-title">@Truncate(r.Title, 50)</span>
                @if (!string.IsNullOrWhiteSpace(r.PriceLabel))
                {
                    <span class="rd2-sticky-price">@r.PriceLabel</span>
                }
                <button type="button" class="btn btn-primary btn-sm" @onclick="OpenModal">@Loc["form.submit"]</button>
            </div>
        </div>
    }

    <!-- ====== QUICK FACTS STRIP ====== -->
    <section class="rd2-facts reveal">
        <div class="container rd2-facts-inner">
            <div class="rd2-fact-item">
                <svg class="rd2-fact-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                <div>
                    <span class="rd2-fact-label">@Loc["rd.facts.duration"]</span>
                    <span class="rd2-fact-value">@durationDays @Loc["rd.facts.days"]</span>
                </div>
            </div>
            <div class="rd2-fact-item">
                <svg class="rd2-fact-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                <div>
                    <span class="rd2-fact-label">@Loc["rd.facts.group"]</span>
                    <span class="rd2-fact-value">@Loc["rd.facts.group_size"]</span>
                </div>
            </div>
            <div class="rd2-fact-item">
                <svg class="rd2-fact-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                <div>
                    <span class="rd2-fact-label">@Loc["rd.facts.level"]</span>
                    <span class="rd2-fact-value">@Loc["rd.facts.level_value"]</span>
                </div>
            </div>
            <div class="rd2-fact-item">
                <svg class="rd2-fact-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10A15.3 15.3 0 0 1 12 2z"/></svg>
                <div>
                    <span class="rd2-fact-label">@Loc["rd.facts.language"]</span>
                    <span class="rd2-fact-value">@Loc["rd.facts.language_value"]</span>
                </div>
            </div>
        </div>
    </section>

    <!-- ====== ABOUT SECTION ====== -->
    <section class="rd2-about reveal">
        <div class="container rd2-about-inner">
            <div class="rd2-about-text">
                <p class="section-eyebrow">@Loc["page.retreat.detail.about_eyebrow"]</p>
                <h2>@Loc["page.retreat.detail.about_h2"]</h2>
                <div class="section-divider" style="margin:1.5rem 0;"></div>
                <div class="rd2-about-prose">
                    @foreach (var block in SplitDescriptionBlocks(r.Description))
                    {
                        <p>@block</p>
                    }
                </div>
                <div class="rd2-for-whom">
                    <h3>@Loc["rd.about.for_whom"]</h3>
                    <ul class="rd2-check-list">
                        <li><span class="rd2-check">✓</span> @Loc["rd.about.whom1"]</li>
                        <li><span class="rd2-check">✓</span> @Loc["rd.about.whom2"]</li>
                        <li><span class="rd2-check">✓</span> @Loc["rd.about.whom3"]</li>
                        <li><span class="rd2-check">✓</span> @Loc["rd.about.whom4"]</li>
                    </ul>
                </div>
            </div>
            <div class="rd2-about-photo">
                <img src="https://images.unsplash.com/photo-1506126279646-a697353d3166?auto=format&fit=crop&w=800&q=80"
                     alt="@Loc["page.retreat.detail.about_eyebrow"]" loading="lazy" />
            </div>
        </div>
    </section>

    <!-- ====== FACILITATOR ====== -->
    <section class="rd2-facilitator reveal">
        <div class="container rd2-facilitator-inner">
            <div class="rd2-facilitator-photo">
                <img src="https://images.unsplash.com/photo-1544367567-0f2fcb009e0b?auto=format&fit=crop&w=400&q=80"
                     alt="Александр Украинцев" loading="lazy" />
            </div>
            <div class="rd2-facilitator-text">
                <p class="section-eyebrow">@Loc["rd.facilitator.eyebrow"]</p>
                <h2>@Loc["rd.facilitator.name"]</h2>
                <p class="rd2-facilitator-role">@Loc["rd.facilitator.role"]</p>
                <div class="section-divider" style="margin:1.25rem 0;"></div>
                <p class="rd2-facilitator-bio">@Loc["rd.facilitator.bio"]</p>
                <blockquote class="rd2-facilitator-quote">
                    <p>@Loc["rd.facilitator.quote"]</p>
                </blockquote>
            </div>
        </div>
    </section>

    <!-- ====== ITINERARY ACCORDION ====== -->
    <section class="rd2-itinerary reveal">
        <div class="container">
            <p class="section-eyebrow">@Loc["page.retreat.detail.program_eyebrow"]</p>
            <h2>@Loc["page.retreat.detail.program_h2"]</h2>
            <div class="section-divider" style="margin:1.5rem 0 2.5rem;"></div>

            @if (!string.IsNullOrWhiteSpace(r.Program))
            {
                <div class="rd2-itinerary-custom">@((MarkupString)r.Program)</div>
            }
            else
            {
                <div class="rd2-itinerary-days">
                    <details class="rd2-day" open>
                        <summary>
                            <span class="rd2-day-chip">@Loc["rd.itinerary.day"] 1</span>
                            <span class="rd2-day-title">@Loc["rd.itinerary.d1.title"]</span>
                            <span class="rd2-day-arrow"></span>
                        </summary>
                        <div class="rd2-day-body">
                            <div class="rd2-timeline-item">
                                <span class="rd2-timeline-time">@Loc["rd.itinerary.afternoon"]</span>
                                <p>@Loc["rd.itinerary.d1.afternoon"]</p>
                            </div>
                            <div class="rd2-timeline-item">
                                <span class="rd2-timeline-time">@Loc["rd.itinerary.evening"]</span>
                                <p>@Loc["rd.itinerary.d1.evening"]</p>
                            </div>
                        </div>
                    </details>

                    <details class="rd2-day">
                        <summary>
                            <span class="rd2-day-chip">@Loc["rd.itinerary.day"] 2–6</span>
                            <span class="rd2-day-title">@Loc["rd.itinerary.d2.title"]</span>
                            <span class="rd2-day-arrow"></span>
                        </summary>
                        <div class="rd2-day-body">
                            <div class="rd2-timeline-item">
                                <span class="rd2-timeline-time">@Loc["rd.itinerary.morning"]</span>
                                <p>@Loc["rd.itinerary.d2.morning"]</p>
                            </div>
                            <div class="rd2-timeline-item">
                                <span class="rd2-timeline-time">@Loc["rd.itinerary.afternoon"]</span>
                                <p>@Loc["rd.itinerary.d2.afternoon"]</p>
                            </div>
                            <div class="rd2-timeline-item">
                                <span class="rd2-timeline-time">@Loc["rd.itinerary.evening"]</span>
                                <p>@Loc["rd.itinerary.d2.evening"]</p>
                            </div>
                        </div>
                    </details>

                    <details class="rd2-day">
                        <summary>
                            <span class="rd2-day-chip">@Loc["rd.itinerary.day"] @durationDays</span>
                            <span class="rd2-day-title">@Loc["rd.itinerary.dlast.title"]</span>
                            <span class="rd2-day-arrow"></span>
                        </summary>
                        <div class="rd2-day-body">
                            <div class="rd2-timeline-item">
                                <span class="rd2-timeline-time">@Loc["rd.itinerary.morning"]</span>
                                <p>@Loc["rd.itinerary.dlast.morning"]</p>
                            </div>
                            <div class="rd2-timeline-item">
                                <span class="rd2-timeline-time">@Loc["rd.itinerary.afternoon"]</span>
                                <p>@Loc["rd.itinerary.dlast.afternoon"]</p>
                            </div>
                        </div>
                    </details>
                </div>
            }
        </div>
    </section>

    <!-- ====== GALLERY (BENTO) ====== -->
    <section class="rd2-gallery reveal">
        <div class="container">
            <p class="section-eyebrow">@Loc["page.retreat.detail.gallery_eyebrow"]</p>
            <h2>@Loc["page.retreat.detail.gallery_h2"]</h2>
            <div class="section-divider" style="margin:1.5rem 0 2.5rem;"></div>
            <div class="rd2-gallery-grid">
                @for (int i = 0; i < GalleryImages.Count; i++)
                {
                    var idx = i;
                    <div class="rd2-gallery-item @(idx == 0 ? "rd2-gallery-featured" : "")" @onclick="() => OpenLightbox(idx)">
                        <img src="@GalleryImages[idx]" alt="@r.Title — @(idx + 1)" loading="lazy" />
                        <div class="rd2-gallery-hover">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="28" height="28"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>

    <!-- ====== LIGHTBOX ====== -->
    @if (showLightbox)
    {
        <div class="rd2-lightbox" @onclick="CloseLightbox">
            <div class="rd2-lightbox-inner" @onclick:stopPropagation="true">
                <button class="rd2-lightbox-close" @onclick="CloseLightbox" aria-label="Close">&times;</button>
                <button class="rd2-lightbox-prev" @onclick="PrevImage" aria-label="Previous">&#8249;</button>
                <img src="@GalleryImages[lightboxIndex]" alt="@r.Title" />
                <button class="rd2-lightbox-next" @onclick="NextImage" aria-label="Next">&#8250;</button>
                <span class="rd2-lightbox-counter">@(lightboxIndex + 1) / @GalleryImages.Count</span>
            </div>
        </div>
    }

    <!-- ====== INCLUDED / NOT INCLUDED ====== -->
    <section class="rd2-inclusions reveal">
        <div class="container">
            <p class="section-eyebrow">@Loc["page.retreat.detail.included_eyebrow"]</p>
            <h2>@Loc["page.retreat.detail.included_h2"]</h2>
            <div class="section-divider" style="margin:1.5rem 0 2.5rem;"></div>
            <div class="rd2-inclusions-grid">
                <div class="rd2-inclusions-col rd2-inclusions-yes">
                    <h3>@Loc["rd.inclusions.included"]</h3>
                    <ul>
                        <li><span class="rd2-incl-icon rd2-incl-yes">✓</span> @Loc["page.retreat.detail.included.1"]</li>
                        <li><span class="rd2-incl-icon rd2-incl-yes">✓</span> @Loc["page.retreat.detail.included.2"]</li>
                        <li><span class="rd2-incl-icon rd2-incl-yes">✓</span> @Loc["page.retreat.detail.included.3"]</li>
                        <li><span class="rd2-incl-icon rd2-incl-yes">✓</span> @Loc["page.retreat.detail.included.4"]</li>
                        <li><span class="rd2-incl-icon rd2-incl-yes">✓</span> @Loc["page.retreat.detail.included.5"]</li>
                        <li><span class="rd2-incl-icon rd2-incl-yes">✓</span> @Loc["page.retreat.detail.included.6"]</li>
                        <li><span class="rd2-incl-icon rd2-incl-yes">✓</span> @Loc["page.retreat.detail.included.7"]</li>
                    </ul>
                </div>
                <div class="rd2-inclusions-col rd2-inclusions-no">
                    <h3>@Loc["rd.inclusions.not_included"]</h3>
                    <ul>
                        <li><span class="rd2-incl-icon rd2-incl-no">✕</span> @Loc["rd.inclusions.not1"]</li>
                        <li><span class="rd2-incl-icon rd2-incl-no">✕</span> @Loc["rd.inclusions.not2"]</li>
                        <li><span class="rd2-incl-icon rd2-incl-no">✕</span> @Loc["rd.inclusions.not3"]</li>
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <!-- ====== ACCOMMODATION ====== -->
    <section class="rd2-accommodation reveal">
        <div class="container rd2-accommodation-inner">
            <div class="rd2-accommodation-photo">
                <img src="https://images.unsplash.com/photo-1571019613454-1cb2f99b2d8b?auto=format&fit=crop&w=800&q=80"
                     alt="@Loc["rd.accommodation.title"]" loading="lazy" />
            </div>
            <div class="rd2-accommodation-text">
                <p class="section-eyebrow">@Loc["rd.accommodation.eyebrow"]</p>
                <h2>@Loc["rd.accommodation.title"]</h2>
                <div class="section-divider" style="margin:1.25rem 0;"></div>
                <p>@Loc["rd.accommodation.text"]</p>
            </div>
        </div>
    </section>

    <!-- ====== REVIEWS CAROUSEL ====== -->
    <section class="rd2-reviews reveal">
        <div class="container">
            <p class="section-eyebrow">@Loc["page.retreat.detail.reviews_eyebrow"]</p>
            <h2>@Loc["page.retreat.detail.reviews_h2"]</h2>
            <div class="section-divider" style="margin:1.5rem 0 2.5rem;"></div>
            <div class="rd2-reviews-track">
                <div class="rd2-review-card">
                    <div class="rd2-review-avatar">ЕМ</div>
                    <div class="rd2-review-stars">★★★★★</div>
                    <p class="rd2-review-quote">@Loc["rd.reviews.r1.text"]</p>
                    <p class="rd2-review-author">@Loc["rd.reviews.r1.author"]</p>
                </div>
                <div class="rd2-review-card">
                    <div class="rd2-review-avatar">ИВ</div>
                    <div class="rd2-review-stars">★★★★★</div>
                    <p class="rd2-review-quote">@Loc["rd.reviews.r2.text"]</p>
                    <p class="rd2-review-author">@Loc["rd.reviews.r2.author"]</p>
                </div>
                <div class="rd2-review-card">
                    <div class="rd2-review-avatar">ДК</div>
                    <div class="rd2-review-stars">★★★★★</div>
                    <p class="rd2-review-quote">@Loc["rd.reviews.r3.text"]</p>
                    <p class="rd2-review-author">@Loc["rd.reviews.r3.author"]</p>
                </div>
                <div class="rd2-review-card">
                    <div class="rd2-review-avatar">АС</div>
                    <div class="rd2-review-stars">★★★★★</div>
                    <p class="rd2-review-quote">@Loc["rd.reviews.r4.text"]</p>
                    <p class="rd2-review-author">@Loc["rd.reviews.r4.author"]</p>
                </div>
            </div>
        </div>
    </section>

    <!-- ====== FAQ ACCORDION ====== -->
    <section class="rd2-faq reveal">
        <div class="container">
            <p class="section-eyebrow">@Loc["rd.faq.eyebrow"]</p>
            <h2>@Loc["rd.faq.title"]</h2>
            <div class="section-divider" style="margin:1.5rem 0 2.5rem;"></div>
            <div class="rd2-faq-list">
                <details class="rd2-faq-item">
                    <summary>@Loc["rd.faq.q1"]</summary>
                    <p>@Loc["rd.faq.a1"]</p>
                </details>
                <details class="rd2-faq-item">
                    <summary>@Loc["rd.faq.q2"]</summary>
                    <p>@Loc["rd.faq.a2"]</p>
                </details>
                <details class="rd2-faq-item">
                    <summary>@Loc["rd.faq.q3"]</summary>
                    <p>@Loc["rd.faq.a3"]</p>
                </details>
                <details class="rd2-faq-item">
                    <summary>@Loc["rd.faq.q4"]</summary>
                    <p>@Loc["rd.faq.a4"]</p>
                </details>
                <details class="rd2-faq-item">
                    <summary>@Loc["rd.faq.q5"]</summary>
                    <p>@Loc["rd.faq.a5"]</p>
                </details>
                <details class="rd2-faq-item">
                    <summary>@Loc["rd.faq.q6"]</summary>
                    <p>@Loc["rd.faq.a6"]</p>
                </details>
            </div>
        </div>
    </section>

    <!-- ====== RELATED BLOG ====== -->
    <RelatedBlog EntityId="retreat?.Id" Section="retreats" />

    <!-- ====== OTHER RETREATS ====== -->
    @if (otherRetreats.Any())
    {
        <section class="rd2-others reveal">
            <div class="container">
                <p class="section-eyebrow">@Loc["page.retreat.detail.other_eyebrow"]</p>
                <h2>@Loc["page.retreat.detail.other_h2"]</h2>
                <div class="section-divider" style="margin:1.5rem 0 2.5rem;"></div>
                <div class="rd2-others-grid">
                    @foreach (var other in otherRetreats)
                    {
                        var o = other;
                        <a href="@RetreatUrls.DetailPath(o)" class="rd2-other-card reveal">
                            <div class="rd2-other-img">
                                <img src="@(o.ImageUrl != null ? ApiService.ResolveMediaUrl(o.ImageUrl) : "https://images.unsplash.com/photo-1506905925346-21bda4d32df4?auto=format&fit=crop&w=600&q=80")"
                                     alt="@o.Title" loading="lazy" />
                            </div>
                            <div class="rd2-other-body">
                                <h4>@o.Title</h4>
                                <p class="rd2-other-meta">
                                    <span class="rd2-other-meta-icon"><RetreatMetaSvg Kind="pin" /></span>
                                    @o.Location
                                </p>
                                <p class="rd2-other-meta">
                                    <span class="rd2-other-meta-icon"><RetreatMetaSvg Kind="calendar" /></span>
                                    @o.StartDate.ToString("dd MMM yyyy") — @o.EndDate.ToString("dd MMM yyyy")
                                </p>
                                @if (!string.IsNullOrWhiteSpace(o.PriceLabel))
                                {
                                    <span class="rd2-other-price">@o.PriceLabel</span>
                                }
                                <span class="rd2-other-cta">@Loc["page.retreat.detail.other_cta"] →</span>
                            </div>
                        </a>
                    }
                </div>
            </div>
        </section>
    }

    <!-- ====== CTA FOOTER ====== -->
    @if (!IsPast)
    {
        <section class="rd2-cta-footer" style="background-image: url('@heroUrl');">
            <div class="rd2-cta-footer-overlay"></div>
            <div class="container rd2-cta-footer-content">
                <h2>@Loc["rd.cta.heading"]</h2>
                <p>@Loc["rd.cta.subheading"]</p>
                <button type="button" class="btn btn-primary btn-lg" @onclick="OpenModal">@Loc["form.submit"]</button>
            </div>
        </section>
    }

    <!-- ====== MOBILE FIXED CTA ====== -->
    @if (!IsPast)
    {
        <div class="rd2-mobile-cta">
            <button type="button" class="btn btn-primary" @onclick="OpenModal">@Loc["form.submit"]</button>
        </div>
    }
}


