    private List<RetreatDto> otherRetreats = new();
    private Guid _loadedForId;
    private string? _loadedForSlug;

    private bool showLightbox;
    private int lightboxIndex;

    private bool IsPast => retreat?.EndDate.ToUniversalTime() < DateTime.UtcNow;

    private List<string> GalleryImages => new()
    {
        retreat?.ImageUrl != null ? ApiService.ResolveMediaUrl(retreat.ImageUrl) : "https://images.unsplash.com/photo-1545205597-3d9d02c29597?auto=format&fit=crop&w=800&q=80",
