    private async void Refresh()
    {
        _loadedForSlug = null;
        _loadedForId = Guid.Empty;
        await LoadData();
        await InvokeAsync(StateHasChanged);
    }

    private void OpenModal()
    {
        var parameters = new Dictionary<string, object>();
        parameters["ContextTitle"] = retreat?.Title ?? "Ретрит";
        if (retreat != null)
        {
            parameters["TargetRetreatId"] = retreat.Id;
        }
        ModalService.Show<LeadModal>(parameters);
    }

    private void OpenLightbox(int index)
    {
        lightboxIndex = index;
        showLightbox = true;
    }

    private void CloseLightbox() => showLightbox = false;

    private void NextImage() =>
        lightboxIndex = (lightboxIndex + 1) % GalleryImages.Count;

    private void PrevImage() =>
        lightboxIndex = (lightboxIndex - 1 + GalleryImages.Count) % GalleryImages.Count;

    private string P(string ru, string uk, string en) => Loc.CurrentLang switch
    {
        "uk" => uk,
        "en" => en,
        _ => ru
    };

    public void Dispose() => Loc.OnLanguageChanged -= Refresh;

    private static string Truncate(string? s, int max) =>
        string.IsNullOrEmpty(s) ? "" : s.Length <= max ? s : s[..max] + "…";

    private static IEnumerable<string> SplitDescriptionBlocks(string? description)
    {
        if (string.IsNullOrWhiteSpace(description))
            yield break;
        var parts = description.Split(new[] { "\r\n\r\n", "\n\n" }, StringSplitOptions.RemoveEmptyEntries);
        foreach (var p in parts)
        {
            var t = p.Trim();
            if (t.Length > 0)
                yield return t;
        }
    }
