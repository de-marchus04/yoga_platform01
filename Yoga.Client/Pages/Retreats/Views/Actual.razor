@page "/retreats/actual"
@inject LocalizationService Loc
@inject Yoga.Client.Services.ApiService ApiService
@implements IDisposable

<PageTitle>@Loc["page.retreats.actual.title"]</PageTitle>

<section class="page-hero">
    <div class="page-hero-bg" style="background-image: url('@F("ActualImageUrl", F("HeroImageUrl", "https://images.unsplash.com/photo-1545205597-3d9d02c29597?auto=format&fit=crop&w=1600&q=80"))');"></div>
    <div class="page-hero-overlay"></div>
    <div class="container page-hero-content">
        <p class="section-eyebrow" style="color:var(--accent);">@F("Eyebrow", Loc["page.retreats.eyebrow"])</p>
        <h1>@F("ActualH1", Loc["page.retreats.actual.h1"])</h1>
        <div class="section-divider" style="margin:2rem 0;"></div>
        <p>@F("ActualIntro", Loc["page.retreats.actual.intro"])</p>
    </div>
</section>

<section class="retreats-section">
    <div class="container">
        @if (retreats == null)
        {
            <p style="text-align:center; padding:4rem 0; color:var(--text-muted); letter-spacing:2px; font-size:0.8rem; text-transform:uppercase;"><em>@Loc["page.home.retreats.loading"]</em></p>
        }
        else if (!retreats.Any())
        {
            <div class="empty-state">
                <p>Актуальные ретриты очищены для нового наполнения. Сюда нужно добавить текущие поездки с датами, местом проведения, описанием программы, изображением и CTA для заявки.</p>
            </div>
        }
        else
        {
            <div class="retreats-grid">
                @foreach (var retreat in retreats)
                {
                    <RetreatCard Retreat="@retreat"
                                 IsPast="false"
                                 DetailText="@Loc["page.retreat.card.detail"]"
                                 CtaText="@F("CardCta", Loc["page.retreats.card.cta"])"
                                 HasCta="true"
                                 OnCtaClick="OpenModal" />
                }
            </div>
        }
    </div>
</section>



@code {
    private List<Yoga.Shared.DTOs.RetreatDto>? retreats;
    private SitePageDto? pageData;

    protected override async Task OnInitializedAsync()
    {
        Loc.OnLanguageChanged += Refresh;
        await Task.WhenAll(LoadData(), LoadPage());
    }

    private async Task LoadPage()
    {
        try { pageData = await ApiService.GetSitePageAsync("retreats", Loc.CurrentLang); }
        catch { pageData = null; }
    }

    private string F(string field, string fallback = "")
    {
        var val = pageData?.Fields != null && pageData.Fields.TryGetValue(field, out var v) && !string.IsNullOrEmpty(v) ? v : fallback;
        return field.Contains("Image", StringComparison.OrdinalIgnoreCase) ? ApiService.ResolveMediaUrl(val) : val;
    }

    private async Task LoadData()
    {
        try { retreats = await CatalogState.GetActiveRetreatsAsync(Loc.CurrentLang); }
        catch { retreats = new(); }
    }

    private async void Refresh()
    {
        await Task.WhenAll(LoadData(), LoadPage());
        await InvokeAsync(StateHasChanged);
    }

    private void OpenModal(string title) 
    {
        ModalService.Show<LeadModal>(new Dictionary<string, object>
        {
            { "ContextTitle", title }
        });
    }
    public void Dispose() => Loc.OnLanguageChanged -= Refresh;
}
