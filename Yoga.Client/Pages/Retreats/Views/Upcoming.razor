@page "/retreats/upcoming"
@inject LocalizationService Loc
@inject Yoga.Client.Services.ApiService ApiService
@implements IDisposable

<PageTitle>@Loc["page.retreats.upcoming.title"]</PageTitle>

<section class="page-hero">
    <div class="page-hero-bg" style="background-image: url('@F("UpcomingImageUrl", F("HeroImageUrl", "https://images.unsplash.com/photo-1506126613408-eca07ce68773?auto=format&fit=crop&w=1600&q=80"))');"></div>
    <div class="page-hero-overlay"></div>
    <div class="container page-hero-content">
        <p class="section-eyebrow" style="color:var(--accent);">@F("Eyebrow", Loc["page.retreats.eyebrow"])</p>
        <h1>@F("UpcomingH1", Loc["page.retreats.upcoming.h1"])</h1>
        <div class="section-divider" style="margin:2rem 0;"></div>
        <p>@F("UpcomingIntro", Loc["page.retreats.upcoming.intro"])</p>
    </div>
</section>

<section class="retreats-section">
    <div class="container">
        @if (retreats == null)
        {
            <p style="text-align:center; padding:4rem 0; color:var(--text-muted); letter-spacing:2px; font-size:0.8rem; text-transform:uppercase;"><em>@Loc["page.home.retreats.loading"]</em></p>
        }
        else if (!retreats.Any())
        {
            <div class="empty-state">
                <p>Будущие ретриты пока не заполнены. Сюда нужно добавить анонсы следующих программ, чтобы пользователь видел план ближайших запусков и мог заранее оставить заявку.</p>
            </div>
        }
        else
        {
            <div class="retreats-grid">
                @foreach (var retreat in retreats)
                {
                    <div class="retreat-card reveal">
                        <div class="card-img-wrapper">
                            <img src="https://images.unsplash.com/photo-1545205597-3d9d02c29597?auto=format&fit=crop&w=600&q=80" alt="@retreat.Title" class="card-img" loading="lazy" decoding="async" />
                        </div>
                        <div class="card-content">
                            <h3>@retreat.Title</h3>
                            <p class="location">📍 @retreat.Location</p>
                            <p class="dates">🗓 @retreat.StartDate.ToString("dd MMM yyyy") — @retreat.EndDate.ToString("dd MMM yyyy")</p>
                            <p class="description">@retreat.Description</p>
                            <div class="retreat-card-actions">
                                <a href="/retreats/@retreat.Id" class="btn btn-outline" style="width:100%; text-align:center;">@Loc["page.retreat.card.detail"]</a>
                                <button class="btn btn-outline btn-sm" style="width:100%;" @onclick="() => OpenModal(retreat.Title)">@F("CardCta", Loc["page.retreats.card.cta"])</button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</section>



@code {
    private List<Yoga.Shared.DTOs.RetreatDto>? retreats;
    private SitePageDto? pageData;

    protected override async Task OnInitializedAsync()
    {
        Loc.OnLanguageChanged += Refresh;
        await Task.WhenAll(LoadData(), LoadPage());
    }

    private async Task LoadPage()
    {
        try { pageData = await ApiService.GetSitePageAsync("retreats", Loc.CurrentLang); }
        catch { pageData = null; }
    }

    private string F(string field, string fallback = "")
    {
        if (pageData?.Fields != null && pageData.Fields.TryGetValue(field, out var val) && !string.IsNullOrEmpty(val))
            return val;
        return fallback;
    }

    private async Task LoadData()
    {
        try { retreats = await CatalogState.GetUpcomingRetreatsAsync(Loc.CurrentLang); }
        catch { retreats = new(); }
    }

    private async void Refresh()
    {
        await Task.WhenAll(LoadData(), LoadPage());
        await InvokeAsync(StateHasChanged);
    }

    private void OpenModal(string title) 
    {
        ModalService.Show<LeadModal>(new Dictionary<string, object>
        {
            { "ContextTitle", title }
        });
    }
    public void Dispose() => Loc.OnLanguageChanged -= Refresh;
}
