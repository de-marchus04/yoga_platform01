@page "/retreats"
@inject LocalizationService Loc
@inject ApiService Api
@implements IDisposable

<PageTitle>@Loc["page.retreats.title"]</PageTitle>

<div class="arc-expedition">
    @* ── Hero: panoramic travel opening ── *@
    <section class="arc-expedition__hero">
        <div class="container arc-expedition__hero-inner">
            <p class="section-eyebrow">@Loc["page.retreats.eyebrow"]</p>
            <h1>@Loc["page.retreats.h1"]</h1>
            <div class="section-divider"></div>
            <p class="arc-expedition__hero-intro">@Loc["page.retreats.intro"]</p>
        </div>
    </section>

    @* ── Catalog: expedition posters ── *@
    <section class="arc-expedition__catalog">
        <div class="container">
            @if (items is null)
            {
                <div class="arc-expedition__skeleton">
                    @for (var i = 0; i < 2; i++)
                    {
                        <div class="arc-expedition__skeleton-card"></div>
                    }
                </div>
            }
            else if (items.Count == 0)
            {
                <p class="arc-expedition__empty">@Loc["page.retreats.empty"]</p>
            }
            else
            {
                <div class="arc-expedition__posters">
                    @foreach (var item in items)
                    {
                        <a class="arc-expedition__poster" href="/retreats/@item.Slug">
                            <div class="arc-expedition__poster-image">
                                @if (!string.IsNullOrEmpty(item.ImageUrl))
                                {
                                    <img src="@Api.ResolveMediaUrl(item.ImageUrl)" alt="@item.Title" loading="lazy" />
                                }
                                <span class="arc-expedition__poster-stamp">@Loc["retreats.status.upcoming"]</span>
                            </div>
                            <div class="arc-expedition__poster-body">
                                @if (!string.IsNullOrEmpty(item.Eyebrow))
                                {
                                    <span class="arc-expedition__poster-eyebrow">@item.Eyebrow</span>
                                }
                                <h3>@item.Title</h3>
                                <p class="arc-expedition__poster-sub">@item.Subtitle</p>
                                <div class="arc-expedition__poster-meta">
                                    @if (!string.IsNullOrEmpty(item.Location))
                                    {
                                        <span>@Loc["meta.location"]: @item.Location</span>
                                    }
                                    @if (!string.IsNullOrEmpty(item.Duration))
                                    {
                                        <span>@Loc["meta.duration"]: @item.Duration</span>
                                    }
                                    @if (!string.IsNullOrEmpty(item.Format))
                                    {
                                        <span>@Loc["meta.format"]: @item.Format</span>
                                    }
                                </div>
                                <span class="arc-expedition__poster-cta">@Loc["page.retreats.card.cta"]</span>
                            </div>
                        </a>
                    }
                </div>
            }
        </div>
    </section>
</div>

@code {
    private List<Yoga.Shared.DTOs.RetreatDto>? items;

    protected override async Task OnInitializedAsync()
    {
        Loc.OnLanguageChanged += Reload;
        await LoadAsync();
    }

    private async void Reload()
    {
        await LoadAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadAsync()
    {
        items = await Api.GetRetreatsAsync(Loc.CurrentLang);
    }

    public void Dispose() => Loc.OnLanguageChanged -= Reload;
}
