@page "/retreats"
@inject LocalizationService Loc
@inject ApiService Api
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>@Loc["page.retreats.title"]</PageTitle>

@if (currentPeriod == "past")
{
    <Yoga.Client.Pages.Retreats.Views.Past Items="items" />
}
else
{
    <Yoga.Client.Pages.Retreats.Views.Upcoming Items="items" />
}

@code {
    private List<Yoga.Shared.DTOs.RetreatDto>? items;
    private string currentPeriod = "upcoming";

    protected override async Task OnInitializedAsync()
    {
        Loc.OnLanguageChanged += Reload;
        Nav.LocationChanged += OnLocationChanged;
        ParsePeriod();
        await LoadAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        var prev = currentPeriod;
        ParsePeriod();
        if (prev != currentPeriod) await LoadAsync();
    }

    private void ParsePeriod()
    {
        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        currentPeriod = string.Equals(query["period"], "past", StringComparison.OrdinalIgnoreCase) ? "past" : "upcoming";
    }

    private async Task LoadAsync()
    {
        items = null;
        StateHasChanged();
        items = await Api.GetRetreatsAsync(Loc.CurrentLang, currentPeriod);
        StateHasChanged();
    }

    private async void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        var prev = currentPeriod;
        ParsePeriod();
        if (prev != currentPeriod)
        {
            await LoadAsync();
            await InvokeAsync(StateHasChanged);
        }
    }

    private async void Reload()
    {
        await LoadAsync();
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Loc.OnLanguageChanged -= Reload;
        Nav.LocationChanged -= OnLocationChanged;
    }
}
