@page "/account/login"
@inject UserAuthService Auth
@inject NavigationManager Nav

<PageTitle>Личный кабинет — Вход</PageTitle>

<section class="auth-section">
    <div class="auth-card">
        <div class="auth-eyebrow">Личный кабинет</div>
        <h1>Войти</h1>
        <div class="auth-divider"></div>

        @if (!string.IsNullOrEmpty(error))
        {
            <div class="auth-error">@error</div>
        }

        <div class="auth-field">
            <label class="auth-label" for="login-email">Email</label>
            <input id="login-email" type="email" @bind="email" class="auth-input" placeholder="your@email.com" autocomplete="email" />
        </div>
        <div class="auth-field">
            <label class="auth-label" for="login-password">Пароль</label>
            <input id="login-password" type="password" @bind="password" class="auth-input" autocomplete="current-password" />
        </div>
        <button class="auth-submit" @onclick="HandleLogin" disabled="@loading">
            @(loading ? "Вход..." : "Войти")
        </button>
    </div>
</section>

@code {
    private string email = "";
    private string password = "";
    private string? error;
    private bool loading;

    private async Task HandleLogin()
    {
        loading = true;
        error = null;
        var (success, err) = await Auth.LoginAsync(email, password);
        if (success) Nav.NavigateTo("/account");
        else error = err ?? "Ошибка входа";
        loading = false;
    }
}
