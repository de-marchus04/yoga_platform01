@page "/account/login"
@inject UserAuthService Auth
@inject NavigationManager Nav
@inject LocalizationService Loc

<PageTitle>@Loc["auth.page_title"]</PageTitle>

<section class="auth-section">
    <div class="auth-visual">
        <div class="auth-visual-overlay"></div>
        <div class="auth-visual-content">
            <span class="brand-lockup auth-brand">
                <span class="brand-mark" aria-hidden="true">
                    <svg viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg" focusable="false">
                        <circle cx="32" cy="32" r="28.5" />
                        <path d="M32 13.5c4.9 6.2 7.4 11.9 7.4 17.1 0 6.1-2.5 11.1-7.4 15.2-4.9-4.1-7.4-9.1-7.4-15.2 0-5.2 2.5-10.9 7.4-17.1Z" />
                        <path d="M24.2 24.1c-6 1.2-10.1 4.7-12.5 10.5 6.8.3 12.2 2.8 16.3 7.6" />
                        <path d="M39.8 24.1c6 1.2 10.1 4.7 12.5 10.5-6.8.3-12.2 2.8-16.3 7.6" />
                        <path d="M20.2 33.2c-4.6 1.1-7.9 4-9.8 8.6 5.4.1 9.8 1.9 13.1 5.3" />
                        <path d="M43.8 33.2c4.6 1.1 7.9 4 9.8 8.6-5.4.1-9.8 1.9-13.1 5.3" />
                        <path d="M21.4 49.6c3.3-2.9 6.9-4.3 10.6-4.3 3.8 0 7.3 1.4 10.6 4.3" />
                        <path d="M28.8 54.2c.9-2.3 2-3.9 3.2-4.8 1.2.9 2.3 2.5 3.2 4.8" />
                        <path d="M32 22.1c1.7 1.4 2.5 3.2 2.5 5.3S33.7 31.3 32 32.7c-1.7-1.4-2.5-3.2-2.5-5.3s.8-3.9 2.5-5.3Z" />
                    </svg>
                </span>
                <span class="brand-wordmark">
                    <span class="brand-prefix">sha</span><span class="brand-rest">kti.ashram</span>
                </span>
            </span>
            <p class="auth-visual-tagline">@Loc["auth.visual_tagline"]</p>
        </div>
    </div>

    <div class="auth-form-panel">
        <div class="auth-card">
            <div class="auth-eyebrow">@Loc["auth.eyebrow"]</div>
            <h1>@Loc["auth.heading"]</h1>
            <div class="auth-divider"></div>

            @if (!string.IsNullOrEmpty(error))
            {
                <div class="auth-error">@error</div>
            }

            <div class="auth-field">
                <label class="auth-label" for="login-email">@Loc["auth.email"]</label>
                <input id="login-email" type="email" @bind="email" class="auth-input" placeholder="your@email.com" autocomplete="email" />
            </div>
            <div class="auth-field">
                <label class="auth-label" for="login-password">@Loc["auth.password"]</label>
                <input id="login-password" type="password" @bind="password" class="auth-input" autocomplete="current-password" />
            </div>
            <button class="auth-submit" @onclick="HandleLogin" disabled="@loading">
                @(loading ? Loc["auth.loading"] : Loc["auth.submit"])
            </button>
        </div>
    </div>
</section>

@code {
    private string email = "";
    private string password = "";
    private string? error;
    private bool loading;

    private async Task HandleLogin()
    {
        loading = true;
        error = null;
        var (success, err) = await Auth.LoginAsync(email, password);
        if (success) Nav.NavigateTo("/account");
        else error = err ?? Loc["auth.error"];
        loading = false;
    }
}
