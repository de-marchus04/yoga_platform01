@page "/account/leads"
@layout CabinetLayout
@inject UserApiService Api

<PageTitle>История заявок</PageTitle>

<div class="cab-page-header">
    <h1 class="cab-page-title">История заявок</h1>
    <p class="cab-page-subtitle">Все обращения, которые вы оставили на сайте</p>
</div>

@if (loading)
{
    <div class="cab-skeleton" style="height:300px; border-radius:12px;"></div>
}
else if (leads.Count == 0)
{
    <div class="cab-empty">
        <div class="cab-empty-icon">📋</div>
        <p>У вас пока нет заявок</p>
        <p class="cab-empty-sub">Оставьте заявку на сайте и она появится здесь</p>
    </div>
}
else
{
    <div class="cab-table-wrap">
        <table class="cab-table">
            <thead>
                <tr>
                    <th>Дата</th>
                    <th>Имя</th>
                    <th>Статус</th>
                    <th>Комментарий</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var l in leads)
                {
                    <tr>
                        <td>@l.CreatedAt.ToString("dd.MM.yyyy")</td>
                        <td>@l.Name</td>
                        <td>
                            <span class="cab-status @StatusClass(l.Status)">@l.Status</span>
                        </td>
                        <td>@(l.Comment ?? "—")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private List<LeadSummaryDto> leads = new();
    private bool loading = true;

    protected override async Task OnInitializedAsync()
    {
        leads = await Api.GetMyLeadsAsync();
        loading = false;
    }

    private string StatusClass(string status) => status switch
    {
        "Успешно" => "active",
        "Отказ" => "expired",
        "В работе" => "pending",
        _ => ""
    };
}
