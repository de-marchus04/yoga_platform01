@page "/account"
@layout CabinetLayout
@inject UserApiService Api
@inject UserAuthService Auth
@inject NavigationManager Nav

<PageTitle>Личный кабинет</PageTitle>

<div class="cab-page-header">
    <h1 class="cab-page-title">Личный кабинет</h1>
</div>

@if (loading)
{
    <div class="cab-dash-grid">
        @for (int i = 0; i < 5; i++)
        {
            <div class="cab-stat-card cab-skeleton" style="min-height:120px"></div>
        }
    </div>
}
else if (dashboard != null)
{
    <div class="cab-welcome">
        <div class="cab-welcome-text">
            <h2>Добро пожаловать, @FirstName() 🙏</h2>
            <p>Здесь собрано всё, что нужно для вашей практики</p>
        </div>
        @if (dashboard.Subscription != null)
        {
            <span class="cab-tier-badge @dashboard.Subscription.Tier.ToLower()">@dashboard.Subscription.Tier</span>
        }
    </div>

    <div class="cab-dash-grid">
        <a href="/account/products" class="cab-stat-card">
            <div class="cab-stat-icon">🎓</div>
            <div class="cab-stat-value">@dashboard.ActiveGrants.Count</div>
            <div class="cab-stat-label">Активных продуктов</div>
        </a>

        <a href="/account/library" class="cab-stat-card">
            <div class="cab-stat-icon">📚</div>
            <div class="cab-stat-label">Библиотека материалов</div>
            <div class="cab-stat-cta">Открыть →</div>
        </a>

        <a href="/account/streams" class="cab-stat-card">
            <div class="cab-stat-icon">🎬</div>
            <div class="cab-stat-value">@dashboard.UpcomingEvents.Count</div>
            <div class="cab-stat-label">Предстоящих трансляций</div>
        </a>

        @if (dashboard.Subscription != null)
        {
            <div class="cab-stat-card cab-stat-card--sub">
                <div class="cab-stat-icon">✨</div>
                <div class="cab-stat-value">@dashboard.Subscription.Tier</div>
                <div class="cab-stat-label">
                    @if (dashboard.Subscription.EndsAt.HasValue)
                    {
                        var days = (int)(dashboard.Subscription.EndsAt.Value - DateTime.UtcNow).TotalDays;
                        <span>Осталось @days @DaysWord(days)</span>
                    }
                    else
                    {
                        <span>Бессрочная подписка</span>
                    }
                </div>
            </div>
        }

        @if (NextEvent() is { } ev)
        {
            <a href="/account/streams" class="cab-stat-card cab-stat-card--event">
                <div class="cab-stat-icon">⏰</div>
                <div class="cab-stat-value" style="font-size:1rem; font-family: var(--cab-font-sans); font-weight:500;">@ev.Title</div>
                <div class="cab-stat-label">@ev.StartsAt.ToString("dd MMM, HH:mm") — через @DaysToEvent(ev.StartsAt)</div>
            </a>
        }

        <a href="/account/leads" class="cab-stat-card">
            <div class="cab-stat-icon">📋</div>
            <div class="cab-stat-value">@dashboard.TotalLeads</div>
            <div class="cab-stat-label">Всего заявок</div>
        </a>
    </div>
}
else
{
    <div class="cab-empty">
        <p>Не удалось загрузить данные. Попробуйте обновить страницу.</p>
    </div>
}

@code {
    private MyDashboardDto? dashboard;
    private bool loading = true;

    protected override async Task OnInitializedAsync()
    {
        var token = await Auth.GetTokenAsync();
        if (string.IsNullOrEmpty(token))
        {
            Nav.NavigateTo("/account/login");
            return;
        }
        dashboard = await Api.GetDashboardAsync();
        loading = false;
    }

    private string FirstName()
    {
        var name = dashboard?.Profile.FullName ?? "";
        return name.Split(' ')[0];
    }

    private LiveEventDto? NextEvent()
    {
        if (dashboard?.UpcomingEvents is not { Count: > 0 } events) return null;
        return events
            .Where(e => e.StartsAt > DateTime.UtcNow)
            .OrderBy(e => e.StartsAt)
            .FirstOrDefault();
    }

    private string DaysToEvent(DateTime dt)
    {
        var days = (int)(dt - DateTime.UtcNow).TotalDays;
        if (days == 0) return "сегодня";
        if (days == 1) return "1 день";
        return $"{days} {DaysWord(days)}";
    }

    private string DaysWord(int n)
    {
        int mod = n % 100;
        if (mod >= 11 && mod <= 19) return "дней";
        return (n % 10) switch { 1 => "день", 2 or 3 or 4 => "дня", _ => "дней" };
    }
}
