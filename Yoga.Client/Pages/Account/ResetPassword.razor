@page "/reset-password"
@inject UserApiService Api
@inject NavigationManager Nav

<PageTitle>Новый пароль</PageTitle>

<section class="auth-section">
    <div class="auth-visual">
        <div class="auth-visual-overlay"></div>
        <div class="auth-visual-content">
            <span class="brand-lockup auth-brand">
                <span class="brand-mark" aria-hidden="true">
                    <svg viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg" focusable="false">
                        <circle cx="32" cy="32" r="28.5" />
                        <path d="M32 13.5c4.9 6.2 7.4 11.9 7.4 17.1 0 6.1-2.5 11.1-7.4 15.2-4.9-4.1-7.4-9.1-7.4-15.2 0-5.2 2.5-10.9 7.4-17.1Z" />
                        <path d="M24.2 24.1c-6 1.2-10.1 4.7-12.5 10.5 6.8.3 12.2 2.8 16.3 7.6" />
                        <path d="M39.8 24.1c6 1.2 10.1 4.7 12.5 10.5-6.8.3-12.2 2.8-16.3 7.6" />
                        <path d="M21.4 49.6c3.3-2.9 6.9-4.3 10.6-4.3 3.8 0 7.3 1.4 10.6 4.3" />
                        <path d="M32 22.1c1.7 1.4 2.5 3.2 2.5 5.3S33.7 31.3 32 32.7c-1.7-1.4-2.5-3.2-2.5-5.3s.8-3.9 2.5-5.3Z" />
                    </svg>
                </span>
                <span class="brand-wordmark">
                    <span class="brand-prefix">sha</span><span class="brand-rest">kti.ashram</span>
                </span>
            </span>
        </div>
    </div>

    <div class="auth-form-panel">
        <div class="auth-card">
            @if (success)
            {
                <div class="auth-eyebrow">✅</div>
                <h1>Пароль обновлён</h1>
                <div class="auth-divider"></div>
                <p style="color:var(--auth-muted,#aaa);font-size:0.95rem;line-height:1.6">
                    Теперь вы можете войти с новым паролем.
                </p>
                <a href="/account/login" class="auth-submit" style="text-align:center;text-decoration:none;display:block;margin-top:1.5rem">
                    Войти
                </a>
            }
            else
            {
                <div class="auth-eyebrow">Новый пароль</div>
                <h1>Сброс пароля</h1>
                <div class="auth-divider"></div>

                @if (!string.IsNullOrEmpty(error))
                {
                    <div class="auth-error">@error</div>
                }

                <div class="auth-field">
                    <label class="auth-label" for="rp-password">Новый пароль</label>
                    <input id="rp-password" type="password" @bind="newPassword" class="auth-input" placeholder="Минимум 8 символов" autocomplete="new-password" />
                </div>
                <div class="auth-field">
                    <label class="auth-label" for="rp-confirm">Повторите пароль</label>
                    <input id="rp-confirm" type="password" @bind="confirmPassword" class="auth-input" autocomplete="new-password" />
                </div>
                <button class="auth-submit" @onclick="HandleReset" disabled="@loading">
                    @(loading ? "Сохранение..." : "Установить пароль")
                </button>
            }
        </div>
    </div>
</section>

@code {
    private string newPassword = "";
    private string confirmPassword = "";
    private string? error;
    private bool loading;
    private bool success;
    private string? token;

    protected override void OnInitialized()
    {
        var uri = new Uri(Nav.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        token = query["token"];
        if (string.IsNullOrEmpty(token))
            error = "Недействительная ссылка для сброса пароля";
    }

    private async Task HandleReset()
    {
        if (string.IsNullOrEmpty(token)) { error = "Недействительная ссылка"; return; }
        if (newPassword.Length < 8) { error = "Пароль должен быть не менее 8 символов"; return; }
        if (newPassword != confirmPassword) { error = "Пароли не совпадают"; return; }

        loading = true;
        error = null;
        var (ok, err) = await Api.ResetPasswordAsync(token, newPassword);
        if (ok) success = true;
        else error = err;
        loading = false;
    }
}
