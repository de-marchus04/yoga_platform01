@page "/account/course/{CourseId:guid}/lesson/{LessonId:guid}"
@layout CabinetLayout
@inject UserApiService Api
@inject NavigationManager Nav

<PageTitle>@(lesson?.Title ?? "Урок")</PageTitle>

@if (loading)
{
    <div class="cab-page-header">
        <div class="cab-skeleton" style="height:18px;width:30%;margin-bottom:12px"></div>
        <div class="cab-skeleton" style="height:32px;width:70%;margin-bottom:8px"></div>
    </div>
    <div class="cab-skeleton" style="height:400px;border-radius:8px"></div>
}
else if (lesson == null)
{
    <div class="cab-empty">
        <div class="cab-empty-icon">📄</div>
        <p>Урок не найден</p>
        <a href="/account/products" class="cab-link-accent">← К моим продуктам</a>
    </div>
}
else
{
    <div class="cab-page-header">
        <a href="/account/course/@CourseId" class="cab-back-link">← @(course?.Title ?? "Курс")</a>
        <h1 class="cab-page-title">@lesson.Title</h1>
        @if (moduleName != null)
        {
            <p class="cab-page-subtitle">@moduleName</p>
        }
    </div>

    <div class="lesson-content">
        @if (!string.IsNullOrEmpty(lesson.Theory))
        {
            <section class="lesson-section">
                <h2 class="lesson-section-title">Теория</h2>
                <div class="lesson-text">@((MarkupString)lesson.Theory)</div>
            </section>
        }
        @if (!string.IsNullOrEmpty(lesson.Practice))
        {
            <section class="lesson-section">
                <h2 class="lesson-section-title">Практика</h2>
                <div class="lesson-text">@((MarkupString)lesson.Practice)</div>
            </section>
        }
        @if (!string.IsNullOrEmpty(lesson.Assignment))
        {
            <section class="lesson-section">
                <h2 class="lesson-section-title">Задание</h2>
                <div class="lesson-text">@((MarkupString)lesson.Assignment)</div>
            </section>
        }
    </div>

    <div class="lesson-nav">
        @if (prevLesson != null)
        {
            <a href="/account/course/@CourseId/lesson/@prevLesson.Id" class="lesson-nav-btn prev">
                ← @prevLesson.Title
            </a>
        }
        else
        {
            <span></span>
        }
        @if (nextLesson != null)
        {
            <a href="/account/course/@CourseId/lesson/@nextLesson.Id" class="lesson-nav-btn next">
                @nextLesson.Title →
            </a>
        }
    </div>
}

@code {
    [Parameter] public Guid CourseId { get; set; }
    [Parameter] public Guid LessonId { get; set; }

    private CourseDto? course;
    private CourseLessonDto? lesson;
    private string? moduleName;
    private CourseLessonDto? prevLesson;
    private CourseLessonDto? nextLesson;
    private bool loading = true;

    protected override async Task OnParametersSetAsync()
    {
        loading = true;
        course = await Api.GetMyCourseAsync(CourseId);
        if (course == null) { loading = false; return; }

        var allLessons = course.Modules
            .SelectMany(m => m.Lessons.Select(l => (Module: m, Lesson: l)))
            .ToList();

        var idx = allLessons.FindIndex(x => x.Lesson.Id == LessonId);
        if (idx < 0) { lesson = null; loading = false; return; }

        lesson = allLessons[idx].Lesson;
        moduleName = allLessons[idx].Module.Title;
        prevLesson = idx > 0 ? allLessons[idx - 1].Lesson : null;
        nextLesson = idx < allLessons.Count - 1 ? allLessons[idx + 1].Lesson : null;
        loading = false;
    }
}
