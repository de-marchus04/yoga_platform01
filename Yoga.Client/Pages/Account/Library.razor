@page "/account/library"
@layout CabinetLayout
@inject UserApiService Api
@inject NavigationManager Nav

<PageTitle>Библиотека</PageTitle>

<div class="cab-page-header">
    <h1 class="cab-page-title">Premium-библиотека</h1>
    <p class="cab-page-subtitle">Видео, гайды и материалы вашей подписки</p>
</div>

@if (loading)
{
    <div class="cab-library-grid">
        @for (int i = 0; i < 6; i++)
        {
            <div class="cab-lib-card cab-skeleton" style="min-height:160px"></div>
        }
    </div>
}
else if (resources.Count == 0)
{
    <div class="cab-empty">
        <div class="cab-empty-icon">📚</div>
        <p>Библиотека пока пуста</p>
        <p class="cab-empty-sub">Материалы появятся после подключения подписки</p>
    </div>
}
else
{
    <div class="cab-library-grid">
        @foreach (var r in resources)
        {
            <div class="cab-lib-card">
                <div class="cab-lib-card-body">
                    <div class="cab-lib-type-badge">@FormatType(r.ResourceType)</div>
                    <h3 class="cab-lib-card-title">@r.Title</h3>
                    @if (!string.IsNullOrEmpty(r.Description))
                    {
                        <p class="cab-lib-card-desc">@r.Description</p>
                    }
                </div>
                <div class="cab-lib-card-footer">
                    @if (r.Duration.HasValue)
                    {
                        <span class="cab-lib-duration">⏱ @r.Duration.Value.ToString(@"h\:mm")</span>
                    }
                    @if (!string.IsNullOrEmpty(r.MediaUrl))
                    {
                        <a href="@r.MediaUrl" target="_blank" class="cab-link-accent">Открыть →</a>
                    }
                    else if (r.IsPrivateMedia)
                    {
                        <button class="cab-link-accent"
                                style="background:none;border:none;cursor:pointer;padding:0;font:inherit;"
                                disabled="@openingIds.Contains(r.Id)"
                                @onclick="() => OpenProtectedResource(r.Id)">
                            @(openingIds.Contains(r.Id) ? "Подготавливаем..." : "Открыть →")
                        </button>
                    }
                    @if (resourceErrors.TryGetValue(r.Id, out var resourceError))
                    {
                        <div class="cab-empty-sub" style="margin-top:0.4rem;">@resourceError</div>
                    }
                </div>
            </div>
        }
    </div>
}

@code {
    private List<PremiumResourceDto> resources = new();
    private bool loading = true;
    private HashSet<Guid> openingIds = new();
    private Dictionary<Guid, string> resourceErrors = new();

    protected override async Task OnInitializedAsync()
    {
        resources = await Api.GetPremiumResourcesAsync();
        loading = false;
    }

    private async Task OpenProtectedResource(Guid id)
    {
        openingIds.Add(id);
        resourceErrors.Remove(id);
        try
        {
            var access = await Api.GetPremiumResourceAccessAsync(id);
            if (!string.IsNullOrWhiteSpace(access?.Url))
            {
                Nav.NavigateTo(access.Url, true);
                return;
            }

            resourceErrors[id] = "Не удалось подготовить ссылку. Попробуйте ещё раз.";
        }
        catch
        {
            resourceErrors[id] = "Ссылка истекла или временно недоступна. Запросите доступ ещё раз.";
        }
        finally
        {
            openingIds.Remove(id);
        }
    }

    private string FormatType(string type) => type switch
    {
        "video" => "🎬 Видео",
        "guide" => "📄 Гайд",
        "masterclass" => "🎓 Мастер-класс",
        "audio" => "🎧 Аудио",
        "document" => "📋 Документ",
        _ => type
    };
}
