@page "/forgot-password"
@inject UserApiService Api
@inject NavigationManager Nav

<PageTitle>Восстановление пароля</PageTitle>

<section class="auth-section">
    <div class="auth-visual">
        <div class="auth-visual-overlay"></div>
        <div class="auth-visual-content">
            <span class="brand-lockup auth-brand">
                <span class="brand-mark" aria-hidden="true">
                    <svg viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg" focusable="false">
                        <circle cx="32" cy="32" r="28.5" />
                        <path d="M32 13.5c4.9 6.2 7.4 11.9 7.4 17.1 0 6.1-2.5 11.1-7.4 15.2-4.9-4.1-7.4-9.1-7.4-15.2 0-5.2 2.5-10.9 7.4-17.1Z" />
                        <path d="M24.2 24.1c-6 1.2-10.1 4.7-12.5 10.5 6.8.3 12.2 2.8 16.3 7.6" />
                        <path d="M39.8 24.1c6 1.2 10.1 4.7 12.5 10.5-6.8.3-12.2 2.8-16.3 7.6" />
                        <path d="M21.4 49.6c3.3-2.9 6.9-4.3 10.6-4.3 3.8 0 7.3 1.4 10.6 4.3" />
                        <path d="M32 22.1c1.7 1.4 2.5 3.2 2.5 5.3S33.7 31.3 32 32.7c-1.7-1.4-2.5-3.2-2.5-5.3s.8-3.9 2.5-5.3Z" />
                    </svg>
                </span>
                <span class="brand-wordmark">
                    <span class="brand-prefix">sha</span><span class="brand-rest">kti.ashram</span>
                </span>
            </span>
        </div>
    </div>

    <div class="auth-form-panel">
        <div class="auth-card">
            @if (sent)
            {
                <div class="auth-eyebrow">✉️</div>
                <h1>Письмо отправлено</h1>
                <div class="auth-divider"></div>
                <p style="color:var(--auth-muted,#aaa);font-size:0.95rem;line-height:1.6">
                    Если аккаунт с таким email существует, мы отправили ссылку для сброса пароля.
                    Проверьте почту и папку «Спам».
                </p>
                <a href="/account/login" class="auth-submit" style="text-align:center;text-decoration:none;display:block;margin-top:1.5rem">
                    Вернуться к входу
                </a>
            }
            else
            {
                <div class="auth-eyebrow">Восстановление</div>
                <h1>Забыли пароль?</h1>
                <div class="auth-divider"></div>
                <p style="color:var(--auth-muted,#aaa);font-size:0.95rem;margin-bottom:1.5rem">
                    Введите email, указанный при регистрации. Мы отправим ссылку для сброса пароля.
                </p>

                @if (!string.IsNullOrEmpty(error))
                {
                    <div class="auth-error">@error</div>
                }

                <div class="auth-field">
                    <label class="auth-label" for="fp-email">Email</label>
                    <input id="fp-email" type="email" @bind="email" class="auth-input" placeholder="your@email.com" autocomplete="email" />
                </div>
                <button class="auth-submit" @onclick="HandleSubmit" disabled="@loading">
                    @(loading ? "Отправка..." : "Отправить ссылку")
                </button>
                <div style="text-align:center;margin-top:1rem">
                    <a href="/account/login" style="color:var(--auth-accent,#C9A96E);font-size:0.9rem;text-decoration:none">← Вернуться к входу</a>
                </div>
            }
        </div>
    </div>
</section>

@code {
    private string email = "";
    private string? error;
    private bool loading;
    private bool sent;

    private async Task HandleSubmit()
    {
        if (string.IsNullOrWhiteSpace(email)) { error = "Введите email"; return; }
        loading = true;
        error = null;
        await Api.ForgotPasswordAsync(email);
        sent = true;
        loading = false;
    }
}
